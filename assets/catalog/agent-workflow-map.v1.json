  "dirty_triage_policy": {
    "blocking_gates": [
      "closeout",
      "merge_ready",
      "cleanup"
    ],
    "states": {
      "active_parallel_agent": {
        "meaning": "A parallel worker still owns the dirty files.",
        "actions": [
          "track_owner",
          "preserve_scope",
          "wait_for_closeout",
          "integrate_evidence"
        ],
        "gate_effect": "does_not_block_intermediate_stages"
      },
      "completed_needs_integration": {
        "meaning": "A worker completed and its files need integration.",
        "actions": [
          "review_changed_paths",
          "integrate_claims",
          "run_validation",
          "record_state_update"
        ],
        "gate_effect": "blocks_closeout_until_integrated"
      },
      "abandoned_needs_review": {
        "meaning": "A worker stopped with dirty files that still need review.",
        "actions": [
          "freeze_scope",
          "review_changed_paths",
          "classify_value",
          "record_state_update"
        ],
        "gate_effect": "blocks_cleanup_until_classified"
      },
      "useful_abandoned_code": {
        "meaning": "Abandoned files contain usable work.",
        "actions": [
          "assign_fix_owner",
          "move_to_fix_wave",
          "validate_after_fix",
          "record_state_update"
        ],
        "gate_effect": "blocks_merge_ready_until_validated_or_removed"
      },
      "obsolete_cleanup_candidate": {
        "meaning": "Dirty files have no retained workflow value.",
        "actions": [
          "mark_cleanup_candidate",
          "wait_for_global_review",
          "cleanup_after_gate",
          "record_state_update"
        ],
        "gate_effect": "blocks_cleanup_until_reviewed"
      },
      "unsafe_dirty_blocker": {
        "meaning": "Dirty files may widen authority, expose restricted data, or corrupt workflow state.",
        "actions": [
          "stop_affected_scope",
          "isolate_files",
          "request_operator_review",
          "block_closeout_merge_ready_cleanup"
        ],
        "gate_effect": "blocks_closeout_merge_ready_cleanup"
      }
    }
  },
  "worker_state_policy": {
    "global_workflow_state_role": "index_and_aggregate_only",
    "worker_state_path_template": "runtime/agent-workflow/<goal_id>/workers/<worker_id>/worker-state.v1.json",
    "worker_write_scope": "A worker writes only its own worker-state.v1.json file.",
    "shared_aggregate_write_policy": "Workers must not write workflow-state directly; the aggregator refresh writes the shared aggregate from worker files.",
    "required_worker_file_fields": [
      "goal_id",
      "worker_id",
      "assigned_scope",
      "scope_lock",
      "current_stage",
      "status",
      "heartbeat_at",
      "changed_paths",
      "validation_evidence",
      "integration_status"
    ],
    "contention_policy": "Per-worker files avoid shared-file write collisions because concurrent workers never write the same workflow-state aggregate.",
    "orchestrator_non_blocking_policy": "Intermediate stages continue from worker heartbeats and aggregate index status; only closeout, merge_ready, and cleanup require resolved worker integration state.",
    "blocking_gates": [
      "closeout",
      "merge_ready",
      "cleanup"
    ]
  },
  "hook_automation_policy": {
    "status": "disabled_without_trust_proof",
    "scope": "local_only",
    "runtime_hook_registration": "not_changed_by_this_map",
    "trust_gate": {
      "required_proof": [
        "hook_trust",
        "effective_hooks"
      ],
      "default": "disabled",
      "enforcement": "Hooks may run only after local hook trust and effective-hooks proof exists."
    },
    "hooks": {
      "pre_task": {
        "writes": [
          "worker_state_file"
        ],
        "reads": [
          "assignment_packet"
        ],
        "actions": [
          "create_or_validate_worker_state",
          "create_or_validate_scope_lock"
        ],
        "forbidden_writes": [
          "workflow_state_aggregate"
        ]
      },
      "heartbeat": {
        "writes": [
          "worker_state_file"
        ],
        "reads": [
          "worker_state_file"
        ],
        "actions": [
          "update_heartbeat",
          "update_current_stage",
          "update_status"
        ],
        "forbidden_writes": [
          "workflow_state_aggregate",
          "other_worker_state_files"
        ]
      },
      "closeout": {
        "writes": [
          "worker_state_file"
        ],
        "reads": [
          "worker_state_file",
          "validation_evidence"
        ],
        "actions": [
          "record_worker_closeout",
          "record_validation_evidence",
          "mark_integration_needed"
        ],
        "forbidden_writes": [
          "workflow_state_aggregate"
        ]
      },
      "aggregator_index_refresh": {
        "writes": [
          "workflow_state_aggregate"
        ],
        "reads": [
          "worker_state_files"
        ],
        "actions": [
          "read_worker_files",
          "refresh_workflow_state_index",
          "refresh_workflow_state_aggregate"
        ],
        "forbidden_writes": [
          "worker_state_files"
        ]
      }
    },
    "contention_policy": "Workers write separate state files; the single aggregate refresh reads worker files and updates workflow-state without worker writes to the shared aggregate.",
    "orchestrator_non_blocking_policy": "Hook automation records progress locally and refreshes an index, so intermediate stages do not wait on shared-state locks.",
    "blocking_gates": [
      "closeout",
      "merge_ready",
      "cleanup"
    ]
  },
  "roles": {
    "bears-development-workflow-orchestrator": {
