        "rejected_claims"
      ]
    }
  },
  "invariants": [
    "agent-workflow-map.v1.json is the primary executable process authority",
    "constitution_gate must appear after route_gate and before research_gate",
    "spec_kit_gate must not run before design_gate",
    "validation must require evidence-bearing outputs",
    "global_review must run before closeout and merge_ready",
    "fix_wave must return to validation",
    "only closeout, merge_ready, and cleanup are blocking gates",
    "domain_orchestrator must not merge"
  ],
  "generated_mermaid": "flowchart TD\n  route_gate --> constitution_gate\n  constitution_gate --> research_gate\n  research_gate --> prototype_gate\n  prototype_gate --> design_gate\n  design_gate --> spec_kit_gate\n  spec_kit_gate --> role_gate\n  role_gate --> subagent_execution\n  subagent_execution --> validation\n  validation --> global_review\n  global_review --> stage_boundary_audit\n  stage_boundary_audit --> closeout\n  closeout --> merge_ready\n  merge_ready --> cleanup\n  global_review --> fix_wave\n  fix_wave --> validation"
}
