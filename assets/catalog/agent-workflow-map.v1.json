  "stages": {
    "route_gate": {
      "purpose": "Select exact path, repository, owner, registry entry, and candidate role.",
      "required_inputs": [
        "task_context",
        "target_path"
      ],
      "required_outputs": [
        "route_decision"
      ],
      "allowed_next": [
        "constitution_gate"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "constitution_gate": {
      "purpose": "Check subagents roles before research and implementation.",
      "required_inputs": [
        "subagents-roles.v1.json",
        "route_decision"
      ],
      "required_outputs": [
        "constitution_decision"
      ],
      "allowed_next": [
        "research_gate"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "research_gate": {
      "purpose": "Capture prior art, best practices, and interface constraints when required.",
      "required_inputs": [
        "constitution_decision"
      ],
      "required_outputs": [
        "research_evidence"
      ],
      "allowed_next": [
        "prototype_gate"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "prototype_gate": {
      "purpose": "Capture tested interaction or runtime shape for behavior path changes.",
      "required_inputs": [
        "research_evidence"
      ],
      "required_outputs": [
        "prototype_evidence"
      ],
      "allowed_next": [
        "design_gate"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "design_gate": {
      "purpose": "Produce deterministic design artifact before Spec Kit planning.",
      "required_inputs": [
        "prototype_evidence"
      ],
      "required_outputs": [
        "design_artifact"
      ],
      "allowed_next": [
        "spec_kit_gate"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "spec_kit_gate": {
      "purpose": "Require spec, plan, tasks, and analyze PASS before mutation.",
      "required_inputs": [
        "design_artifact"
      ],
      "required_outputs": [
        "spec_kit_pass"
      ],
      "allowed_next": [
        "role_gate"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "role_gate": {
      "purpose": "Prove task scope matches exactly one primary specialist or helper role.",
      "required_inputs": [
        "tasks",
        "platform-role-catalog.v1.json"
      ],
      "required_outputs": [
        "role_assignment"
      ],
      "allowed_next": [
        "subagent_execution"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "subagent_execution": {
      "purpose": "Run assigned agent roles under the orchestration policy.",
      "required_inputs": [
        "role_assignment",
        "task_contract"
      ],
      "required_outputs": [
        "agent_outputs",
        "execution_evidence"
      ],
      "allowed_next": [
        "validation"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "validation": {
      "purpose": "Run validators, tests, or E2E checks tied to changed surfaces.",
      "required_inputs": [
        "agent_outputs",
        "execution_evidence"
      ],
      "required_outputs": [
        "validation_evidence"
      ],
      "allowed_next": [
        "global_review"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "global_review": {
      "purpose": "Review integrated evidence once before closeout and merge-ready.",
      "required_inputs": [
        "validation_evidence",
        "dirty_triage_status"
      ],
      "required_outputs": [
        "global_review_result"
      ],
      "allowed_next": [
        "stage_boundary_audit",
        "fix_wave"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "stage_boundary_audit": {
      "purpose": "Record route, Spec Kit, role, validation, docs, and restricted-data status at the stage boundary.",
      "required_inputs": [
        "global_review_result"
      ],
      "required_outputs": [
        "stage_boundary_audit"
      ],
      "allowed_next": [
        "closeout"
      ],
      "blocking": false,
      "evidence_required": true
    },
    "closeout": {
      "purpose": "Close the workflow only after evidence, global review, and dirty triage are resolved.",
      "required_inputs": [
        "stage_boundary_audit",
        "global_review_result"
      ],
      "required_outputs": [
        "closeout_packet"
      ],
      "allowed_next": [
        "merge_ready"
      ],
      "blocking": true,
      "evidence_required": true
    },
    "merge_ready": {
      "purpose": "Mark merge-ready only after closeout, global review, and validation evidence are present.",
      "required_inputs": [
        "closeout_packet",
        "global_review_result"
      ],
      "required_outputs": [
        "merge_ready_packet"
      ],
      "allowed_next": [
        "cleanup"
      ],
      "blocking": true,
      "evidence_required": true
    },
    "cleanup": {
      "purpose": "Remove obsolete or unsafe dirty work only after merge-ready or explicit cleanup decision.",
      "required_inputs": [
        "merge_ready_packet",
        "dirty_triage_status"
      ],
      "required_outputs": [
        "cleanup_packet"
      ],
      "allowed_next": [],
      "blocking": true,
      "evidence_required": true
    },
    "fix_wave": {
      "purpose": "Apply assigned fixes from global review and return to validation.",
      "required_inputs": [
        "global_review_result",
        "fix_assignment"
      ],
      "required_outputs": [
        "fix_wave_output"
      ],
      "allowed_next": [
        "validation"
      ],
      "blocking": false,
      "evidence_required": true
    }
  },
