{
  "schema": "bears-agentic-enterprise-workflow.v1",
  "version": "1",
  "updated": "2026-06-22",
  "owner_plugin": "bears",
  "purpose": "Govern small, parallel L1/L2/L3 work across four repo domains while the Bears plugin remains a governance and control-plane overlay.",
  "plugin_boundary": {
    "plugin_role": "governance_control_plane",
    "plugin_is_governance_control_plane": true,
    "plugin_generates_repo_payload": false,
    "forbidden_surfaces": [
      "apps",
      "connectors",
      "mcp_servers",
      "runtime_services",
      "production_mutation",
      "product_code_generation",
      "gitops_generation",
      "infra_generation"
    ],
    "allowed_surfaces": [
      "catalogs",
      "schemas",
      "validators",
      "hooks",
      "roles",
      "docs",
      "fixtures",
      "compact_state_packets"
    ]
  },
  "repo_domains": [
    {
      "id": "platform",
      "purpose": "Reusable product core used by every product.",
      "owns": [
        "auth",
        "gateway",
        "queues",
        "redis",
        "shared_api_contracts",
        "tenant_registry",
        "provider_gateway"
      ],
      "must_not_own": [
        "cluster_desired_state",
        "host_bootstrap",
        "product_specific_runtime_overrides",
        "bears_governance_catalogs"
      ],
      "primary_l2_role": "l2-platform-domain-orchestrator",
      "transitional_evidence": []
    },
    {
      "id": "gitops",
      "purpose": "Desired state, promotion, rollback, policy, and secret references.",
      "owns": [
        "helm_values",
        "kustomize_overlays",
        "argo_flux_applications",
        "promotion_rules",
        "rollback_manifests",
        "secret_refs"
      ],
      "must_not_own": [
        "business_logic",
        "product_feature_code",
        "agent_governance_rules",
        "raw_secrets"
      ],
      "primary_l2_role": "l2-gitops-domain-orchestrator",
      "transitional_evidence": [
        "/srv/bears/kubernetes"
      ]
    },
    {
      "id": "infra",
      "purpose": "Shared host, cluster, network, bootstrap, and workspace runtime infrastructure.",
      "owns": [
        "host_bootstrap",
        "cluster_bootstrap",
        "networking",
        "codex_workspace_runtime",
        "shared_observability_runtime"
      ],
      "must_not_own": [
        "product_business_logic",
        "gitops_promotion_state",
        "product_specific_adapters",
        "raw_secret_values"
      ],
      "primary_l2_role": "l2-infra-domain-orchestrator",
      "transitional_evidence": [
        "/srv/bears/kubernetes"
      ]
    },
    {
      "id": "product_infra",
      "purpose": "Product-specific infrastructure adapters and runtime requirements.",
      "owns": [
        "product_runtime_requirements",
        "product_infra_adapters",
        "service_specific_resource_profiles",
        "product_observability_requirements"
      ],
      "must_not_own": [
        "shared_platform_core",
        "shared_host_bootstrap",
        "global_governance_catalogs",
        "production_desired_state_source"
      ],
      "primary_l2_role": "l2-product-infra-domain-orchestrator",
      "transitional_evidence": []
    }
  ],
  "scope_policy": {
    "small_scope_definition": "One repo_domain, one measurable output, one owner lineage, one timebox, one token budget, one validation path.",
    "one_domain_per_scope": true,
    "measurable_output_required": true,
    "timebox_required": true,
    "token_budget_required": true,
    "auto_split_triggers": [
      "multiple_repo_domains",
      "multiple_measurable_outputs",
      "missing_owner_lineage",
      "write_scope_overlap",
      "hard_split_threshold_exceeded",
      "timebox_over_policy",
      "token_budget_over_policy"
    ],
    "hard_split_threshold_min": 5,
    "max_timebox_min_default": 45,
    "max_token_budget_default": 12000,
    "task_decomposition_owner": "l1_head_orchestrator",
    "governance_owner": "l2_domain_orchestrator",
    "spawn_per_task_forbidden": true
  },
  "owner_lineage_policy": {
    "sticky_l2_by_domain": true,
    "sticky_l2_by_scope_family": true,
    "l3_bound_to_l2": true,
    "doc_l3_bound_to_l2": true,
    "role_profile_not_chat_memory": true,
    "required_fields": [
      "l2_owner_role",
      "l2_owner_id",
      "scope_family",
      "l3_executor_role",
      "l3_doc_role",
      "artifact_type"
    ]
  },
  "layer_workflow": {
    "l1_head_orchestrator": {
      "allowed_actions": [
        "strategy",
        "scope_matrix_write",
        "task_decomposition",
        "task_matrix_write",
        "compact_controller_state_read",
        "l2_governance_packet_write",
        "goal_block_or_unblock_from_state"
      ],
      "forbidden_actions": [
        "product_code_edit",
        "gitops_file_generation",
        "infra_mutation",
        "test_execution",
        "raw_log_read",
        "raw_subagent_message_ingest",
        "mcp_skill_plugin_discovery",
        "subagent_spawn_per_task"
      ],
      "max_context_files": 1
    },
    "l2_domain_orchestrator": {
      "allowed_actions": [
        "domain_research",
        "domain_governance",
        "scope_boundary_review",
        "l3_assignment_packet_review",
        "progress_packet_review",
        "remediation_scope_governance"
      ],
      "forbidden_actions": [
        "task_decomposition",
        "subagent_spawn_per_task",
        "global_l1_state_overwrite",
        "cross_domain_write_without_split",
        "final_merge_authority"
      ]
    },
    "l3_executor": {
      "allowed_actions": [
        "exact_task_execution",
        "schema_update",
        "fixture_update",
        "docs_update",
        "bounded_output_packet_write"
      ],
      "forbidden_actions": [
        "scope_redefinition",
        "owner_lineage_change",
        "raw_secret_read",
        "unbounded_search"
      ]
    }
  },
  "goal_agent_modes": {
    "goal_1_agent": {
      "required_sequence": [
        "create_own_state_file",
        "research",
        "decompose_operator_goal_prompt_into_scopes",
        "persist_scopes_in_state",
        "solve_scopes_sequentially_through_bears_spec_kit_flow",
        "use_helper_agents_for_token_economy_git_ci_cache_closeout_review_fix_support"
      ],
      "state_file": {
        "create_own_state_file_first": true
      },
      "scope_execution": {
        "order": "sequential",
        "flow": "bears_spec_kit_flow"
      },
      "helper_agents": {
        "required": true,
        "purposes": [
          "token_economy",
          "git_ci_cache_closeout",
          "review_fix_support"
        ],
        "fork_context": false,
        "parent_context": "none"
      },
      "review_fix_policy": {
        "real_blocker_only_stops_agent": true
      },
      "subagent_spawn_policy": {
        "fork_context": false,
        "parent_context": "none"
      }
    },
    "goal_parallel_l1": {
      "required_sequence": [
        "create_own_state_file",
        "normalize_operator_goal_prompt_into_scopes",
        "persist_scopes_in_state",
        "selected_scope_research",
        "selected_scope_development_area_design",
        "selected_scope_requirements",
        "selected_scope_spec_kit_logic",
        "spawn_l2_subagent_for_approved_spec_kit_plan",
        "continue_own_sequential_workflow"
      ],
      "state_file": {
        "create_own_state_file_first": true
      },
      "scope_execution": {
        "selected_scope_order": "sequential",
        "flow": "spec_kit_logic"
      },
      "l2_spawn": {
        "required": true,
        "step": "spawn_l2_subagent_for_approved_spec_kit_plan",
        "fork_context": false,
        "parent_context": "none",
        "l1_tracks_l2_after_spawn": false,
        "l1_waits_for_l2_after_spawn": false,
        "after_spawn_l1_execution": "continue_own_sequential_workflow"
      },
      "l2_helper_agents": {
        "required": true,
        "purposes": [
          "token_economy",
          "git_ci_cache_closeout",
          "review_fix_support"
        ],
        "fork_context": false,
        "parent_context": "none"
      },
      "subagent_spawn_policy": {
        "fork_context": false,
        "parent_context": "none"
      }
    }
  },
  "stage_order": [
    "scope_row",
    "research",
    "clarification_gate",
    "l1_task_decomposition",
    "l2_governance_review",
    "l3_assignment",
    "bounded_execution",
    "progress_packet",
    "local_commit_validation_read",
    "commit_to_main",
    "local_commit_validation_pass",
    "cache_sync_done",
    "effective_hooks_proof",
    "delivery_complete"
  ],
  "message_to_scope_rule": {
    "operator_message_creates_scope_row": true,
    "scope_row_requires_research_first": true,
    "operator_messages_count_must_equal_scope_rows_count": true,
    "missing_scope_row_status": "blocker"
  },
  "decision_log_policy": {
    "schema": "bears-decision-log.v1",
    "required_types": [
      "user_fact",
      "user_directive",
      "agent_decision",
      "contradiction",
      "needs_user_input"
    ],
    "user_input_has_priority_over_agent_decision": true,
    "contradiction_blocks_scope": true,
    "raw_chat_forbidden": true
  },
  "clarification_gate": {
    "ask_only_after_research": true,
    "allowed_reasons": [
      "architecture_cost_security_impact",
      "default_conflicts_with_saas_standard",
      "default_conflicts_with_agent_development_standard",
      "user_facts_or_directives_conflict"
    ],
    "default_action_without_allowed_reason": "continue_with_standard_default"
  },
  "hook_policy": {
    "hot_path_inputs": [
      "compact_state",
      "compiled_catalog",
      "plugin_delivery_state",
      "metadata_only_git_status"
    ],
    "slo_ms": {
      "PreToolUse": 150,
      "PreTask": 250,
      "SessionStart": 500,
      "Stop": 500
    },
    "forbidden_hot_path_actions": [
      "tests",
      "broad_search",
      "network",
      "raw_logs",
      "workspace_scan",
      "secret_read",
      "local_tests",
      "kubernetes_history_archaeology"
    ],
    "blocking_enabled_after_packet": "workflow_packet_approved",
    "session_start_initializes_l1_prompt": true,
    "plugin_installed_prevents_workflow_bypass": true,
    "state_file_path": "runtime/agent-workflow/current-enterprise-orchestrator-state/workflow-matrix/orchestrator-state.json",
    "session_start_creates_l1_state_file": true,
    "runtime_duration_from_state_started_at_epoch": true,
    "governed_missing_time_token_metadata_denied": true,
    "unmanaged_missing_metadata_warning": "control_not_armed",
    "local_test_execution_policy": {
      "default": "ci_owned",
      "explicit_operator_command_required": true,
      "forbidden_by_default": [
        "pytest",
        "python -m pytest",
        "python -m unittest",
        "npm test",
        "pnpm test",
        "yarn test",
        "go test",
        "cargo test",
        "gradle test",
        "./gradlew test",
        "mvn test",
        "smoke/integration/browser/docker/kubernetes test suites",
        "repo validator suites"
      ]
    },
    "kubernetes_history_read_policy": {
      "default": "current_state_only",
      "explicit_operator_task_required": true,
      "forbidden_by_default": [
        "/srv/bears/kubernetes/.git/**",
        "git log --all",
        "git reflog",
        "git branch -av",
        "git worktree list",
        "git show <old-sha>",
        "broad historical grep"
      ],
      "allowed_by_default": [
        "git status --short",
        "targeted current-file reads",
        "targeted current-file grep",
        "git show HEAD:<path>"
      ]
    },
    "ci_result_lookup_policy": {
      "current_commit_or_pr_only": true,
      "required_evidence_fields": [
        "commit_sha",
        "check_name",
        "status",
        "timestamp"
      ],
      "allowed_sources": [
        "GitHub Checks",
        "GitHub Actions",
        "commit statuses",
        "current PR artifacts"
      ],
      "stale_history_results_forbidden": true
    }
  },
  "runtime_degradation_policy": {
    "metrics": [
      "duration_min",
      "token_spend",
      "errors",
      "heartbeat_stale_minutes",
      "progress_delta"
    ],
    "actions": [
      "continue",
      "throttle_scope",
      "isolate_scope",
      "block_workflow",
      "rollback_runtime_activation"
    ],
    "time_ratio_isolate_threshold": 1.5,
    "token_ratio_throttle_threshold": 2.0,
    "stop_only_problem_scope": true,
    "unrelated_scopes_continue_parallel": true,
    "l1_during_stop": "open_l2_governance_review_only"
  },
  "symphony_pattern_mapping": {
    "adopted_patterns": [
      "issue_or_scope_as_state_machine",
      "single_authoritative_state",
      "isolated_workspace_or_write_scope",
      "proof_of_work_packet",
      "stall_restart_or_remediation"
    ],
    "not_adopted": [
      "vendored_symphony_code",
      "linear_only_control_plane",
      "broad_ticket_units_for_l1",
      "spawn_per_task_workflow"
    ]
  },
  "validation": {
    "command": "python3 scripts/agentic_enterprise_workflow.py validate",
    "schemas": [
      "assets/schemas/agentic-enterprise-workflow.v1.schema.json",
      "assets/schemas/decision-log.v1.schema.json",
      "assets/schemas/scope-matrix.v1.schema.json"
    ],
    "fixtures": [
      "tests/fixtures/agentic_enterprise_workflow/good/scope-matrix.valid.json",
      "tests/fixtures/agentic_enterprise_workflow/bad/scope-matrix.multi-domain.invalid.json",
      "tests/fixtures/agentic_enterprise_workflow/good/decision-log.valid.json",
      "tests/fixtures/agentic_enterprise_workflow/bad/decision-log.conflict-missing-contradiction.invalid.json"
    ]
  },
  "references": [
    "/srv/bears/platform-enterprise/docs/target-state/layer-boundaries.md",
    "/srv/bears/platform-enterprise/docs/target-state/workflow-lifecycle.md",
    "/srv/bears/platform-enterprise/docs/target-state/validation-hooks-spec.md",
    "/srv/bears/platform-enterprise/docs/target-state/codex-initialization-and-instructions.md",
    "https://github.com/openai/symphony",
    "https://github.com/openai/symphony/blob/main/SPEC.md",
    "https://openai.com/index/open-source-codex-orchestration-symphony/",
    "assets/catalog/plugin-cache-sync.v1.json",
    "assets/schemas/plugin-cache-sync-state.v1.schema.json"
  ],
  "delivery_policy": {
    "branch_model": "main_only",
    "task_commits_target": "main",
    "pull_request_required": false,
    "github_review_required": false,
    "final_stage": "delivery_complete",
    "delivery_complete_requires": [
      "commit_to_main",
      "local_commit_validation_pass",
      "cache_sync_done",
      "effective_hooks_proof"
    ],
    "state_file": "runtime/plugin-cache-sync/plugin-cache-sync-state.v1.json",
    "abandoned_task_definition": "plugin workflow task without delivery_complete=true after commit to main"
  }
}
