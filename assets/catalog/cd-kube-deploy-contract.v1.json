{
  "schema": "bears.cd-kube-deploy-contract.v1",
  "version": 1,
  "owner_plugin": "bears",
  "updated": "2026-07-07",
  "purpose": "Schema pointer for automatic Kubernetes CD. Environment-owned application descriptors and target mappings live outside plugin source and are passed with --cd-contract.",
  "git_contract_ref": "environment-owned git deploy contract",
  "application_descriptor_directory": "local_cd/applications",
  "applications": [],
  "evidence": {
    "sanitized_only": true,
    "forbidden": [
      "raw_secret",
      "kubeconfig",
      "token",
      "private_chat",
      "production_data",
      "raw_log"
    ]
  },
  "rollback": {
    "method": "commit_previous_environment_descriptor_and_manifest_state",
    "uses_same_git_contract": true,
    "uses_same_cd_contract": true
  },
  "rules": {
    "environment_contract_required": true,
    "plugin_source_contains_no_environment_targets": true,
    "executor_owns_cd_mechanics": true
  }
}
