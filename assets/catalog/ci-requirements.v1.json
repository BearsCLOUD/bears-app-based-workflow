  "cd_gate": {
    "runtime_apply_requires_degradation_continue": true,
    "delivery_branch": "main",
    "closeout_requires_cache_sync_done": true,
    "closeout_requires_effective_hooks_proof": true,
    "cache_sync_state_file": "runtime/plugin-cache-sync/plugin-cache-sync-state.v1.json",
    "cache_sync_script": "scripts/plugin_cache_sync.py",
    "diagnostic_summary_job": "ci-summary",
    "runtime_apply_requires_exact_commit_local_validation_pass": true,
    "local_validation_fail_creates_workflow_defect": "CI-owned diagnostic only; not an app-dev L2 blocker unless task packet declares hard blocker",
    "cache_sync_requires_exact_commit_local_validation_pass": true,
    "local_validation_proof_file": "runtime/local-commit-validation/<main_sha>.json",
    "github_diagnostics_automatic_on_push": true,
    "local_commit_hook": "post-commit",
    "local_commit_hooks": [
      "pre-commit",
      "post-commit"
    ],
    "blocking_local_commit_hook": "pre-commit",
    "proof_local_commit_hook": "post-commit",
    "github_push_ci_required_before_cache_sync": true,
    "github_push_ci_workflow": ".github/workflows/validate.yml",
    "cache_sync_runtime_scope": "local_codex_cache_on_this_host",
    "app_dev_direct_trigger_allowed": false,
    "full_proof_owner": "Dagger objective-runtime-proof through /srv/bears/dev/platform/dagger",
    "final_live_pass_owner": "/srv/bears/kubernetes kubernetes_deployment plus local_cd"
  },
  "local_gate_policy": {
    "pre_commit_blocks_only": [
      "secret_value_exposure",
      "raw_private_data",
      "forbidden_tracked_path",
      "repo_boundary_violation"
    ],
    "pre_commit_forbidden": [
      "tests",
      "validators",
      "lint",
      "schema validation",
      "Dagger",
      "Kubernetes checks",
      "local_cd",
      "long scripts"
    ],
    "post_commit": "automatic evidence only",
    "agent_closeout_rule": "Agents cite automatic commit/status evidence; they do not create local PASS layers."
  },
  "app_dev_status_matrix": {
    "scope": "L3 only",
    "unit": "one task equals one L3 commit",
    "l2_blocking": false,
    "required_evidence": [
      "commit_sha",
      "push_proof",
      "automatic_fast_statuses",
      "dagger_objective_runtime_proof_when_required",
      "kubernetes_deployment_plus_local_cd_when_live_required"
    ],
    "forbidden": [
      "app-dev direct CI trigger",
      "app-dev direct Dagger trigger",
      "app-dev direct local_cd trigger",
      "manual test or validator PASS"
    ]
  }
}
