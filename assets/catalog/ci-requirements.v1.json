{
  "schema": "bears-ci-requirements.v1",
  "version": "1",
  "owner_plugin": "bears",
  "purpose": "Automatic post-commit and GitHub push diagnostics for @Bears policy changes. Local pre-commit is safety-only and must not run development checks. App-dev consumes L3 status evidence; Dagger and Kubernetes local_cd own full/live PASS.",
  "trigger_policy": {
    "automatic_on_pull_request": false,
    "agent_manual_ci_dispatch_allowed": false,
    "allowed_events": [
      "push",
      "workflow_dispatch"
    ],
    "push_branches": [
      "main"
    ],
    "forbidden_agent_commands": [
      "/dispatches",
      "gh run rerun",
      "gh workflow run",
      "manual Dagger dispatch from app-dev",
      "manual local_cd dispatch from app-dev",
      "manual test suite dispatch",
      "manual validator suite dispatch",
      "repository_dispatch"
    ],
    "changed_path_diff_policy": {
      "local_post_commit": "HEAD^..HEAD",
      "reason": "Pre-commit is safety-only. Post-commit and GitHub push create automatic evidence for the exact commit. Agents must not run local check layers as PASS evidence.",
      "github_push": "HEAD^..HEAD"
    },
    "operator_emergency_dispatch_allowed": true,
    "automatic_local_on_commit": true,
    "automatic_github_on_commit": true,
    "local_commit_hook": "post-commit",
    "local_commit_hook_command": "python3 scripts/local_commit_validation.py install-hook",
    "local_commit_hooks": [
      "pre-commit",
      "post-commit"
    ],
    "blocking_local_commit_hook": "pre-commit",
    "proof_local_commit_hook": "post-commit",
    "pre_commit_scope": "safety_only",
    "post_commit_scope": "enqueue_or_record_automatic_evidence_only"
  },
  "parallel_jobs": [
    "changes",
    "schema-catalog-validation",
    "hook-policy-validation",
    "role-workflow-validation",
    "skill-inventory-validation",
    "dirty-boundary-validation",
    "ci-summary"
  ],
  "path_policy": {
    "hooks_changed_runs": [
      "hook-policy-validation"
    ],
    "schemas_or_catalogs_changed_runs": [
      "schema-catalog-validation",
      "role-workflow-validation"
    ],
    "skills_changed_runs": [
      "skill-inventory-validation"
    ],
    "workflow_core_changed_runs": [
      "schema-catalog-validation",
      "role-workflow-validation",
      "skill-inventory-validation",
      "dirty-boundary-validation"
    ],
    "dirty_boundary_changed_runs": [
      "dirty-boundary-validation"
    ],
    "docs_only_skips_automatic_tests": true
  },
  "test_policy": {
    "single_runner": "local_commit_validation",
    "forbidden_duplicate_runners": [
      "python3 -m unittest discover -s tests",
      "python3 -m pytest -q tests"
    ],
    "fast_command": "python3 scripts/local_commit_validation.py run --commit-sha HEAD",
    "fast_timeout_minutes": 12,
    "fast_target_minutes": 5,
    "warning_after_minutes": 8,
    "required_categories": [
      "fast",
      "integration",
      "slow"
    ],
    "new_test_requires_catalog_or_marker": "CI-owned only; agents must not create tests as PASS evidence",
