{
  "schema": "bears-deterministic-runners.v1",
  "version": "1",
  "updated": "2026-06-24",
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "runners": [
    {
      "id": "git_workflow_runner",
      "script": "scripts/git_workflow_runner.py",
      "packet_schema": "assets/schemas/git-workflow-runner-packet.v1.schema.json",
      "writes": "runtime/deterministic-runners/git/<command_id>.json"
    },
    {
      "id": "validation_job_runner",
      "script": "scripts/validation_job_runner.py",
      "packet_schema": "assets/schemas/validation-runner-packet.v1.schema.json",
      "writes": "runtime/deterministic-runners/validation/<command_id>.json"
    },
    {
      "id": "cache_sync_runner",
      "script": "scripts/cache_sync_runner.py",
      "packet_schema": "assets/schemas/cache-sync-runner-packet.v1.schema.json",
      "writes": "runtime/deterministic-runners/cache-sync/<command_id>.json"
    },
    {
      "id": "evidence_compactor",
      "script": "scripts/evidence_compactor.py",
      "packet_schema": "assets/schemas/evidence-compaction-packet.v1.schema.json",
      "writes": "runtime/deterministic-runners/evidence/<command_id>.json"
    }
  ],
  "forbidden_packet_fields": [
    "secret",
    "credential",
    "env_value",
    "private_chat",
    "unrestricted_diagnostics",
    "vpn_config",
    "production_data"
  ],
  "stdout_policy": "single_bounded_json_packet",
  "agent_rule": "Agents prepare and review packets. Runners execute repeatable procedures and write bounded evidence."
}
