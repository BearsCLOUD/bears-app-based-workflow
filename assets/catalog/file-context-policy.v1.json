{
  "schema": "bears-file-context-policy.v1",
  "version": "1",
  "updated": "2026-06-25",
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "index": "assets/file-context/index.v1.json",
  "commands": [
    "python3 scripts/file_context_index.py validate",
    "python3 scripts/file_context_index.py scan --paths <paths> --json",
    "python3 scripts/file_context_index.py build-index --json",
    "python3 scripts/file_context_index.py select --path <path> --role <role_id> --json",
    "python3 scripts/file_context_index.py stale --json",
    "python3 scripts/file_context_refresh.py refresh --path <path> --json",
    "python3 scripts/file_context_refresh.py gc --json",
    "python3 scripts/file_context_index.py doctor --json"
  ],
  "read_policy": {
    "default": "summary_first",
    "full_read_requires_reason": true,
    "stale_write_execution": "blocked"
  },
  "governed_path_patterns": [
    "assets/catalog/*.v1.json",
    "assets/schemas/*.v1.schema.json",
    "scripts/*.py",
    "docs/reference/*.md"
  ],
  "exempt_path_patterns": [
    "tests/**",
    "runtime/**",
    ".pytest_cache/**",
    ".ruff_cache/**"
  ],
  "required_context_paths": [
    "scripts/goal_orchestrator.py",
    "scripts/bears_doctor.py",
    "assets/catalog/goal-orchestrator.v1.json",
    "assets/catalog/bears-doctor.v1.json",
    "assets/catalog/file-context-policy.v1.json",
    "scripts/file_context_index.py",
    "scripts/file_context_refresh.py"
  ],
  "integration_points": {
    "bears_doctor": "file_context_freshness",
    "goal_orchestrator": "context_selector_before_role_plan",
    "decision_ledger": "context_ids_used",
    "artifact_registry": "tracked_context_assets"
  }
}
