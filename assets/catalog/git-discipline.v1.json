{
  "schema": "bears-git-discipline.v1",
  "owner_plugin": "bears",
  "concrete_part": "git_discipline",
  "updated": "2026-06-25",
  "purpose": "Deterministic Git closeout gate for status capture, validation evidence, staging, commit, post-commit cleanliness checks, and read-only branch cleanup classification.",
  "route_target": "/srv/bears/plugins/bears/scripts/git_discipline.py",
  "reference_doc": "/srv/bears/plugins/bears/docs/reference/git-discipline.md",
  "validation": {
    "commands": [
      "python3 scripts/platform_roles.py validate",
      "python3 scripts/platform_roles.py route /srv/bears/plugins/bears/scripts/git_discipline.py",
      "python3 scripts/git_discipline.py validate",
      "python3 -m unittest discover -s tests"
    ],
    "requires_exact_role_route": true
  },
  "closeout_order": [
    {
      "step": "status_before",
      "command": "git status --short --branch",
      "required_before": "validation"
    },
    {
      "step": "diff_check_before_stage",
      "command": "git diff --check",
      "required_before": "validation"
    },
    {
      "step": "surface_validation",
      "command": "run validators and tests tied to changed files",
      "required_before": "stage"
    },
    {
      "step": "stage_all_requested_repo_changes",
      "command": "git add -A",
      "required_before": "commit"
    },
    {
      "step": "cached_diff_check",
      "command": "git diff --cached --check",
      "required_before": "commit"
    },
    {
      "step": "safe_worker_git_identity_preflight",
      "command": "python3 scripts/git_discipline.py inspect --repo <repo> --json",
      "required_before": "commit_authority"
    },
    {
      "step": "commit",
      "command": "git commit -m \"<imperative English summary>\"",
      "required_before": "post_commit_status"
    },
    {
      "step": "post_commit_status",
      "command": "git status --short --branch",
      "required_before": "report"
    }
  ],
  "command_policy": {
    "validator_is_read_only": true,
    "mutating_git_commands_require_operator_request": true,
    "push_requires_explicit_operator_request": true,
    "commit_message_language": "English",
    "commit_message_style": "imperative summary",
    "forbidden_automatic_commands": [
      "git push",
      "git reset",
      "git clean",
      "git checkout",
      "git switch",
      "git stash",
      "git merge",
      "git rebase",
      "git revert",
      "git config --global"
    ],
    "safe_worker_git_identity": {
      "required_before_commit_authority": true,
      "user_name": "Bears Codex Worker",
      "user_email": "codex-worker@bears.local",
      "fixed_public_identity_label": "Bears Codex Worker <codex-worker@bears.local>",
      "allowed_config_sources": [
        "local"
      ],
      "global_config_source_allowed": false,
      "automatic_global_config_mutation_allowed": false,
      "provider_account_profile_lookup_allowed": false,
      "missing_or_unsafe_status": "GIT_DISCIPLINE_BLOCKED",
      "preflight_output_fields": [
        "worker_git_identity_configured",
        "worker_git_identity_label"
      ]
    }
  },
  "path_safety": {
    "secret_path_fragments_block_commit": [
      ".env",
      "id_rsa",
      "id_ed25519",
      "private_key",
      "token",
      "credential",
      "credentials",
      "secret",
      "secrets"
    ],
    "raw_log_fragments_require_operator_review": [
      ".log",
      "logs/",
      "shell_history",
      "history"
    ],
    "external_workspace_changes_must_be_reported": true,
    "raw_file_content_scan_allowed": false,
    "allowed_changed_paths_required_for_closeout": true,
    "dirty_worktree_blocker_status": "DIRTY_WORKTREE_BLOCKER",
    "canonical_plugin_checkout_policy": {
      "canonical_root": "/srv/bears/plugins/bears",
      "hidden_temporary_worktree_default_allowed": false,
      "before_plugin_edits_required_checks": [
        "pwd equals canonical_root or task packet names an approved isolated worktree",
        "git rev-parse --show-toplevel equals canonical_root for canonical checkout work",
        "git config --get core.worktree is empty or equals canonical_root",
        "git status --short --branch is captured for canonical_root"
      ],
      "temporary_worktree_exception_requires": [
        "operator approval or issue assignment packet naming the isolated worktree",
        "canonical_root dirty-state backup path",
        "sync-back plan to canonical_root before closeout",
        "bears_doctor canonical_plugin_worktree pass before final report"
      ],
      "forbidden_closeout_states": [
        "PLUGIN_TOPLEVEL_REDIRECTED",
        "PLUGIN_CORE_WORKTREE_MISMATCH",
        "PLUGIN_CLOSEOUT_FROM_TEMP_WORKTREE",
        "UNSYNCED_CANONICAL_CHECKOUT",
        "PLUGIN_CWD_MISMATCH"
      ],
      "operator_report_required_fields": [
        "canonical_root",
        "actual_toplevel",
        "core_worktree",
        "dirty_backup_path",
        "sync_back_status"
      ]
    },
    "secret_path_exception_roots": [
      "agents/bears-secret-factory-engineer.toml",
      "assets/catalog/secret-factory.v1.json",
      "docs/reference/secret-factory.md",
      "scripts/secret_factory.py",
      "skills/secret-factory/SKILL.md",
      "tests/test_secret_factory.py"
    ],
    "closeout_preflight": {
      "required_for_ledger_gitlink_closeout": true,
      "allowed_paths_required": true,
      "current_branch_must_match_task": true,
      "carry_forward_list_is_allowed_paths": true,
      "gitlink_object_proof_required": true,
      "output_schema": "bears-git-closeout-preflight.v1",
      "command": "python3 scripts/git_discipline.py closeout-preflight --repo <repo> --allowed-path <path> --expected-branch-prefix <branch-prefix> --gitlink-proof <path>:<old-object>:<target-object>:<source-pr-merge-commit> --json",
      "required_output_fields": [
        "schema",
        "repo_root",
        "branch",
        "head",
        "status",
        "closeout_allowed",
        "commit_allowed_after_validation",
        "allowed_changed_paths",
        "disallowed_changed_paths",
        "gitlink_proofs",
        "block_reasons",
        "read_only"
      ]
    }
  },
  "output_contract": {
    "schema": "bears-git-discipline-inspection.v1",
    "top_level_required": [
      "schema",
      "repo_root",
      "branch",
      "head",
      "generated_at",
      "status",
      "worktree_dirty",
      "staged_dirty",
      "unstaged_dirty",
      "untracked_count",
      "diff_check_passed",
      "cached_diff_check_passed",
      "operator_review_required",
      "push_allowed",
      "commit_allowed_after_validation",
      "changed_paths",
      "allowed_changed_paths",
      "disallowed_changed_paths",
      "worker_git_identity_configured",
      "worker_git_identity_label"
    ],
    "blocked_statuses": [
      "GIT_DISCIPLINE_BLOCKED",
      "GIT_DISCIPLINE_REQUIRES_OPERATOR_REVIEW",
      "DIRTY_WORKTREE_BLOCKER"
    ],
    "ready_status": "GIT_DISCIPLINE_READY"
  },
  "dirty_triage_policy": {
    "validator_is_read_only": true,
    "unclosed_changes_require_classification": true,
    "state_machine": {
      "outcomes": [
        "active_parallel_agent",
        "completed_needs_integration",
        "abandoned_needs_review",
        "useful_abandoned_code",
        "obsolete_cleanup_candidate",
        "unsafe_dirty_blocker"
      ],
      "actions": {
        "active_parallel_agent": [
          "protect_branch",
          "coordinate_with_active_owner",
          "block_auto_delete"
        ],
        "completed_needs_integration": [
          "protect_branch",
          "request_integration_review",
          "block_auto_delete"
        ],
        "abandoned_needs_review": [
          "protect_branch",
          "request_owner_review",
          "block_auto_delete"
        ],
        "useful_abandoned_code": [
          "create_narrow_integration_assignment",
          "block_auto_cherry_pick",
          "block_auto_delete"
        ],
        "obsolete_cleanup_candidate": [
          "require_cleanup_plan_proof",
          "allow_safe_local_cleanup_only"
        ],
        "unsafe_dirty_blocker": [
          "block_auto_delete",
          "request_operator_review"
        ]
      },
      "active_parallel_agent_proofs": [
        "active_worker_state",
        "heartbeat",
        "scope_lock",
        "open_pr",
        "live_session_proof"
      ]
    },
    "useful_abandoned_code": {
      "narrow_integration_assignment_required": true,
      "auto_cherry_pick_allowed": false
    },
    "cleanup_rules": {
      "auto_cleanup_requires_cleanup_plan_proof": true,
      "safe_local_candidates_only": true,
      "remote_delete_requires_explicit_cleanup_authority": true,
      "unknown_ownership_auto_delete_allowed": false,
      "open_pr_auto_delete_allowed": false,
      "attached_worktree_auto_delete_allowed": false,
      "backup_dirty_branch_auto_delete_allowed": false,
      "cleanup_eligibility_requires_closeout_or_merge_ready": true,
      "normal_worker_progress_cleanup_allowed": false
    },
    "required_inventory_fields": [
      "dirty_triage_outcome",
      "dirty_triage_actions",
      "dirty_triage_proofs",
      "cleanup_plan_proof",
      "cleanup_authority",
      "owner_known",
      "auto_delete_allowed"
    ],
    "worker_state_files": {
      "per_worker_state_files_required_for_concurrent_workers": true,
      "root_workflow_state_still_supported": true,
      "read_only_hook_collection_allowed": true,
      "hook_collection_must_not_delete_or_mutate_git": true,
      "accepted_active_proofs": [
        "active_worker_state",
        "heartbeat",
        "scope_lock",
        "open_pr",
        "live_session_proof"
      ],
      "cli_flags": [
        "--workflow-state-json",
        "--worker-state-json"
      ]
    }
  },
  "branch_cleanup_policy": {
    "validator_is_read_only": true,
    "inventory_required_before_branch_delete": true,
    "github_pr_state_must_be_checked_before_unmerged_claim": true,
    "squash_merge_safe_classification_required": true,
    "worktree_branch_delete_blocked": true,
    "backup_dirty_branch_delete_blocked": true,
    "remote_delete_requires_explicit_operator_request": true,
    "mutating_cleanup_commands_require_operator_request": true,
    "backup_dirty_prefixes": [
      "backup/",
      "codex/bears-plugin-stash-backup-",
      "codex/bears-plugin-other-dirty-"
    ],
    "required_branch_classes": [
      "main_branch",
      "worktree_attached",
      "backup_dirty_preserve",
      "github_merged_cleanup_candidate",
      "ancestry_merged_cleanup_candidate",
      "closed_unmerged_review_required",
      "open_pr_review_required",
      "remote_branch_without_pr_review_required",
      "local_only_review_required"
    ],
    "safe_local_delete_classes": [
      "github_merged_cleanup_candidate",
      "ancestry_merged_cleanup_candidate"
    ],
    "blocked_delete_classes": [
      "main_branch",
      "worktree_attached",
      "backup_dirty_preserve",
      "closed_unmerged_review_required",
      "open_pr_review_required",
      "remote_branch_without_pr_review_required",
      "local_only_review_required"
    ],
    "required_inventory_fields": [
      "branch",
      "head",
      "upstream",
      "remote_exists",
      "worktree_attached",
      "worktree_path",
      "merged_into_base_by_ancestry",
      "github_pr_numbers",
      "github_pr_states",
      "creation_hint",
      "cleanup_class",
      "local_delete_eligible",
      "delete_blocked_reason",
      "dirty_triage_outcome",
      "dirty_triage_actions",
      "dirty_triage_proofs",
      "cleanup_plan_proof",
      "cleanup_authority",
      "owner_known",
      "auto_delete_allowed"
    ],
    "forbidden_automatic_commands": [
      "git branch -d",
      "git branch -D",
      "git push origin --delete",
      "git worktree prune",
      "git remote prune",
      "git fetch --prune"
    ],
    "issue_mapping": {
      "BearsCLOUD/bears_plugin#133": "clean_worktree_and_gitlink_closeout_guard",
      "BearsCLOUD/bears_plugin#88": "branch_base_preflight",
      "BearsCLOUD/bears_plugin#144": "codex_branch_prefix_governance",
      "BearsCLOUD/bears_plugin#128": "gitlink_sync_target_audit",
      "BearsCLOUD/bears_plugin#132": "merge_authority_lane",
      "BearsCLOUD/bears_plugin#120": "durable_pass_evidence_before_merge_handoff"
    },
    "remote_inventory_required_before_remote_delete": true,
    "post_merge_closeout_gate": {
      "required_after_pr_merge": true,
      "must_report_zero_local_delete_eligible": true,
      "must_report_zero_remote_delete_eligible": true,
      "worktree_attached_merged_branch_blocks_closeout": true,
      "output_schema": "bears-git-branch-closeout-gate.v1",
      "command": "python3 scripts/git_discipline.py branch-closeout-gate --repo <repo> --base <base> --github-prs-json <prs.json> --json"
    },
    "required_remote_branch_classes": [
      "remote_main_branch",
      "remote_tracking_local_present",
      "remote_github_merged_cleanup_candidate",
      "remote_ancestry_merged_cleanup_candidate",
      "remote_open_pr_review_required",
      "remote_closed_unmerged_review_required",
      "remote_without_pr_review_required"
    ],
    "safe_remote_delete_classes": [
      "remote_github_merged_cleanup_candidate",
      "remote_ancestry_merged_cleanup_candidate"
    ],
    "required_remote_inventory_fields": [
      "branch",
      "remote_ref",
      "head",
      "local_branch_exists",
      "merged_into_base_by_ancestry",
      "github_pr_numbers",
      "github_pr_states",
      "cleanup_class",
      "remote_delete_eligible",
      "delete_blocked_reason",
      "dirty_triage_outcome",
      "dirty_triage_actions",
      "dirty_triage_proofs",
      "cleanup_plan_proof",
      "cleanup_authority",
      "owner_known",
      "auto_delete_allowed"
    ],
    "gitlink_target_audit": {
      "required_for_gitlink_closeout": true,
      "local_checkout_must_match_parent_target_for_local_claims": true,
      "stale_local_checkout_blocks_local_claims": true,
      "output_schema": "bears-gitlink-target-audit.v1",
      "command": "python3 scripts/git_discipline.py gitlink-audit --repo <parent-repo> --tree-ref <ref> --path <gitlink-path> --expected-target <sha> --local-checkout <path> --json",
      "required_output_fields": [
        "schema",
        "repo_root",
        "tree_ref",
        "gitlink_path",
        "parent_gitlink_target",
        "expected_target",
        "local_checkout",
        "local_checkout_head",
        "local_checkout_status",
        "claim_source",
        "claim_object_used",
        "local_checkout_evidence_usable",
        "status",
        "read_only"
      ]
    },
    "branch_prefix_policy": {
      "default_prefix": "codex/",
      "assignment_override_required_for_non_default": true,
      "required_before_push_or_pr": true,
      "output_schema": "bears-branch-prefix-check.v1",
      "command": "python3 scripts/git_discipline.py branch-prefix-check --branch <branch> --assignment-packet <assignment.json> --json",
      "required_output_fields": [
        "schema",
        "branch",
        "default_prefix",
        "assignment_packet",
        "override_prefix",
        "override_used",
        "status",
        "branch_prefix_check",
        "read_only"
      ]
    },
    "local_delete_requires_cleanup_plan_proof": true,
    "unknown_ownership_delete_blocked": true
  }
}
