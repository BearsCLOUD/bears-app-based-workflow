{
  "schema": "bears-git-hook-bootstrap.v1",
  "version": "1",
  "updated": "2026-07-07",
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "plugin_reference": "@bears",
  "default_workspace_root": "<generated-local-config:workspace_root>",
  "shared_runner": "scripts/bears_git_hook.py",
  "thin_hooks": [
    {
      "name": "pre-commit",
      "mode": "single_fast_smoke",
      "allowed_actions": [
        "detect_repo_boundary",
        "detect_worktree_path",
        "run_one_staged_diff_smoke_under_5_seconds",
        "write_effective_hook_proof"
      ],
      "forbidden_actions": [
        "create_test_or_validator",
        "print_secret",
        "print_unbounded_output",
        "read_raw_chat",
        "read_raw_log",
        "read_secret",
        "run_dagger",
        "run_kubernetes_check",
        "run_lint",
        "run_local_cd",
        "run_long_validator",
        "run_schema_validation",
        "run_test_suite",
        "solve_github_issue"
      ]
    },
    {
      "name": "post-commit",
      "mode": "proof_only",
      "allowed_actions": [
        "detect_commit_sha",
        "write_effective_hook_proof",
        "exit_without_worker_execution"
      ],
      "forbidden_actions": [
        "create_test_or_validator",
        "print_secret",
        "print_unbounded_output",
        "read_raw_chat",
        "read_raw_log",
        "read_secret",
        "run_dagger",
        "run_kubernetes_check",
        "run_lint",
        "run_local_cd",
        "run_long_validator",
        "run_schema_validation",
        "run_test_suite",
        "solve_github_issue"
      ]
    }
  ],
  "runtime_paths": {
    "effective_hooks": "runtime/effective-hooks/<repo_id>/effective-hooks-proof.v1.json"
  },
  "bounded_spawn": {
    "enabled": false,
    "auto_start": false,
    "mode": "disabled_by_default",
    "reason": "Hooks never start validation workers. Runtime status comes from Sentry.",
    "command_template": [],
    "timeout_seconds": 5
  },
  "stdout_policy": "single_bounded_json_event",
  "proof_schema": "assets/schemas/effective-hooks-proof.v1.schema.json",
  "component_issue": "#390",
  "authoritative_artifacts": [
    "assets/catalog/git-hook-bootstrap.v1.json",
    "assets/schemas/effective-hooks-proof.v1.schema.json",
    "scripts/bears_git_hook.py",
    "tests/test_bears_git_hook.py",
    "tests/fixtures/git_hook_bootstrap/good/effective-hooks-proof.json",
    "tests/fixtures/git_hook_bootstrap/bad/missing-bears-reference.json",
    "docs/reference/git-hook-bootstrap.md"
  ],
  "commands": [
    {
      "name": "install",
      "argv": [
        "python3",
        "scripts/bears_git_hook.py",
        "install",
        "--repo-path",
        "<repo_path>"
      ],
      "writes": [
        "repo-local thin hooks",
        "runtime/effective-hooks/<repo_id>/effective-hooks-proof.v1.json"
      ]
    },
    {
      "name": "run",
      "argv": [
        "python3",
        "scripts/bears_git_hook.py",
        "run",
        "--hook",
        "<hook>",
        "--repo-path",
        "<repo_path>"
      ],
      "writes": [
        "runtime/effective-hooks/<repo_id>/effective-hooks-proof.v1.json"
      ]
    },
    {
      "name": "verify",
      "argv": [
        "python3",
        "scripts/bears_git_hook.py",
        "verify",
        "--repo-path",
        "<repo_path>"
      ],
      "writes": []
    },
    {
      "name": "write-proof",
      "argv": [
        "python3",
        "scripts/bears_git_hook.py",
        "write-proof",
        "--repo-path",
        "<repo_path>"
      ],
      "writes": [
        "runtime/effective-hooks/<repo_id>/effective-hooks-proof.v1.json"
      ]
    },
    {
      "name": "validate-proof",
      "argv": [
        "python3",
        "scripts/bears_git_hook.py",
        "validate-proof",
        "--proof",
        "<proof_path>"
      ],
      "writes": []
    },
    {
      "name": "validate",
      "argv": [
        "python3",
        "scripts/bears_git_hook.py",
        "validate"
      ],
      "writes": []
    }
  ],
  "policy_summary": "Pre-commit runs one staged diff smoke under 5 seconds. Post-commit records hook proof only. Runtime status and no-error state come from Sentry."
}
