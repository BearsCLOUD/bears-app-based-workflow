{
  "schema": "bears-gitops-workflow.v1",
  "version": "1",
  "owner_issue": "#421",
  "states": [
    "planned",
    "committed",
    "validated",
    "synced",
    "degraded",
    "rollback_required",
    "rolled_back",
    "manual_review",
    "closed"
  ],
  "degradation_signals": [
    "post_commit_validation_fail",
    "cache_sync_missing",
    "hook_proof_missing",
    "diagnostics_failed",
    "repo_routing_mismatch",
    "tracked_runtime_file",
    "release_gate_missing",
    "authority_map_mismatch",
    "stale_delivery_manifest",
    "issue_closeout_failed",
    "infra_evidence_missing",
    "infra_evidence_stale",
    "infra_validator_failed",
    "infra_rollout_diagnostics_redaction_failed",
    "infra_bundle_provenance_missing",
    "infra_public_route_policy_failed",
    "infra_runtime_egress_policy_failed",
    "infra_runtime_health_policy_failed",
    "infra_plugin_ref_unpinned"
  ],
  "commands": [
    "scripts/gitops_workflow.py validate",
    "scripts/gitops_workflow.py state --delivery-id <id> --json",
    "scripts/gitops_workflow.py transition --packet <path>",
    "scripts/gitops_degradation.py scan --delivery-id <id> --json",
    "scripts/gitops_degradation.py scan --delivery-id <id> --infra-evidence <path> --json",
    "scripts/gitops_degradation.py doctor --json"
  ],
  "evidence_authority": [
    "runtime/deliveries/<delivery_id>/delivery-manifest.v1.json",
    "runtime/local-commit-validation/<commit_sha>.json",
    "runtime/plugin-cache-sync/plugin-cache-sync-state.v1.json",
    "runtime/effective-hooks/plugins_bears/effective-hooks-proof.v1.json",
    "runtime/commit-usage-ledger/<commit_sha>.json",
    "assets/catalog/gitops-workflow.v1.json",
    "runtime/cross-repo-infra-evidence/<delivery_id>.json",
    "assets/catalog/cross-repo-infra-evidence.v1.json"
  ],
  "transitions": [
    {
      "from_state": "planned",
      "to_state": "committed",
      "guard": "main_commit",
      "required_evidence": [
        "delivery_manifest",
        "commit_sha"
      ]
    },
    {
      "from_state": "committed",
      "to_state": "validated",
      "guard": "local_commit_validation_pass",
      "required_evidence": [
        "local_commit_validation"
      ]
    },
    {
      "from_state": "validated",
      "to_state": "synced",
      "guard": "cache_sync_pass",
      "required_evidence": [
        "plugin_cache_sync"
      ]
    },
    {
      "from_state": "synced",
      "to_state": "closed",
      "guard": "closeout_pass",
      "required_evidence": [
        "issue_closeout",
        "hook_proof",
        "commit_usage_ledger"
      ]
    },
    {
      "from_state": "committed",
      "to_state": "degraded",
      "guard": "degradation_event",
      "required_evidence": [
        "gitops_degradation_event"
      ]
    },
    {
      "from_state": "validated",
      "to_state": "degraded",
      "guard": "degradation_event",
      "required_evidence": [
        "gitops_degradation_event"
      ]
    },
    {
      "from_state": "synced",
      "to_state": "degraded",
      "guard": "degradation_event",
      "required_evidence": [
        "gitops_degradation_event"
      ]
    },
    {
      "from_state": "degraded",
      "to_state": "rollback_required",
      "guard": "workflow_surface_mutated",
      "required_evidence": [
        "rollback_policy"
      ]
    },
    {
      "from_state": "rollback_required",
      "to_state": "rolled_back",
      "guard": "rollback_complete",
      "required_evidence": [
        "rollback_packet"
      ]
    },
    {
      "from_state": "degraded",
      "to_state": "manual_review",
      "guard": "role_audit_or_manual_review",
      "required_evidence": [
        "degradation_event"
      ]
    },
    {
      "from_state": "rolled_back",
      "to_state": "closed",
      "guard": "closeout_pass",
      "required_evidence": [
        "issue_closeout",
        "rollback_packet"
      ]
    }
  ],
  "remediation_policy": {
    "post_commit_validation_fail": "retry",
    "cache_sync_missing": "retry",
    "hook_proof_missing": "manual_review",
    "diagnostics_failed": "manual_review",
    "repo_routing_mismatch": "role_audit",
    "tracked_runtime_file": "rollback",
    "release_gate_missing": "retry",
    "authority_map_mismatch": "role_audit",
    "stale_delivery_manifest": "retry",
    "issue_closeout_failed": "manual_review",
    "infra_evidence_missing": "retry",
    "infra_evidence_stale": "retry",
    "infra_validator_failed": "manual_review",
    "infra_rollout_diagnostics_redaction_failed": "manual_review",
    "infra_bundle_provenance_missing": "retry",
    "infra_public_route_policy_failed": "manual_review",
    "infra_runtime_egress_policy_failed": "manual_review",
    "infra_runtime_health_policy_failed": "manual_review",
    "infra_plugin_ref_unpinned": "manual_review"
  },
  "rollback_policy": {
    "required_for_surfaces": [
      "workflow",
      "hook",
      "validation",
      "autostart"
    ],
    "command": "git revert <sha> && python3 scripts/local_commit_validation.py run --commit-sha <new_sha> --timeout-seconds 600",
    "closeout_block": "rollback_required delivery cannot close without rollback_packet evidence"
  }
}
