{
  "schema": "bears-objective-runtime-proof-policy.v1",
  "version": "1",
  "owner": "@Bears",
  "platform_dagger_module": "/srv/bears/dev/platform/dagger",
  "platform_dagger_manifest": "/srv/bears/dev/platform/dagger.json",
  "artifact_root": "runtime/objective-runtime-proof",
  "required_entrypoints": [
    "dagger call runtime-proof-location --app <app>",
    "DAGGER_ENGINE_POD_NAME=$(kubectl get pod --selector=name=dagger-dagger-helm-engine --namespace=dagger --output=jsonpath='{.items[0].metadata.name}')",
    "_EXPERIMENTAL_DAGGER_RUNNER_HOST=kube-pod://$DAGGER_ENGINE_POD_NAME?namespace=dagger dagger call objective-runtime-proof --source /srv/bears/dev/app --app <app> --scenario <scenario>"
  ],
  "final_live_owner": "/srv/bears/kubernetes",
  "final_live_required_refs": [
    "kubernetes_deployment",
    "local_cd",
    "image_provenance",
    "name_only_secret_refs",
    "workload_evidence",
    "runtime_health"
  ],
  "forbidden_pass_evidence": [
    "app_dev_direct_trigger",
    "ci_status_without_runtime_scenario",
    "contracts",
    "docker_run",
    "lint",
    "local_host_processes",
    "local_infisical_helpers",
    "manual_kubectl_apply",
    "schemas",
    "static_checks",
    "tests",
    "validators"
  ],
  "migration_instruction": "When a validation-layer artifact is found, migrate behavior into a Kubernetes-backed Dagger runtime scenario or remove the obsolete acceptance reference.",
  "runtime_owner": "/srv/bears/kubernetes",
  "dagger_engine_manifest_path": "/srv/bears/kubernetes/manifests/dagger-engine",
  "dagger_engine_namespace": "dagger",
  "dagger_engine_workload": "daemonset/dagger-engine",
  "dagger_engine_pod_selector": "name=dagger-dagger-helm-engine",
  "runner_host_env": "_EXPERIMENTAL_DAGGER_RUNNER_HOST",
  "methodology": "fixed_dagger_objective_runtime_proof",
  "app_dev_integration": {
    "mode": "status_matrix_evidence_only",
    "scope": "L3 task closeout",
    "l2_blocking": false,
    "direct_trigger_allowed": false,
    "one_task_one_commit": true
  }
}
