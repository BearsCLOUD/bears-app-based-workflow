{
  "schema": "bears-plugin-cache-sync.v1",
  "version": "1",
  "updated": "2026-06-23",
  "owner_plugin": "bears",
  "purpose": "Main-only local Codex plugin cache sync after exact local commit validation PASS.",
  "delivery_policy": {
    "branch_model": "main_only",
    "task_commit_branch": "main",
    "pull_request_required": false,
    "github_review_required": false,
    "test_authority": "local_commit_validation",
    "github_actions": "optional_diagnostics_only",
    "required_local_proof": "runtime/local-commit-validation/<main_sha>.json",
    "exact_commit_required": true,
    "closeout_requires_delivery_complete": true
  },
  "local_commit_validation": {
    "script": "scripts/local_commit_validation.py",
    "install_hook_command": "python3 scripts/local_commit_validation.py install-hook",
    "hook_type": "post-commit",
    "hook_command": "python3 scripts/local_commit_validation.py run --commit-sha HEAD",
    "manual_command": "python3 scripts/local_commit_validation.py run --commit-sha HEAD",
    "selector_command": "python3 scripts/test_selection.py run --from-git <commit_range> --tier fast",
    "proof_root": "runtime/local-commit-validation",
    "proof_file": "runtime/local-commit-validation/<commit_sha>.json",
    "state_schema": "bears-local-commit-validation.v1",
    "generated_state_ignored_by_git": true,
    "hook_types": [
      "pre-commit",
      "post-commit"
    ],
    "blocking_hook_type": "pre-commit",
    "blocking_hook_command": "python3 scripts/local_commit_validation.py run --staged",
    "proof_hook_type": "post-commit",
    "proof_hook_command": "python3 scripts/local_commit_validation.py run --commit-sha HEAD"
  },
  "watcher": {
    "script": "scripts/plugin_cache_sync.py",
    "command": "python3 scripts/plugin_cache_sync.py watch --interval-seconds 15 --timeout-seconds 1200",
    "poll_interval_seconds": 15,
    "commit_timeout_seconds": 1200,
    "max_sync_attempts": 3,
    "state_file": "runtime/plugin-cache-sync/plugin-cache-sync-state.v1.json",
    "state_schema": "assets/schemas/plugin-cache-sync-state.v1.schema.json",
    "github_repo": "BearsCLOUD/bears-codex-workflow-plugin",
    "branch": "main",
    "required_local_proof": "runtime/local-commit-validation/<main_sha>.json"
  },
  "sync_commands": [
    "codex plugin marketplace upgrade bears-workflow-plugin --json",
    "codex plugin add bears@bears-workflow-plugin --json"
  ],
  "verify": {
    "local_commit_validation_status_equals": "pass",
    "local_commit_validation_commit_sha_equals_main_sha": true,
    "installed_cache_sha_equals_main_sha": true,
    "manifest_hooks_equals": "./hooks.json",
    "hooks_json_required": true,
    "hooks_dir_required": true
  },
  "failure_handling": {
    "local_validation_missing_or_failed": "write workflow_defect and keep last working cache",
    "sync_fail_after_retries": "block_workflow",
    "hooks_missing_after_sync": "block_workflow",
    "during_block_workflow_l1_action": "create remediation scope only"
  },
  "delivery_complete_stages": [
    "commit_to_main",
    "local_commit_validation_pass",
    "cache_sync_done",
    "effective_hooks_proof"
  ],
  "validation": {
    "local_commit_validation_install_command": "python3 scripts/local_commit_validation.py install-hook",
    "local_commit_validation_manual_command": "python3 scripts/local_commit_validation.py run --commit-sha HEAD",
    "state_validate_command": "python3 scripts/plugin_cache_sync.py validate-state",
    "catalog_validate_command": "python3 scripts/ci_requirements.py validate-catalog --catalog assets/catalog/ci-requirements.v1.json",
    "local_commit_validation_blocking_command": "python3 scripts/local_commit_validation.py run --staged"
  },
  "sync_policy": {
    "marketplace_snapshot_fallback": {
      "enabled": true,
      "condition": "codex plugin add cannot resolve the root-local bears plugin after marketplace upgrade",
      "guard": "marketplace snapshot git SHA must equal exact main SHA before replacing installed cache",
      "verification": "installed cache SHA and hooks proof must pass after replacement"
    }
  }
}
