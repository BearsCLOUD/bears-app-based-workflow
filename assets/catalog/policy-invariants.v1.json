{
  "schema": "bears-policy-invariants.v1",
  "version": "1",
  "updated": "2026-06-25",
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "component_issue": "#460",
  "commands": [
    "python3 scripts/policy_invariants.py validate",
    "python3 scripts/policy_invariants.py evaluate --input <packet.json> --json",
    "python3 scripts/policy_invariants.py evaluate-closeout --from-git <range> --json"
  ],
  "invariants": [
    {
      "id": "solved_covered_issue_not_open",
      "severity": "blocking",
      "rule": "A covered issue marked solved or closed/superseded must not have github_state OPEN."
    },
    {
      "id": "non_final_issue_not_auto_closed",
      "severity": "blocking",
      "rule": "Covered issues classified partial, manual_review, blocked, or out_of_scope must not request automatic close."
    },
    {
      "id": "behavior_change_has_changelog",
      "severity": "blocking",
      "rule": "Behavior-changing files must have release-note or changelog coverage."
    },
    {
      "id": "governance_change_has_decision",
      "severity": "blocking",
      "rule": "Governance, policy, workflow, script, schema, hook, and catalog changes must have an accepted decision-ledger record."
    },
    {
      "id": "audit_artifacts_no_forbidden_raw_data",
      "severity": "blocking",
      "rule": "Policy inputs and audit packets must not contain forbidden raw data markers."
    }
  ],
  "behavior_patterns": [
    "assets/catalog/**",
    "assets/schemas/**",
    "scripts/**",
    "hooks/**",
    ".codex-plugin/plugin.json",
    "README.md",
    "SPEC.md",
    "docs/reference/**",
    "systemd/**",
    "docs/runbooks/**"
  ],
  "non_behavior_patterns": [
    "tests/**",
    "runtime/**",
    ".pytest_cache/**",
    "__pycache__/**"
  ],
  "decision_required_patterns": [
    "assets/catalog/**",
    "assets/schemas/**",
    "hooks/**",
    "scripts/**"
  ],
  "decision_exempt_paths": [
    "assets/catalog/decision-ledger.v1.json"
  ],
  "forbidden_output_markers": [
    "BEGIN PRIVATE KEY",
    "raw_secret",
    ".env=",
    "credential=",
    "raw log",
    "raw chat",
    "raw vpn config",
    "production data"
  ]
}
