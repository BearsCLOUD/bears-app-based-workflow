{
  "behavior_patterns": [
    "assets/catalog/**",
    "assets/schemas/**",
    "scripts/**",
    "hooks/**",
    ".codex-plugin/plugin.json",
    "README.md",
    "SPEC.md",
    "docs/reference/**",
    "systemd/**"
  ],
  "commands": [
    "python3 scripts/release_notes_gate.py validate",
    "python3 scripts/release_notes_gate.py check --from-git <range>",
    "python3 scripts/release_notes_gate.py check --staged"
  ],
  "component_issue": "#384",
  "non_behavior_patterns": [
    "tests/**",
    "runtime/**",
    ".pytest_cache/**",
    "__pycache__/**"
  ],
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "release_notes": "assets/catalog/release-notes.v1.json",
  "required_entry_fields": [
    "date",
    "issue_ref",
    "impact",
    "validation",
    "affected_surfaces",
    "files"
  ],
  "required_exemption_fields": [
    "date",
    "issue_ref",
    "reason",
    "files"
  ],
  "schema": "bears-release-notes-gate.v1",
  "updated": "2026-06-24",
  "version": "1"
}
