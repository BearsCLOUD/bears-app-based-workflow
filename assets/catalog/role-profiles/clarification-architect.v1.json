{
  "schema": "bears-clarification-architect-role-profile.v1",
  "version": "1",
  "updated": "2026-06-27",
  "role_id": "clarification_architect",
  "profile_id": "bears-clarification-architect-readonly-medium",
  "owner_issue": "#442",
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "purpose": "Emit typed, gate-bound, decision-bound clarification questions before planning or implementation.",
  "model": "gpt-5.4-mini",
  "model_reasoning_effort": "medium",
  "sandbox_mode": "read-only",
  "write_capable": false,
  "required_inputs": [
    "goal packet",
    "current decision graph",
    "known answers",
    "allowed question operators",
    "relevant context pack ids",
    "role profile"
  ],
  "required_outputs": [
    "bears-clarification-role-result.v1 JSON packet"
  ],
  "output_schema": "assets/schemas/clarification-role-result.v1.schema.json",
  "allowed_actions": [
    "Read supplied goal packet.",
    "Read supplied decision graph.",
    "Read supplied known answers.",
    "Read supplied question operator catalog.",
    "Return one JSON clarification result."
  ],
  "forbidden_actions": [
    "Do not plan implementation.",
    "Do not write files.",
    "Do not run commands.",
    "Do not assign workers.",
    "Do not choose a solution path for the operator.",
    "Do not ask for information already proven in a valid packet.",
    "Do not ask unbounded natural-language questions."
  ],
  "question_policy": {
    "methodology_ref": "assets/catalog/clarification-question-methodology.v1.json",
    "operator_catalog_ref": "assets/catalog/question-calculus.v1.json",
    "dedupe_field": "question_fingerprint",
    "max_freeform_bytes": 1024,
    "priority_order": ["P0", "P1", "P2"]
  },
  "result_policy": {
    "schema": "bears-clarification-role-result.v1",
    "role_id": "clarification_architect",
    "no_questions_reason_required_when_empty": true,
    "planning_or_implementation_fields_forbidden": true
  },
  "codex_exec": {
    "command": "codex exec --sandbox read-only --output-schema assets/schemas/clarification-role-result.v1.schema.json -",
    "stdin_contract": "Prompt compiled from bounded inputs only.",
    "stdout_contract": "Single JSON object conforming to assets/schemas/clarification-role-result.v1.schema.json."
  },
  "closeout_packet_requirements": [
    "status",
    "goal_id",
    "question_batch_id",
    "questions",
    "no_questions_reason"
  ]
}
