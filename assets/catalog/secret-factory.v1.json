{
  "schema": "bears-secret-factory.v1",
  "version": "1",
  "updated": "2026-06-21",
  "owner_plugin": "bears",
  "purpose": "Govern local agent-created secret values that are written to Infisical through a write-only path.",
  "secret_manager_create_target": {
    "api_family": "v4",
    "create_endpoint_template": "/api/v4/secrets/{secretName}",
    "required_env": [
      "INFISICAL_TOKEN",
      "INFISICAL_PROJECT_ID",
      "INFISICAL_ENVIRONMENT"
    ],
    "optional_env": [
      "INFISICAL_API_URL",
      "INFISICAL_SECRET_PATH"
    ],
    "default_api_url": "https://app.infisical.com",
    "default_secret_path": "/",
    "allowed_http_methods": [
      "POST"
    ],
    "forbidden_http_methods": [
      "GET",
      "PUT",
      "PATCH",
      "DELETE"
    ],
    "response_body_policy": "discard_without_printing"
  },
  "infisical_network_policy": {
    "required_api_scheme": "https",
    "allowed_hosts": [
      "app.infisical.com"
    ],
    "reject_host_changes": true
  },
  "allowed_generators": [
    {
      "kind": "random_base64url",
      "default_bytes": 32,
      "min_bytes": 16,
      "max_bytes": 128,
      "description": "URL-safe random bytes encoded without padding."
    },
    {
      "kind": "random_hex",
      "default_bytes": 32,
      "min_bytes": 16,
      "max_bytes": 128,
      "description": "Random bytes encoded as lowercase hexadecimal."
    },
    {
      "kind": "random_password",
      "default_length": 40,
      "min_length": 24,
      "max_length": 128,
      "alphabet": "letters_digits_symbols",
      "description": "Random password from an approved non-space alphabet."
    }
  ],
  "refusal_classes": [
    {
      "kind": "provider_issued_api_key",
      "handoff_owner": "external_provider",
      "reason": "Provider API keys must be issued by the provider or an authorized human."
    },
    {
      "kind": "oauth_client_secret",
      "handoff_owner": "identity_provider",
      "reason": "OAuth client secrets must be issued by the identity provider."
    },
    {
      "kind": "ssh_private_key",
      "handoff_owner": "platform_security_owner",
      "reason": "SSH private keys require explicit platform-security ownership and placement rules."
    },
    {
      "kind": "tls_private_key",
      "handoff_owner": "platform_security_owner",
      "reason": "TLS private keys require certificate lifecycle ownership."
    },
    {
      "kind": "payment_credential",
      "handoff_owner": "payment_provider",
      "reason": "Payment credentials must be issued by the payment provider."
    },
    {
      "kind": "wallet_private_key",
      "handoff_owner": "platform_security_owner",
      "reason": "Wallet private keys are custody material and are outside local agent generation."
    }
  ],
  "required_refusal_classes": [
    "provider_issued_api_key",
    "oauth_client_secret",
    "ssh_private_key",
    "tls_private_key",
    "payment_credential",
    "wallet_private_key"
  ],
  "request_schema": {
    "required_fields": [
      "secret_name",
      "kind"
    ],
    "optional_fields": [
      "secret_path",
      "bytes",
      "length"
    ],
    "forbidden_fields": [
      "secret_value",
      "token",
      "credential",
      "credentials",
      "private_key"
    ]
  },
  "secret_name_policy": {
    "pattern": "^[A-Z][A-Z0-9_]{2,127}$",
    "forbidden_fragments": [
      "VALUE",
      "TOKEN_VALUE",
      "SECRET_VALUE",
      "PASSWORD_VALUE"
    ]
  },
  "write_only_controls": {
    "print_secret_value": false,
    "read_secret_value": false,
    "store_secret_value_on_disk": false,
    "pass_secret_value_in_argv": false,
    "commit_secret_value": false,
    "log_secret_value": false,
    "include_secret_value_in_tests": false,
    "include_secret_value_in_docs": false,
    "discard_infisical_response_body": true,
    "stdout_fields": [
      "status",
      "secret_name",
      "generator_kind",
      "secret_path",
      "provider_handoff"
    ]
  },
  "provider_handoff": {
    "status": "HANDOFF_REQUIRED",
    "required_fields": [
      "secret_name",
      "requested_kind",
      "handoff_owner",
      "target_project_id_present",
      "target_environment",
      "secret_path",
      "reason"
    ],
    "forbidden_fields": [
      "secret_value",
      "token",
      "credential",
      "private_key"
    ]
  },
  "validation": {
    "commands": [
      "python3 scripts/platform_roles.py validate",
      "python3 scripts/platform_roles.py route /srv/bears/plugins/bears/assets/catalog/secret-factory.v1.json",
      "python3 scripts/platform_roles.py audit /srv/bears/plugins/bears/assets/catalog/secret-factory.v1.json",
      "python3 scripts/secret_factory.py validate",
      "python3 -m unittest tests/test_secret_factory.py tests/test_platform_roles.py",
      "python3 scripts/validate_overlay.py --json validate --strict-overlay-skills"
    ]
  },
  "names_only_handoff_refs": {
    "live_infisical_existence_policy": "operator_confirmed_no_agent_readback",
    "reason": "Secret Factory represents required Infisical refs by name and path only. It does not call Infisical read or list endpoints. Refs with operator_confirmed_live_ref have exact operator-confirmed Infisical metadata and provider API routing, but agents still must not print secret values.",
    "required_ref_fields": [
      "provider",
      "secret_name",
      "secret_path",
      "handoff_owner",
      "purpose",
      "existence_status"
    ],
    "allowed_existence_statuses": [
      "operator_required",
      "documented_unconfirmed",
      "operator_confirmed_live_ref"
    ],
    "refs": [
      {
        "provider": "serverspace",
        "secret_name": "SERVERSPACE_API_KEY",
        "secret_path": "/srv/bears",
        "handoff_owner": "external_provider",
        "purpose": "ServerSpace Public API credential for Bears workspace operations. Agents must resolve this ref through Infisical MCP before ServerSpace API calls and must not use chat-provided token text as the source of truth.",
        "existence_status": "operator_required"
      },
      {
        "provider": "serverspace",
        "secret_name": "S2CTL_APIKEY",
        "secret_path": "/serverspace/universal-platform/users/s2ctl-apikey",
        "handoff_owner": "external_provider",
        "purpose": "Legacy ServerSpace CLI credential for the backend users tenant lane. Do not use for ServerSpace Public API work.",
        "existence_status": "operator_required"
      },
      {
        "provider": "serverspace",
        "secret_name": "S2CTL_APIKEY",
        "secret_path": "/serverspace/universal-platform/gateway/s2ctl-apikey",
        "handoff_owner": "external_provider",
        "purpose": "Legacy ServerSpace CLI credential for the backend gateway tenant lane. Do not use for ServerSpace Public API work.",
        "existence_status": "operator_required"
      },
      {
        "provider": "serverspace",
        "secret_name": "S2CTL_APIKEY",
        "secret_path": "/serverspace/universal-platform/payments/s2ctl-apikey",
        "handoff_owner": "external_provider",
        "purpose": "Legacy ServerSpace CLI credential for the backend payments tenant lane. Do not use for ServerSpace Public API work.",
        "existence_status": "operator_required"
      },
      {
        "provider": "gitlab",
        "secret_name": "GITLAB_NAMES_ONLY_TOKEN",
        "secret_path": "/gitlab/bears/names-only-inventory",
        "handoff_owner": "external_provider",
        "purpose": "GitLab names-only inventory token for Bears backend repository inventory against scheme=https, host=bears.gitlab.yandexcloud.net, api_path_prefix=/api/v4 without secret readback or token output.",
        "existence_status": "operator_confirmed_live_ref"
      }
    ],
    "unconfirmed_ref_resolution": {
      "applies_to_existence_status": "documented_unconfirmed",
      "required_before_task_ids": [
        "T085",
        "T109"
      ],
      "allowed_confirmation_methods": [
        "operator_confirmed_exact_secret_name_and_path",
        "safe_metadata_only_list_folders_then_list_secret_names"
      ],
      "forbidden_methods": [
        "get_secret_or_readback",
        "list_secrets_without_names_only_or_exclude_values_mode",
        "provider_cli_secret_value_readback"
      ],
      "reason": "Infisical MCP get_secret returned folder 404 for the documented GitLab names-only path. The local CLI has no valid login session, and list_secrets lacks names-only or exclude-values mode."
    },
    "provider_api_routing": {
      "gitlab": {
        "api_scheme": "https",
        "api_host": "bears.gitlab.yandexcloud.net",
        "api_path_prefix": "/api/v4",
        "token_secret_name": "GITLAB_NAMES_ONLY_TOKEN",
        "token_secret_path": "/gitlab/bears/names-only-inventory",
        "infisical_project_id": "2812d08f-50f4-4d38-b43d-ac360b84e097",
        "infisical_environment": "dev",
        "preferred_auth_header": "PRIVATE-TOKEN",
        "accepted_auth_headers": [
          "PRIVATE-TOKEN",
          "Authorization: Bearer"
        ],
        "smoke_probe_path": "/user",
        "forbidden_hosts": [
          "gitlab.com"
        ],
        "confirmation": "operator confirmed exact Infisical ref and GitLab /api/v4/user returned HTTP 200 on 2026-06-21 without token output",
        "output_policy": "Print only HTTP status, resource IDs, repo paths, branch names, and non-secret user names."
      }
    }
  }
}
