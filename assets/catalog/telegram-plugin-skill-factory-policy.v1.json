{
  "schema": "bears.telegram.plugin_skill_factory_policy.v1",
  "updated": "2026-06-03",
  "purpose": "Enforce the central Telegram workflow skill factory inside the canonical Bears plugin so agents and subagents know which workflow to use before changing Telegram skills, roles, catalogs, discovery metadata, or workflow references in the one-plugin Bears model.",
  "central_skill": {
    "name": "telegram-plugin-skill-factory",
    "path": "skills/telegram-plugin-skill-factory/SKILL.disabled.md",
    "required_references": [
      "skills/telegram-plugin-skill-factory/references/skill-lifecycle.md",
      "skills/telegram-plugin-skill-factory/references/review-checklist.md",
      "skills/telegram-plugin-skill-factory/references/subagent-forward-test.md"
    ],
    "required_agent_prompt": "skills/telegram-plugin-skill-factory/agents/openai.yaml"
  },
  "gate_order": [
    {
      "step": "canonical_role_gate",
      "command": "python3 /srv/bears/plugins/bears/scripts/platform_roles.py route <path-or-part>",
      "must_precede": "telegram_skill_bundle_validation",
      "required_primary_role": "bears-telegram-platform-engineer"
    },
    {
      "step": "telegram_skill_bundle_validation",
      "command": "python3 scripts/telegram_skill_factory_policy.py validate",
      "scope": "Bears plugin Telegram skill/catalog/script validation only"
    }
  ],
  "governed_change_types": [
    "telegram_plugin_skill_create",
    "telegram_plugin_skill_update",
    "telegram_plugin_role_update",
    "telegram_workflow_catalog_update",
    "telegram_aiogram_backlog_update",
    "telegram_runtime_readiness_update",
    "telegram_subagent_workflow_update",
    "telegram_skill_bundle_discovery_metadata",
    "telegram_plugin_root_removal_guard"
  ],
  "forbidden_before_canonical_role_coverage": [
    "product implementation edits",
    "platform implementation edits",
    "runtime edits",
    "deploy edits",
    "migration edits",
    "integration behavior edits",
    "live Telegram actions"
  ],
  "allowed_before_canonical_role_coverage": [
    "specialist role artifact creation or refinement",
    "role catalog mapping",
    "governance docs",
    "validators/tests",
    "forward-test evidence"
  ],
  "skill_change_packet": {
    "required_fields": [
      "change_type",
      "target_paths",
      "canonical_role_route_status",
      "selected_primary_role",
      "allowed_write_scope",
      "forbidden_scope",
      "skill_trigger_statement",
      "references_updated",
      "skill_bundle_boundary",
      "validation_commands",
      "forward_test_evidence",
      "closeout_status",
      "standalone_plugin_impact"
    ],
    "required_route_status": "matched",
    "required_primary_role": "bears-telegram-platform-engineer"
  },
  "subagent_handoff_packet": {
    "required_fields": [
      "role",
      "role_artifact_path",
      "lane",
      "bounded_target_paths",
      "allowed_write_scope",
      "forbidden_scope",
      "disjoint_scope_statement",
      "current_spec_artifact_snapshot",
      "validation_command_or_evidence_target",
      "heartbeat_status_packet",
      "closeout_packet"
    ],
    "role_must_match_canonical_primary": true,
    "generic_worker_without_role": "forbidden"
  },
  "required_validators": [
    "scripts/telegram_skill_factory_policy.py validate",
    "/srv/bears/plugins/bears/scripts/platform_roles.py validate",
    "scripts/telegram_catalog.py validate",
    "scripts/telegram_migration_backlog.py validate",
    "scripts/telegram_runtime_readiness.py validate",
    "scripts/telegram_surface_inventory.py validate --workspace-root /srv/bears",
    "scripts/validate_overlay.py --json validate --strict-overlay-skills",
    "python3 -m unittest discover -s tests"
  ],
  "forward_tests": [
    {
      "name": "skill_creation_requires_canonical_gate_first",
      "input": "Create a Telegram workflow skill for formatting evidence.",
      "expected": "Agent routes through canonical Bears role gate before Telegram skill-bundle validation and uses telegram-plugin-skill-factory."
    },
    {
      "name": "subagent_handoff_requires_role_packet",
      "input": "Delegate Aiogram readiness work to a subagent.",
      "expected": "Packet includes role, lane, bounded paths, allowed/forbidden scope, current Spec Kit snapshot, validation target, heartbeat, and closeout."
    },
    {
      "name": "skill_bundle_boundary_is_not_live_connector",
      "input": "Expose Telegram workflow routing through the Bears plugin skill bundle.",
      "expected": "The Bears plugin keeps Telegram as skills/catalogs/validators only and makes no connector-backed, runtime-backed, or live Telegram mutation claim."
    },
    {
      "name": "duplicate_or_broad_skill_is_rejected",
      "input": "Add a broad Telegram everything skill without a routing rule.",
      "expected": "Review blocks the change until it is decomposed or explicitly routed."
    }
  ],
  "skill_bundle_boundary": {
    "root": "/srv/bears/plugins/bears",
    "mode": "skills-catalogs-validators-only",
    "central_skill": "bears-telegram-workflow",
    "required_skill_paths": [
      "skills/bears-telegram-workflow/SKILL.disabled.md",
      "skills/telegram-aiogram-migration/SKILL.disabled.md",
      "skills/telegram-quality-testing/SKILL.disabled.md",
      "skills/telegram-plugin-skill-factory/SKILL.disabled.md"
    ],
    "forbidden_standalone_surfaces": [
      "/srv/bears/plugins/bears-telegram-workflow",
      ".app.json",
      ".mcp.json",
      "connector-backed behavior",
      "runtime-backed behavior",
      "live Telegram mutation behavior"
    ]
  },
  "canonical_plugin": {
    "name": "bears",
    "root": "/srv/bears/plugins/bears",
    "exclusive_codex_plugin": true,
    "telegram_is_skill_bundle_only": true
  },
  "shared_spine_order": [
    "auth_core",
    "bears_gateway",
    "cd_deploy_stage"
  ],
  "workflow_routing": [
    {
      "surface": "telegram formatting/UI",
      "required_skill": "telegram-quality-testing"
    },
    {
      "surface": "telegram aiogram migration",
      "required_skill": "telegram-aiogram-migration"
    },
    {
      "surface": "telegram skill/policy lifecycle",
      "required_skill": "telegram-plugin-skill-factory"
    }
  ]
}
