{
  "schema": "bears-workflow-tree-contract.v1",
  "version": "1",
  "updated": "2026-06-24",
  "owner_plugin": "bears",
  "owner_role": "bears-machine-first-execution-kernel-engineer",
  "purpose": "Canonical machine-readable workflow tree and node contract for governed @bears goal and issue execution.",
  "authoritative_artifacts": [
    "assets/schemas/workflow-tree.v1.schema.json",
    "assets/schemas/workflow-node.v1.schema.json",
    "scripts/workflow_tree.py"
  ],
  "root_tree_required_fields": [
    "schema",
    "version",
    "goal_id",
    "repo_boundary",
    "root_issue",
    "root_role",
    "state",
    "nodes",
    "edges",
    "required_artifacts",
    "required_decisions",
    "required_validations",
    "closeout_gate"
  ],
  "node_required_fields": [
    "node_id",
    "node_type",
    "owner_role",
    "repo_boundary",
    "target_paths",
    "allowed_write_scope",
    "forbidden_scope",
    "preconditions",
    "inputs",
    "outputs",
    "allowed_runners",
    "validation_commands",
    "evidence_outputs",
    "blocker_conditions",
    "closeout_conditions",
    "next_nodes"
  ],
  "state_model": [
    "draft",
    "ready",
    "running",
    "blocked",
    "pass",
    "fail"
  ],
  "edge_model": [
    "sequence",
    "blocked_remediation",
    "bounded_loop"
  ],
  "validation_rules": [
    "node owner_role is required",
    "node target_paths are required for tracked writes",
    "target_paths must stay within allowed_write_scope",
    "validation_commands and allowed_runners are required",
    "closeout nodes require evidence_outputs",
    "edges must reference existing nodes",
    "non-loop cycles are rejected",
    "unreachable nodes are rejected",
    "future artifact registry and decision ledger integrations are not_available until their issue surfaces land"
  ],
  "commands": [
    "validate",
    "init --goal-id <id> --issue <issue>",
    "add-node --tree <path> --packet <node.json>",
    "check-node --tree <path> --node-id <id>",
    "check-closeout --tree <path>",
    "emit-report --tree <path> --json"
  ],
  "forbidden_data": [
    "secret",
    "credential",
    "env_value",
    "raw_log",
    "raw_chat",
    "raw_vpn_config",
    "production_data"
  ],
  "future_integrations": [
    {
      "issue": "#382",
      "surface": "artifact registry",
      "status": "not_available"
    },
    {
      "issue": "#383",
      "surface": "decision ledger",
      "status": "not_available"
    },
    {
      "issue": "#388",
      "surface": "bears_doctor closeout",
      "status": "not_available"
    }
  ]
}
