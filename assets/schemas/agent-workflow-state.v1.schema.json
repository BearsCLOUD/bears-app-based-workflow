{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/agent-workflow-state.v1.schema.json",
  "title": "agent-workflow-state.v1",
  "type": "object",
  "required": [
    "schema_version",
    "state_kind",
    "goal_id",
    "runtime_state_path",
    "worker_state_refs",
    "active_workers",
    "active_prs",
    "dirty_inventory",
    "integration_tasks",
    "cleanup_plan",
    "closeout_gates"
  ],
  "properties": {
    "schema_version": {
      "const": "agent-workflow-state.v1"
    },
    "state_kind": {
      "const": "workflow_state_index"
    },
    "goal_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "runtime_state_path": {
      "type": "string",
      "pattern": "^runtime/agent-workflow/[^/]+/workflow-state\\.v1\\.json$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repo_boundary": {
      "$ref": "#/$defs/non_empty_string"
    },
    "index_role": {
      "const": "aggregate_only"
    },
    "worker_state_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/worker_state_ref"
      },
      "minItems": 1
    },
    "active_workers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/active_worker_summary"
      }
    },
    "active_prs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/active_pr"
      }
    },
    "dirty_inventory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dirty_index_item"
      }
    },
    "integration_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/integration_task"
      }
    },
    "cleanup_plan": {
      "$ref": "#/$defs/cleanup_plan"
    },
    "closeout_gates": {
      "$ref": "#/$defs/closeout_gates"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|(^|/)\\.\\.(/|$))"
      }
    },
    "packet_kind": {
      "enum": [
        "workspace_bootstrap",
        "task_graph",
        "worker_assignment",
        "domain_orchestrator_assignment",
        "worker_state",
        "worker_heartbeat",
        "scope_lock",
        "open_pr",
        "live_session_proof",
        "worker_closeout",
        "validation_evidence",
        "restricted_data_risk",
        "unknown_owner",
        "current_worktree",
        "backup_branch",
        "cleanup_authority",
        "hook_event",
        "review_result",
        "merge_decision",
        "stage_boundary_audit"
      ]
    },
    "packet_ref": {
      "type": "object",
      "required": [
        "kind",
        "ref",
        "source",
        "requires_network"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/packet_kind"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source": {
          "enum": [
            "fixture",
            "runtime_state",
            "local_packet",
            "redacted_operator_note",
            "metadata_only"
          ]
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "digest": {
          "type": "string",
          "pattern": "^(sha256:[0-9a-f]{64}|pending|not_recorded)$"
        },
        "requires_network": {
          "const": false
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "worker_state_ref": {
      "type": "object",
      "required": [
        "worker_id",
        "path",
        "status",
        "role",
        "lane",
        "active_parallel_agent",
        "requires_network",
        "last_hook_event"
      ],
      "properties": {
        "worker_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "path": {
          "type": "string",
          "pattern": "^runtime/agent-workflow/[^/]+/workers/[^/]+/worker-state\\.v1\\.json$"
        },
        "status": {
          "enum": [
            "available",
            "claimed",
            "running",
            "waiting",
            "blocked",
            "stale",
            "completed",
            "closed"
          ]
        },
        "role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lane": {
          "enum": [
            "constitution",
            "specification",
            "planning",
            "docs",
            "auth",
            "gateway",
            "deploy",
            "validation",
            "review",
            "audit",
            "implementation",
            "role-development"
          ]
        },
        "active_parallel_agent": {
          "type": "boolean"
        },
        "requires_network": {
          "const": false
        },
        "last_hook_event": {
          "enum": [
            "pre_task",
            "heartbeat",
            "closeout",
            "aggregate_index_refresh"
          ]
        }
      },
      "additionalProperties": false
    },
    "active_worker_summary": {
      "type": "object",
      "required": [
        "worker_id",
        "worker_state_ref",
        "role",
        "status",
        "active_parallel_agent",
        "cleanup_protected",
        "protection_reason"
      ],
      "properties": {
        "worker_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "worker_state_ref": {
          "type": "string",
          "pattern": "^runtime/agent-workflow/[^/]+/workers/[^/]+/worker-state\\.v1\\.json$"
        },
        "role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "enum": [
            "available",
            "claimed",
            "running",
            "waiting",
            "blocked",
            "stale",
            "completed",
            "closed"
          ]
        },
        "active_parallel_agent": {
          "type": "boolean"
        },
        "cleanup_protected": {
          "type": "boolean"
        },
        "protection_reason": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "active_pr": {
      "type": "object",
      "required": [
        "provider",
        "repository",
        "number",
        "state",
        "draft",
        "head_branch",
        "base_branch",
        "tracked_work",
        "cleanup_protected",
        "proof_ref",
        "linked_worker_ids"
      ],
      "properties": {
        "provider": {
          "const": "github"
        },
        "repository": {
          "$ref": "#/$defs/non_empty_string"
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "state": {
          "enum": [
            "open",
            "closed",
            "merged"
          ]
        },
        "draft": {
          "type": "boolean"
        },
        "head_branch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "base_branch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tracked_work": {
          "type": "boolean"
        },
        "cleanup_protected": {
          "type": "boolean"
        },
        "protection_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "proof_ref": {
          "$ref": "#/$defs/packet_ref"
        },
        "linked_worker_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "dirty_index_item": {
      "type": "object",
      "required": [
        "item_id",
        "owner_worker_id",
        "worker_state_ref",
        "category",
        "owner_status",
        "cleanup_protected",
        "protected_by"
      ],
      "properties": {
        "item_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner_worker_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "worker_state_ref": {
          "type": "string",
          "pattern": "^runtime/agent-workflow/[^/]+/workers/[^/]+/worker-state\\.v1\\.json$"
        },
        "category": {
          "enum": [
            "untracked",
            "modified",
            "deleted",
            "renamed",
            "runtime_state",
            "worktree",
            "branch",
            "pull_request",
            "unknown"
          ]
        },
        "owner_status": {
          "enum": [
            "known_worker",
            "open_pr",
            "live_session",
            "unknown",
            "closed_worker"
          ]
        },
        "cleanup_protected": {
          "type": "boolean"
        },
        "protected_by": {
          "type": "array",
          "items": {
            "enum": [
              "heartbeat",
              "scope_lock",
              "open_pr",
              "live_session_proof",
              "worker_closeout_missing",
              "validation_evidence_missing",
              "restricted_data_risk",
              "unknown_owner",
              "current_worktree",
              "backup_branch",
              "manual_hold"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "integration_task": {
      "type": "object",
      "required": [
        "task_id",
        "title",
        "status",
        "owner_role",
        "worker_state_refs",
        "depends_on",
        "required_packet_refs",
        "validation_evidence_refs"
      ],
      "properties": {
        "task_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "enum": [
            "pending",
            "running",
            "blocked",
            "completed"
          ]
        },
        "owner_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "worker_state_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^runtime/agent-workflow/[^/]+/workers/[^/]+/worker-state\\.v1\\.json$"
          }
        },
        "depends_on": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "required_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packet_ref"
          }
        },
        "validation_evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packet_ref"
          }
        }
      },
      "additionalProperties": false
    },
    "cleanup_plan": {
      "type": "object",
      "required": [
        "default_policy",
        "protected_items",
        "candidate_items",
        "actions"
      ],
      "properties": {
        "default_policy": {
          "const": "protect_until_owner_and_closeout_are_known"
        },
        "protected_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "candidate_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "action_id",
              "item_id",
              "action",
              "authority",
              "status",
              "blocked_by"
            ],
            "properties": {
              "action_id": {
                "$ref": "#/$defs/non_empty_string"
              },
              "item_id": {
                "$ref": "#/$defs/non_empty_string"
              },
              "action": {
                "enum": [
                  "preserve",
                  "review",
                  "archive",
                  "remove_after_closeout"
                ]
              },
              "authority": {
                "enum": [
                  "worker_owner",
                  "pr_owner",
                  "orchestrator_after_closeout",
                  "operator_only",
                  "no_cleanup_until_resolved"
                ]
              },
              "status": {
                "enum": [
                  "pending",
                  "blocked",
                  "complete"
                ]
              },
              "blocked_by": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/non_empty_string"
                },
                "uniqueItems": true
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "closeout_gates": {
      "type": "object",
      "required": [
        "decision",
        "active_prs_preserved",
        "protected_work_has_owner_evidence",
        "restricted_data_risk_reviewed",
        "validation_evidence_present",
        "worker_closeouts_required",
        "closeout_packet_refs",
        "validation_evidence_refs"
      ],
      "properties": {
        "decision": {
          "enum": [
            "close_allowed",
            "close_blocked",
            "needs_operator_review"
          ]
        },
        "active_prs_preserved": {
          "type": "boolean"
        },
        "protected_work_has_owner_evidence": {
          "type": "boolean"
        },
        "restricted_data_risk_reviewed": {
          "type": "boolean"
        },
        "validation_evidence_present": {
          "type": "boolean"
        },
        "worker_closeouts_required": {
          "type": "boolean"
        },
        "closeout_packet_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packet_ref"
          }
        },
        "validation_evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packet_ref"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
