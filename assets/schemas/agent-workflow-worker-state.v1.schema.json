{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/agent-workflow-worker-state.v1.schema.json",
  "title": "agent-workflow-worker-state.v1",
  "type": "object",
  "required": [
    "schema_version",
    "state_kind",
    "worker_state_path",
    "worker_id",
    "goal_id",
    "assignment_ref",
    "status",
    "heartbeat",
    "scope_lock_ref",
    "dirty_inventory_refs",
    "closeout_ref",
    "validation_evidence_refs",
    "integration_status",
    "cleanup_authority",
    "hook_events"
  ],
  "properties": {
    "schema_version": {
      "const": "agent-workflow-worker-state.v1"
    },
    "state_kind": {
      "const": "worker_state"
    },
    "worker_state_path": {
      "type": "string",
      "pattern": "^runtime/agent-workflow/[^/]+/workers/[^/]+/worker-state\\.v1\\.json$"
    },
    "worker_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "goal_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "role": {
      "$ref": "#/$defs/non_empty_string"
    },
    "lane": {
      "enum": [
        "constitution",
        "specification",
        "planning",
        "docs",
        "auth",
        "gateway",
        "deploy",
        "validation",
        "review",
        "audit",
        "implementation",
        "role-development"
      ]
    },
    "active_parallel_agent": {
      "type": "boolean"
    },
    "assignment_ref": {
      "$ref": "#/$defs/packet_ref"
    },
    "status": {
      "enum": [
        "available",
        "claimed",
        "running",
        "waiting",
        "blocked",
        "stale",
        "completed",
        "closed"
      ]
    },
    "heartbeat": {
      "$ref": "#/$defs/heartbeat"
    },
    "scope_lock_ref": {
      "$ref": "#/$defs/packet_ref"
    },
    "dirty_inventory_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dirty_inventory_ref"
      }
    },
    "closeout_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/packet_ref"
        },
        {
          "type": "null"
        }
      ]
    },
    "validation_evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packet_ref"
      }
    },
    "integration_status": {
      "$ref": "#/$defs/integration_status"
    },
    "cleanup_authority": {
      "$ref": "#/$defs/cleanup_authority"
    },
    "hook_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hook_event"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|(^|/)\\.\\.(/|$))"
      }
    },
    "packet_kind": {
      "enum": [
        "workspace_bootstrap",
        "task_graph",
        "worker_assignment",
        "domain_orchestrator_assignment",
        "worker_state",
        "worker_heartbeat",
        "scope_lock",
        "open_pr",
        "live_session_proof",
        "worker_closeout",
        "validation_evidence",
        "restricted_data_risk",
        "unknown_owner",
        "current_worktree",
        "backup_branch",
        "cleanup_authority",
        "hook_event",
        "review_result",
        "merge_decision",
        "stage_boundary_audit"
      ]
    },
    "packet_ref": {
      "type": "object",
      "required": [
        "kind",
        "ref",
        "source",
        "requires_network"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/packet_kind"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source": {
          "enum": [
            "fixture",
            "runtime_state",
            "local_packet",
            "redacted_operator_note",
            "metadata_only"
          ]
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "digest": {
          "type": "string",
          "pattern": "^(sha256:[0-9a-f]{64}|pending|not_recorded)$"
        },
        "requires_network": {
          "const": false
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "heartbeat": {
      "type": "object",
      "required": [
        "packet_ref",
        "status",
        "last_seen",
        "active",
        "open_pr_refs"
      ],
      "properties": {
        "packet_ref": {
          "$ref": "#/$defs/packet_ref"
        },
        "status": {
          "enum": [
            "running",
            "waiting",
            "blocked",
            "completed",
            "closed"
          ]
        },
        "last_seen": {
          "type": "string",
          "format": "date-time"
        },
        "active": {
          "type": "boolean"
        },
        "open_pr_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packet_ref"
          }
        }
      },
      "additionalProperties": false
    },
    "dirty_inventory_ref": {
      "type": "object",
      "required": [
        "item_id",
        "path",
        "category",
        "protected_by",
        "proof_refs"
      ],
      "properties": {
        "item_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "category": {
          "enum": [
            "untracked",
            "modified",
            "deleted",
            "renamed",
            "runtime_state",
            "worktree",
            "branch",
            "pull_request",
            "unknown"
          ]
        },
        "protected_by": {
          "type": "array",
          "items": {
            "enum": [
              "heartbeat",
              "scope_lock",
              "open_pr",
              "live_session_proof",
              "worker_closeout_missing",
              "validation_evidence_missing",
              "restricted_data_risk",
              "unknown_owner",
              "current_worktree",
              "backup_branch",
              "manual_hold"
            ]
          },
          "uniqueItems": true
        },
        "proof_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packet_ref"
          }
        }
      },
      "additionalProperties": false
    },
    "integration_status": {
      "type": "object",
      "required": [
        "state",
        "active_pr_tracked",
        "aggregate_index_refreshed",
        "blocked_by"
      ],
      "properties": {
        "state": {
          "enum": [
            "not_started",
            "running",
            "waiting_for_validation",
            "blocked",
            "integrated",
            "closed"
          ]
        },
        "active_pr_tracked": {
          "type": "boolean"
        },
        "aggregate_index_refreshed": {
          "type": "boolean"
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "cleanup_authority": {
      "type": "object",
      "required": [
        "authority",
        "action_allowed",
        "reason",
        "protected_by"
      ],
      "properties": {
        "authority": {
          "enum": [
            "worker_owner",
            "pr_owner",
            "orchestrator_after_closeout",
            "operator_only",
            "no_cleanup_until_resolved"
          ]
        },
        "action_allowed": {
          "type": "boolean"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "protected_by": {
          "type": "array",
          "items": {
            "enum": [
              "heartbeat",
              "scope_lock",
              "open_pr",
              "live_session_proof",
              "worker_closeout_missing",
              "validation_evidence_missing",
              "restricted_data_risk",
              "unknown_owner",
              "current_worktree",
              "backup_branch",
              "manual_hold"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "hook_event": {
      "type": "object",
      "required": [
        "event_id",
        "event_type",
        "write_scope",
        "target_path",
        "requires_network",
        "status"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "event_type": {
          "enum": [
            "pre_task",
            "heartbeat",
            "closeout",
            "aggregate_index_refresh"
          ]
        },
        "write_scope": {
          "enum": [
            "own_worker_state",
            "aggregate_index"
          ]
        },
        "target_path": {
          "$ref": "#/$defs/relative_path"
        },
        "requires_network": {
          "const": false
        },
        "status": {
          "enum": [
            "planned",
            "written",
            "skipped",
            "blocked"
          ]
        },
        "note": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "event_type": {
                "const": "aggregate_index_refresh"
              }
            },
            "required": [
              "event_type"
            ]
          },
          "then": {
            "properties": {
              "write_scope": {
                "const": "aggregate_index"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "event_type": {
                "enum": [
                  "pre_task",
                  "heartbeat",
                  "closeout"
                ]
              }
            },
            "required": [
              "event_type"
            ]
          },
          "then": {
            "properties": {
              "write_scope": {
                "const": "own_worker_state"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
