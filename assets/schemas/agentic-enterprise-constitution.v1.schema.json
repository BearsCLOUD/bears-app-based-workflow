{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/agentic-enterprise-constitution.v1.schema.json",
  "title": "Bears Agentic Enterprise Constitution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "updated",
    "owner_plugin",
    "purpose",
    "authority_order",
    "principles",
    "role_scoped_principles",
    "references",
    "validation"
  ],
  "properties": {
    "schema": {"const": "bears-agentic-enterprise-constitution.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_plugin": {"const": "bears"},
    "purpose": {"type": "string", "minLength": 20},
    "authority_order": {"type": "array", "items": {"type": "string"}, "minItems": 3},
    "principles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rule"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "rule": {"type": "string", "minLength": 12}
        }
      },
      "minItems": 20
    },
    "role_scoped_principles": {
      "type": "object",
      "additionalProperties": {"type": "array", "items": {"type": "string"}, "minItems": 1}
    },
    "references": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "validation": {"type": "object"}
  }
}
