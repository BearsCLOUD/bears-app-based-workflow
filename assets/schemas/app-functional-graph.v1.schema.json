{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/app-functional-graph.v1.schema.json",
  "title": "Bears app functional graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "app", "owner_repo", "app_directory", "functionalities"],
  "properties": {
    "schema": {"const": "app-functional-graph.v1"},
    "version": {"type": "string"},
    "app": {"type": "string", "minLength": 1},
    "owner_repo": {"type": "string", "minLength": 1},
    "app_directory": {"type": "string", "minLength": 1},
    "updated": {"type": "string"},
    "source_docs": {"type": "array", "items": {"type": "string"}},
    "functionalities": {"type": "array", "items": {"$ref": "#/$defs/functionality"}}
  },
  "$defs": {
    "functionality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "owner_layer", "owner_role", "entrypoints", "nodes", "edges", "async_cycles", "api_calls", "state_transitions", "acceptance", "task_refs"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "status": {"enum": ["planned", "active", "deprecated"]},
        "owner_layer": {"enum": ["app", "platform", "infra"]},
        "owner_role": {"type": "string", "minLength": 1},
        "entrypoints": {"type": "array", "items": {"type": "string"}},
        "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}},
        "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}},
        "async_cycles": {"type": "array", "items": {"$ref": "#/$defs/async_cycle"}},
        "api_calls": {"type": "array", "items": {"$ref": "#/$defs/api_call"}},
        "state_transitions": {"type": "array", "items": {"type": "string"}},
        "acceptance": {"type": "array", "items": {"type": "string"}},
        "proof_refs": {"type": "array", "items": {"type": "string"}},
        "task_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "owner_layer", "target_paths", "input_refs", "output_refs", "side_effects", "evidence_refs"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["ui", "route", "api_call", "domain_rule", "storage", "queue", "worker", "external_callback", "platform_call", "infra_dependency", "state_transition"]},
        "owner_layer": {"enum": ["app", "platform", "infra"]},
        "target_paths": {"type": "array", "items": {"type": "string"}},
        "input_refs": {"type": "array", "items": {"type": "string"}},
        "output_refs": {"type": "array", "items": {"type": "string"}},
        "side_effects": {"type": "array", "items": {"type": "string"}},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "trigger", "mode", "condition"],
      "properties": {
        "from": {"type": "string", "minLength": 1},
        "to": {"type": "string", "minLength": 1},
        "trigger": {"type": "string"},
        "mode": {"enum": ["sync", "async", "scheduled", "callback"]},
        "condition": {"type": "string"}
      }
    },
    "async_cycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "trigger_node_ref", "worker_node_ref", "trigger", "max_attempts", "backoff", "exit_conditions"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "trigger_node_ref": {"type": "string", "minLength": 1},
        "worker_node_ref": {"type": "string", "minLength": 1},
        "trigger": {"type": "string"},
        "max_attempts": {"type": "integer", "minimum": 0},
        "backoff": {"enum": ["fixed", "linear", "exponential", "none"]},
        "exit_conditions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "api_call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "caller_node_ref", "provider", "method", "endpoint_ref", "auth_ref", "timeout_ms", "retry_policy_ref"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "caller_node_ref": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "endpoint_ref": {"type": "string", "minLength": 1},
        "auth_ref": {"type": "string", "minLength": 1},
        "timeout_ms": {"type": "integer", "minimum": 0},
        "retry_policy_ref": {"type": "string", "minLength": 1}
      }
    }
  }
}
