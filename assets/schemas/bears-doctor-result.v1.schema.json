{
  "$id": "https://bears.local/schemas/bears-doctor-result.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blockers": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "changed_files": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "checks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "component_issue": {
            "type": "string"
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "id": {
            "minLength": 2,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "blocked",
              "warning",
              "not_available"
            ]
          },
          "summary": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "status",
          "required",
          "summary"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "closeout_summary": {
      "additionalProperties": false,
      "properties": {
        "affected_range": {
          "minLength": 1,
          "type": "string"
        },
        "changelog": {
          "additionalProperties": false,
          "properties": {
            "delivery_id": {
              "const": "bears-governance-kernel-v1",
              "type": "string"
            },
            "reference": {
              "minLength": 1,
              "type": "string"
            },
            "status": {
              "enum": [
                "linked",
                "missing",
                "exempt"
              ]
            }
          },
          "required": [
            "status",
            "reference",
            "delivery_id"
          ],
          "type": "object"
        },
        "cleanup_status": {
          "minLength": 1,
          "type": "string"
        },
        "debt_status": {
          "minLength": 1,
          "type": "string"
        },
        "delivery_id": {
          "const": "bears-governance-kernel-v1",
          "type": "string"
        },
        "doctor_result": {
          "minLength": 1,
          "type": "string"
        },
        "expected_evidence_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "final_report_policy": {
          "minLength": 1,
          "type": "string"
        },
        "final_sha": {
          "minLength": 1,
          "type": "string"
        },
        "issue_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "known_blockers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "scope": {
          "minLength": 1,
          "type": "string"
        },
        "validation_result": {
          "minLength": 1,
          "type": "string"
        },
        "release_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary"
          ],
          "properties": {
            "status": {
              "enum": [
                "pass",
                "fail",
                "blocked",
                "warning",
                "not_available"
              ]
            },
            "summary": {
              "type": "string"
            },
            "delivery_id": {
              "type": "string"
            }
          }
        },
        "repo_routing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary"
          ],
          "properties": {
            "status": {
              "enum": [
                "pass",
                "fail",
                "blocked",
                "warning",
                "not_available"
              ]
            },
            "summary": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "final_sha",
        "delivery_id",
        "issue_refs",
        "scope",
        "affected_range",
        "expected_evidence_paths",
        "changelog",
        "known_blockers",
        "validation_result",
        "doctor_result",
        "debt_status",
        "cleanup_status",
        "final_report_policy"
      ],
      "type": "object"
    },
    "commit_range": {
      "type": "string"
    },
    "failed_checks": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_next_actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "sanitized_summary": {
      "type": "string"
    },
    "schema": {
      "const": "bears-doctor-result.v1"
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "blocked",
        "review"
      ]
    },
    "version": {
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema",
    "version",
    "status",
    "commit_range",
    "changed_files",
    "checks",
    "failed_checks",
    "warnings",
    "blockers",
    "required_next_actions",
    "sanitized_summary",
    "closeout_summary"
  ],
  "title": "Bears doctor closeout result",
  "type": "object"
}
