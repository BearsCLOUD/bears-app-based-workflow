{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/bears-goals.v1.schema.json",
  "title": "Bears goals catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "goals"],
  "properties": {
    "schema": {"const": "bears-goals.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/goal"}
    }
  },
  "$defs": {
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_id",
        "horizon",
        "status",
        "priority",
        "owner_surface",
        "success_metric",
        "linked_issues",
        "blocked_by"
      ],
      "properties": {
        "goal_id": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9][a-z0-9_\\.-]*$"},
        "horizon": {"enum": ["near", "mid", "long"]},
        "status": {"enum": ["active", "deferred", "completed", "deprecated"]},
        "priority": {"enum": ["P0", "P1", "P2"]},
        "owner_surface": {"enum": ["catalog", "schema", "script", "docs", "runtime"]},
        "success_metric": {"type": "string", "minLength": 3},
        "linked_issues": {"type": "array", "items": {"type": "string", "pattern": "^#[0-9]+$"}},
        "blocked_by": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
