{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/bears-principles.v1.schema.json",
  "title": "Bears principles catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "principles"],
  "properties": {
    "schema": {"const": "bears-principles.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "principles": {
      "type": "array",
      "minItems": 10,
      "items": {"$ref": "#/$defs/principle"}
    }
  },
  "$defs": {
    "principle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principle_id",
        "status",
        "severity",
        "rule",
        "validator",
        "decision_required_when",
        "exceptions"
      ],
      "properties": {
        "principle_id": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9][a-z0-9_\\.-]*$"},
        "status": {"enum": ["active", "deprecated"]},
        "severity": {"enum": ["blocking", "warning", "advisory"]},
        "rule": {"type": "string", "minLength": 3},
        "validator": {"type": ["string", "null"]},
        "decision_required_when": {"type": "array", "items": {"type": "string", "minLength": 3}},
        "exceptions": {"type": "array", "items": {"$ref": "#/$defs/exception"}}
      }
    },
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_code", "rationale", "evidence_paths"],
      "properties": {
        "reason_code": {"type": "string", "minLength": 3},
        "rationale": {"type": "string", "minLength": 3},
        "evidence_paths": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
