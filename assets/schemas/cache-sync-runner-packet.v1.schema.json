{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/cache-sync-runner-packet.v1.schema.json",
  "title": "Bears cache sync runner packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "command_id", "commit_sha", "cache_path", "require_validation_pass", "verify_only", "max_output_bytes"],
  "properties": {
    "schema": {"const": "bears-cache-sync-runner-packet.v1"},
    "version": {"type": "string"},
    "command_id": {"type": "string", "minLength": 3},
    "commit_sha": {"type": "string", "minLength": 7},
    "cache_path": {"type": "string", "minLength": 1},
    "require_validation_pass": {"type": "boolean"},
    "verify_only": {"type": "boolean"},
    "max_output_bytes": {"type": "integer"}
  }
}
