{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/code-property-edge.v1.schema.json",
  "title": "Bears code property edge",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "edge_id", "fact_type", "source", "target", "path", "source_hash", "confidence", "extraction_validated"],
  "properties": {
    "schema": {"const": "bears-code-property-edge.v1"},
    "edge_id": {"type": "string", "minLength": 3},
    "fact_type": {"enum": ["file_contains_symbol", "symbol_imports_module", "function_calls_symbol", "function_reads_name", "function_writes_name", "script_exposes_command", "script_validates_schema", "schema_validates_packet", "catalog_references_schema", "test_targets_script"]},
    "source": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "source_hash": {"type": "string", "minLength": 8},
    "confidence": {"enum": ["candidate", "accepted"]},
    "extraction_validated": {"type": "boolean"},
    "metadata": {"type": "object"}
  }
}
