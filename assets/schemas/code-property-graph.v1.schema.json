{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/code-property-graph.v1.schema.json",
  "title": "Bears code property graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "commands", "fact_types", "nodes", "edges"],
  "properties": {
    "schema": {"const": "bears-code-property-graph.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "commands": {"type": "array", "items": {"type": "string"}},
    "fact_types": {"type": "array", "items": {"type": "string"}},
    "nodes": {"type": "array", "items": {"$ref": "code-property-node.v1.schema.json"}},
    "edges": {"type": "array", "items": {"$ref": "code-property-edge.v1.schema.json"}},
    "tracked_sources": {"type": "array", "items": {"type": "object"}}
  }
}
