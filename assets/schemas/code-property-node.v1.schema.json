{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/code-property-node.v1.schema.json",
  "title": "Bears code property node",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "node_id", "node_type", "path", "name", "source_hash", "confidence"],
  "properties": {
    "schema": {"const": "bears-code-property-node.v1"},
    "node_id": {"type": "string", "minLength": 3},
    "node_type": {"enum": ["file", "module", "class", "function", "async_function", "command", "schema", "catalog", "name"]},
    "path": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "source_hash": {"type": "string", "minLength": 8},
    "confidence": {"enum": ["candidate", "accepted"]},
    "metadata": {"type": "object"}
  }
}
