{
  "$id": "https://bears.local/schemas/commit-closeout.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "canonical_delivery_id": {
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "type": "string"
    },
    "changelog_gate": {
      "additionalProperties": false,
      "properties": {
        "delivery_id_required": {
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "type": "string"
        },
        "owner_issue": {
          "pattern": "^#[0-9]+$",
          "type": "string"
        },
        "required_metadata_value": {
          "minLength": 2,
          "type": "string"
        },
        "status": {
          "enum": [
            "linked",
            "exempt"
          ]
        }
      },
      "required": [
        "owner_issue",
        "required_metadata_value",
        "delivery_id_required",
        "status"
      ],
      "type": "object"
    },
    "commands": {
      "items": {
        "minLength": 2,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "component_issue": {
      "pattern": "^#[0-9]+$",
      "type": "string"
    },
    "doctor_integration": {
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "minLength": 2,
          "type": "string"
        },
        "delivery_id_field": {
          "const": "delivery_id",
          "type": "string"
        },
        "runtime_sha_authority": {
          "minLength": 2,
          "type": "string"
        },
        "summary_field": {
          "minLength": 2,
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "summary_field",
        "runtime_sha_authority",
        "delivery_id_field"
      ],
      "type": "object"
    },
    "final_report_policy": {
      "minLength": 2,
      "type": "string"
    },
    "forbidden_output_markers": {
      "items": {
        "minLength": 2,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "owner_role": {
      "minLength": 2,
      "type": "string"
    },
    "required_metadata": {
      "items": {
        "minLength": 2,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "runtime_evidence_templates": {
      "items": {
        "minLength": 2,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schema": {
      "const": "bears-commit-closeout.v1"
    },
    "updated": {
      "minLength": 10,
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "version",
    "updated",
    "owner_role",
    "component_issue",
    "canonical_delivery_id",
    "required_metadata",
    "runtime_evidence_templates",
    "changelog_gate",
    "doctor_integration",
    "commands",
    "final_report_policy",
    "forbidden_output_markers"
  ],
  "title": "Bears commit closeout contract",
  "type": "object"
}
