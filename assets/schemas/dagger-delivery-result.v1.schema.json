{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/dagger-delivery-result.v1.schema.json",
  "title": "Bears dagger delivery result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "failed_gates", "artifacts", "next_actions"],
  "properties": {
    "schema": {
      "const": "bears-dagger-delivery-result.v1"
    },
    "status": {
      "enum": ["pass", "fail", "tool_missing"]
    },
    "delivery_id": {
      "type": "string",
      "minLength": 1
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "status", "exit_code", "summary"],
        "properties": {
          "gate": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "enum": ["fail", "tool_missing", "not_available"]
          },
          "exit_code": {
            "type": "integer"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "kind", "path"],
        "properties": {
          "gate": {
            "type": "string",
            "minLength": 3
          },
          "kind": {
            "type": "string",
            "minLength": 3
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
