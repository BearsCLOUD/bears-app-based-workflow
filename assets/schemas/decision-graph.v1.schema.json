{
  "$id": "https://bears.local/schemas/decision-graph.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blocked_gates": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "edges": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "from": {
            "minLength": 1,
            "type": "string"
          },
          "relation": {
            "enum": [
              "depends_on",
              "enables",
              "blocks"
            ]
          },
          "to": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "from",
          "to",
          "relation"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "evidence_paths": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "goal_id": {
      "minLength": 1,
      "type": "string"
    },
    "nodes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "node_id": {
            "minLength": 1,
            "type": "string"
          },
          "operator_id": {
            "enum": [
              "resolve_source_of_truth",
              "classify_task_type",
              "find_smallest_verifiable_goal",
              "infer_required_research",
              "infer_required_plan",
              "select_semantic_context",
              "select_role_profile",
              "select_executor",
              "select_model_tier",
              "select_mcp_policy",
              "select_file_scope",
              "select_validation_gate",
              "select_closeout_gate",
              "select_roadmap_update",
              "select_self_improvement_action"
            ]
          },
          "proof_id": {
            "minLength": 1,
            "type": "string"
          },
          "status": {
            "enum": [
              "accepted",
              "candidate",
              "blocked"
            ]
          }
        },
        "required": [
          "node_id",
          "operator_id",
          "proof_id",
          "status"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schema": {
      "const": "bears-decision-graph.v1"
    },
    "semantic_fact_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "unlocked_gates": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schema",
    "goal_id",
    "nodes",
    "edges",
    "unlocked_gates",
    "blocked_gates",
    "evidence_paths",
    "semantic_fact_refs"
  ],
  "title": "Bears decision graph v1",
  "type": "object"
}
