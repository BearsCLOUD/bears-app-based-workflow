{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/decision-log.v1.schema.json",
  "title": "Bears Decision Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "records"],
  "properties": {
    "schema": {"const": "bears-decision-log.v1"},
    "schema_version": {"type": "string"},
    "scope_id": {"type": "string"},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "decision_key", "summary", "status", "source", "created_by_role"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["user_fact", "user_directive", "agent_decision", "contradiction", "needs_user_input"]},
          "decision_key": {"type": "string"},
          "value": {},
          "summary": {"type": "string"},
          "status": {"enum": ["active", "superseded", "blocked", "resolved"]},
          "source": {"type": "string"},
          "created_by_role": {"type": "string"},
          "needs_user_input": {"type": "boolean"},
          "conflicts_with": {"type": "array", "items": {"type": "string"}},
          "expected_next_step": {"type": "string"}
        }
      }
    }
  }
}
