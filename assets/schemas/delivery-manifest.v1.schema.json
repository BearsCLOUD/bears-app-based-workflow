{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/delivery-manifest.v1.schema.json",
  "title": "Bears delivery manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "delivery_id",
    "repo",
    "issues",
    "workflow_tree",
    "sequential_plan",
    "state",
    "commits",
    "validation",
    "doctor",
    "closeout",
    "cleanup_status",
    "blocking_debt",
    "updated_at"
  ],
  "properties": {
    "schema": {
      "const": "bears-delivery-manifest.v1"
    },
    "version": {
      "type": "string"
    },
    "delivery_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "repo": {
      "type": "string",
      "minLength": 3
    },
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "touched_repos": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/touched_repo"
      }
    },
    "workflow_tree": {
      "type": "string",
      "minLength": 1
    },
    "sequential_plan": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "enum": [
        "intake_ready",
        "running",
        "blocked",
        "validation_pending",
        "ready_for_closeout",
        "closed",
        "stale"
      ]
    },
    "commits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commit"
      }
    },
    "validation": {
      "$ref": "#/$defs/validation"
    },
    "doctor": {
      "$ref": "#/$defs/doctor"
    },
    "closeout": {
      "$ref": "#/$defs/closeout"
    },
    "lease_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lease"
      }
    },
    "event_packets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "release_gate": {
      "$ref": "#/$defs/release_gate"
    },
    "cleanup_status": {
      "enum": [
        "clean",
        "pending",
        "blocked"
      ]
    },
    "blocking_debt": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "covered_issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/covered_issue"
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "number",
        "url",
        "state"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 3
        },
        "number": {
          "type": "integer"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "enum": [
            "OPEN",
            "CLOSED"
          ]
        },
        "closeout_state": {
          "enum": [
            "closed",
            "partial",
            "superseded",
            "out_of_scope",
            "blocked",
            "manual_review"
          ]
        }
      }
    },
    "commit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha",
        "role_step",
        "validation_proof"
      ],
      "properties": {
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "role_step": {
          "type": "string",
          "minLength": 3
        },
        "validation_proof": {
          "type": "string"
        }
      }
    },
    "touched_repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "worktree_path",
        "access"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 3
        },
        "worktree_path": {
          "type": "string",
          "minLength": 1
        },
        "repo_id": {
          "type": "string"
        },
        "access": {
          "enum": [
            "write_scoped",
            "read_only",
            "manual_review",
            "blocked"
          ]
        },
        "authority_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hook_proof": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        }
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "delivery_id",
        "status"
      ],
      "properties": {
        "lease_id": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "issue_number": {
          "type": "integer"
        },
        "delivery_id": {
          "type": "string"
        },
        "worktree_path": {
          "type": "string"
        },
        "process_id": {
          "type": "integer"
        },
        "started_at": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        },
        "finished_at": {
          "type": "string"
        },
        "finish_reason": {
          "type": "string"
        },
        "status": {
          "enum": [
            "active",
            "cancelled",
            "stale",
            "recoverable",
            "pass",
            "fail",
            "blocked"
          ]
        },
        "path": {
          "type": "string"
        }
      }
    },
    "release_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reference",
        "delivery_id"
      ],
      "properties": {
        "status": {
          "enum": [
            "required",
            "linked",
            "exempt",
            "missing"
          ]
        },
        "reference": {
          "type": "string"
        },
        "delivery_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "issue_ref": {
          "type": "string"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "exact_proof",
        "async_state",
        "remediation_state"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_started",
            "queued",
            "running",
            "pass",
            "fail",
            "blocked"
          ]
        },
        "exact_proof": {
          "type": "string"
        },
        "async_state": {
          "type": "string"
        },
        "remediation_state": {
          "enum": [
            "none",
            "open",
            "resolved",
            "blocked"
          ]
        }
      }
    },
    "doctor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "result_path"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_started",
            "pass",
            "fail",
            "blocked"
          ]
        },
        "result_path": {
          "type": "string"
        }
      }
    },
    "closeout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "issue_comment_url",
        "closed_issues"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_ready",
            "ready",
            "closed",
            "blocked"
          ]
        },
        "issue_comment_url": {
          "type": "string"
        },
        "closed_issues": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "covered_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "number",
        "url",
        "github_state",
        "classification",
        "reason"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 3
        },
        "number": {
          "type": "integer"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "github_state": {
          "enum": [
            "OPEN",
            "CLOSED",
            "UNKNOWN"
          ]
        },
        "classification": {
          "enum": [
            "closed",
            "partial",
            "superseded",
            "out_of_scope",
            "blocked",
            "manual_review"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 3
        },
        "proof_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "proof_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
