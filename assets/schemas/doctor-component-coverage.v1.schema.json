{
  "$defs": {
    "component": {
      "additionalProperties": false,
      "properties": {
        "coverage_status": {
          "enum": [
            "covered",
            "missing",
            "partial",
            "not_applicable",
            "manual_review"
          ],
          "type": "string"
        },
        "doctor_check_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "gap_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "issue": {
          "pattern": "^#[0-9]+$",
          "type": "string"
        },
        "not_applicable_evidence": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "required_commands": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "required_files": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "requires_doctor": {
          "type": "boolean"
        },
        "requires_validator": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "open",
            "closed"
          ],
          "type": "string"
        },
        "test_selection_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "issue",
        "title",
        "status",
        "requires_doctor",
        "requires_validator",
        "required_commands",
        "required_files",
        "doctor_check_ids",
        "test_selection_refs",
        "coverage_status",
        "gap_ids"
      ],
      "type": "object"
    },
    "gap": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "gap_id": {
          "minLength": 1,
          "type": "string"
        },
        "gap_type": {
          "enum": [
            "missing_doctor_check",
            "missing_validator_command",
            "missing_test_selection",
            "missing_doctor_summary",
            "stale_component_issue",
            "closed_issue_still_not_available",
            "unsafe_autostart_without_doctor_gate"
          ],
          "type": "string"
        },
        "issue": {
          "pattern": "^#[0-9]+$",
          "type": "string"
        },
        "recommended_next": {
          "enum": [
            "add_doctor_check",
            "add_test_selection",
            "manual_review",
            "mark_not_applicable",
            "close_duplicate"
          ],
          "type": "string"
        },
        "severity": {
          "enum": [
            "blocking",
            "warning",
            "info"
          ],
          "type": "string"
        }
      },
      "required": [
        "gap_id",
        "issue",
        "gap_type",
        "severity",
        "evidence_refs",
        "recommended_next"
      ],
      "type": "object"
    },
    "source_ref": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "timestamp": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "source",
        "timestamp",
        "confidence"
      ],
      "type": "object"
    },
    "summary": {
      "additionalProperties": false,
      "properties": {
        "blocking_count": {
          "minimum": 0,
          "type": "integer"
        },
        "covered_count": {
          "minimum": 0,
          "type": "integer"
        },
        "missing_count": {
          "minimum": 0,
          "type": "integer"
        },
        "open_issue_count": {
          "minimum": 0,
          "type": "integer"
        },
        "partial_count": {
          "minimum": 0,
          "type": "integer"
        },
        "requires_doctor_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "open_issue_count",
        "requires_doctor_count",
        "covered_count",
        "partial_count",
        "missing_count",
        "blocking_count"
      ],
      "type": "object"
    }
  },
  "$id": "https://bears.local/schemas/doctor-component-coverage.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "components": {
      "items": {
        "$ref": "#/$defs/component"
      },
      "type": "array"
    },
    "doctor_catalog": {
      "minLength": 1,
      "type": "string"
    },
    "gaps": {
      "items": {
        "$ref": "#/$defs/gap"
      },
      "type": "array"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "repo": {
      "minLength": 1,
      "type": "string"
    },
    "schema": {
      "const": "bears-doctor-component-coverage.v1"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/source_ref"
      },
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "required": [
    "schema",
    "repo",
    "generated_at",
    "source_refs",
    "doctor_catalog",
    "components",
    "gaps",
    "summary"
  ],
  "title": "Bears doctor component coverage v1",
  "type": "object"
}
