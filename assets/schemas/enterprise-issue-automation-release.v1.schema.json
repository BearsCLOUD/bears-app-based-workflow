{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/enterprise-issue-automation-release.v1.schema.json",
  "title": "Bears enterprise issue automation release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "release_id", "delivery_id", "owner_role", "state", "issue_order", "completed_issues", "active_issue", "dependency_policy", "hook_policy", "service_policy", "closeout_policy"],
  "properties": {
    "schema": {"const": "bears-enterprise-issue-automation-release.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "release_id": {"type": "string", "minLength": 3},
    "delivery_id": {"type": "string", "minLength": 3},
    "owner_role": {"type": "string", "minLength": 3},
    "state": {"enum": ["planned", "running", "blocked", "closed"]},
    "issue_order": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "completed_issues": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "active_issue": {"type": "integer", "minimum": 1},
    "dependency_policy": {"type": "object"},
    "hook_policy": {"type": "object"},
    "service_policy": {"type": "object"},
    "closeout_policy": {"type": "object"}
  }
}
