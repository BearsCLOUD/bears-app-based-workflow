{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/evidence-compaction-packet.v1.schema.json",
  "title": "Bears evidence compaction packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "command_id", "state_files", "max_files", "max_output_bytes"],
  "properties": {
    "schema": {"const": "bears-evidence-compaction-packet.v1"},
    "version": {"type": "string"},
    "command_id": {"type": "string", "minLength": 3},
    "state_files": {"type": "array", "items": {"type": "string"}},
    "max_files": {"type": "integer"},
    "max_output_bytes": {"type": "integer"}
  }
}
