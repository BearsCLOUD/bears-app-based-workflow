{
  "$defs": {
    "conflict": {
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "resolution": {
          "enum": [
            "merge_unit",
            "sequential",
            "blocked"
          ]
        },
        "right": {
          "type": "string"
        }
      },
      "required": [
        "left",
        "right",
        "reason",
        "resolution"
      ],
      "type": "object"
    },
    "file": {
      "additionalProperties": false,
      "properties": {
        "authority_topic": {
          "type": [
            "string",
            "null"
          ]
        },
        "changelog_required": {
          "type": "boolean"
        },
        "context_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "coverage_status": {
          "enum": [
            "covered",
            "missing_context",
            "missing_authority",
            "missing_lock",
            "manual_review"
          ]
        },
        "decision_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "execution_unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "lock_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "operation": {
          "enum": [
            "read",
            "create",
            "modify",
            "delete",
            "rename"
          ]
        },
        "owner_role": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "workflow_nodes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "path",
        "operation",
        "owner_role",
        "authority_topic",
        "context_id",
        "workflow_nodes",
        "decision_refs",
        "changelog_required",
        "lock_id",
        "execution_unit",
        "coverage_status"
      ],
      "type": "object"
    }
  },
  "$id": "https://bears.local/schemas/file-change-plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "conflicts": {
      "items": {
        "$ref": "#/$defs/conflict"
      },
      "type": "array"
    },
    "delivery_id": {
      "minLength": 1,
      "type": "string"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/file"
      },
      "type": "array"
    },
    "goal_id": {
      "minLength": 1,
      "type": "string"
    },
    "join_gate": {
      "minLength": 1,
      "type": "string"
    },
    "schema": {
      "const": "bears-file-change-plan.v1"
    },
    "source_ref": {
      "minLength": 1,
      "type": "string"
    },
    "state": {
      "enum": [
        "draft",
        "covered",
        "ready_for_fanout",
        "running",
        "joined",
        "blocked"
      ]
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "schema",
    "version",
    "goal_id",
    "delivery_id",
    "source_ref",
    "state",
    "files",
    "conflicts",
    "join_gate"
  ],
  "title": "Bears file change plan",
  "type": "object"
}
