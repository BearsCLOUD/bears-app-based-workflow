{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/file-context-index.v1.schema.json",
  "title": "Bears file context index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "policy", "records"],
  "properties": {
    "schema": {"const": "bears-file-context-index.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "policy": {"type": "string", "minLength": 3},
    "records": {"type": "array", "items": {"$ref": "#/definitions/record"}}
  },
  "definitions": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "context_id", "path", "source_hash", "language", "status", "owner_role", "authority_topic", "purpose", "technologies", "public_interfaces", "functions", "classes", "imports", "reads", "writes", "contracts", "workflow_nodes", "decision_refs", "changelog_refs", "related_contexts", "read_policy", "write_policy", "prompt_hints", "last_verified_commit"],
      "properties": {
        "schema": {"const": "bears-file-context.v1"},
        "context_id": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9][a-z0-9_.:-]*$"},
        "path": {"type": "string", "minLength": 1},
        "source_hash": {"type": "string", "minLength": 8},
        "language": {"enum": ["python", "json", "markdown", "toml", "yaml", "other"]},
        "status": {"enum": ["active", "stale", "deprecated", "generated_only", "manual_review"]},
        "owner_role": {"type": "string", "minLength": 3},
        "authority_topic": {"type": ["string", "null"]},
        "purpose": {"type": "string", "minLength": 3},
        "technologies": {"type": "array", "items": {"type": "string"}},
        "public_interfaces": {"type": "array", "items": {"type": "string"}},
        "functions": {"type": "array", "items": {"type": "string"}},
        "classes": {"type": "array", "items": {"type": "string"}},
        "imports": {"type": "array", "items": {"type": "string"}},
        "reads": {"type": "array", "items": {"type": "string"}},
        "writes": {"type": "array", "items": {"type": "string"}},
        "contracts": {"type": "array", "items": {"type": "string"}},
        "workflow_nodes": {"type": "array", "items": {"type": "string"}},
        "decision_refs": {"type": "array", "items": {"type": "string"}},
        "changelog_refs": {"type": "array", "items": {"type": "string"}},
        "related_contexts": {"type": "array", "items": {"type": "string"}},
        "read_policy": {"enum": ["summary_first", "section_only", "full_read_allowed", "manual_review"]},
        "write_policy": {"enum": ["forbidden", "packet_required", "role_required", "manual_review"]},
        "prompt_hints": {"type": "array", "items": {"type": "string"}},
        "last_verified_commit": {"type": ["string", "null"]}
      }
    }
  }
}
