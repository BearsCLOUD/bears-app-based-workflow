{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/file-context-refresh.v1.schema.json",
  "title": "Bears file context refresh result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "command", "updated", "changed_records", "removed_records", "errors"],
  "properties": {
    "schema": {"const": "bears-file-context-refresh.v1"},
    "status": {"enum": ["pass", "fail", "blocked"]},
    "command": {"enum": ["refresh", "gc", "doctor"]},
    "updated": {"type": "string"},
    "changed_records": {"type": "array", "items": {"type": "string"}},
    "removed_records": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}},
    "stale_records": {"type": "array", "items": {"type": "string"}},
    "missing_context_paths": {"type": "array", "items": {"type": "string"}},
    "orphaned_records": {"type": "array", "items": {"type": "string"}}
  }
}
