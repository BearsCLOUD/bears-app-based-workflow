{
  "$id": "https://bears.local/schemas/formal-semantics-kernel.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "commands": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "fact_sets": {
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "authority_source": {
                "minLength": 1,
                "type": "string"
              },
              "evidence": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "array",
                "uniqueItems": true
              },
              "id": {
                "minLength": 1,
                "type": "string"
              },
              "object": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "semantic_type": {
                    "enum": [
                      "goal",
                      "issue",
                      "file",
                      "symbol",
                      "role",
                      "executor",
                      "workflow_node",
                      "decision",
                      "evidence",
                      "contract",
                      "validator",
                      "event",
                      "store",
                      "term"
                    ]
                  }
                },
                "required": [
                  "id",
                  "semantic_type"
                ],
                "type": "object"
              },
              "reason": {
                "minLength": 1,
                "type": "string"
              },
              "relation": {
                "enum": [
                  "is_a",
                  "part_of",
                  "depends_on",
                  "requires",
                  "blocks",
                  "enables",
                  "implements",
                  "validates",
                  "owns",
                  "reads",
                  "writes",
                  "uses",
                  "produces",
                  "consumes",
                  "proves",
                  "supersedes",
                  "conflicts_with"
                ]
              },
              "status": {
                "enum": [
                  "accepted",
                  "candidate",
                  "rejected"
                ]
              },
              "subject": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "semantic_type": {
                    "enum": [
                      "goal",
                      "issue",
                      "file",
                      "symbol",
                      "role",
                      "executor",
                      "workflow_node",
                      "decision",
                      "evidence",
                      "contract",
                      "validator",
                      "event",
                      "store",
                      "term"
                    ]
                  }
                },
                "required": [
                  "id",
                  "semantic_type"
                ],
                "type": "object"
              },
              "validator": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "id",
              "subject",
              "relation",
              "object",
              "status",
              "authority_source"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "candidate": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "authority_source": {
                "minLength": 1,
                "type": "string"
              },
              "evidence": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "array",
                "uniqueItems": true
              },
              "id": {
                "minLength": 1,
                "type": "string"
              },
              "object": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "semantic_type": {
                    "enum": [
                      "goal",
                      "issue",
                      "file",
                      "symbol",
                      "role",
                      "executor",
                      "workflow_node",
                      "decision",
                      "evidence",
                      "contract",
                      "validator",
                      "event",
                      "store",
                      "term"
                    ]
                  }
                },
                "required": [
                  "id",
                  "semantic_type"
                ],
                "type": "object"
              },
              "reason": {
                "minLength": 1,
                "type": "string"
              },
              "relation": {
                "enum": [
                  "is_a",
                  "part_of",
                  "depends_on",
                  "requires",
                  "blocks",
                  "enables",
                  "implements",
                  "validates",
                  "owns",
                  "reads",
                  "writes",
                  "uses",
                  "produces",
                  "consumes",
                  "proves",
                  "supersedes",
                  "conflicts_with"
                ]
              },
              "status": {
                "enum": [
                  "accepted",
                  "candidate",
                  "rejected"
                ]
              },
              "subject": {
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "semantic_type": {
                    "enum": [
                      "goal",
                      "issue",
                      "file",
                      "symbol",
                      "role",
                      "executor",
                      "workflow_node",
                      "decision",
                      "evidence",
                      "contract",
                      "validator",
                      "event",
                      "store",
                      "term"
                    ]
                  }
                },
                "required": [
                  "id",
                  "semantic_type"
                ],
                "type": "object"
              },
              "validator": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "id",
              "subject",
              "relation",
              "object",
              "status",
              "authority_source"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "accepted",
        "candidate"
      ],
      "type": "object"
    },
    "owner_issue": {
      "pattern": "^#[0-9]+$",
      "type": "string"
    },
    "owner_role": {
      "minLength": 3,
      "type": "string"
    },
    "relation_catalog": {
      "minLength": 1,
      "type": "string"
    },
    "rules": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "effect": {
            "minLength": 1,
            "type": "string"
          },
          "id": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "effect"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schema": {
      "const": "bears-formal-semantics-kernel.v1"
    },
    "semantic_type_catalog": {
      "minLength": 1,
      "type": "string"
    },
    "updated": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "version",
    "updated",
    "owner_issue",
    "owner_role",
    "semantic_type_catalog",
    "relation_catalog",
    "fact_sets",
    "rules",
    "commands"
  ],
  "title": "Bears formal semantics kernel v1",
  "type": "object"
}
