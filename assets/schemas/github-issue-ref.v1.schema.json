{
  "$id": "https://bears.local/schemas/github-issue-ref.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears GitHub issue reference v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "repo",
    "owner",
    "repo_name",
    "issue_number",
    "canonical_ref",
    "github_url",
    "state",
    "source_snapshot_ref",
    "source_snapshot_sha256",
    "legacy_local_ref",
    "status"
  ],
  "properties": {
    "schema": {
      "const": "bears-github-issue-ref.v1"
    },
    "version": {
      "const": "1"
    },
    "repo": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "owner": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "repo_name": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "issue_number": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "canonical_ref": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+#[1-9][0-9]*$"
    },
    "github_url": {
      "type": ["string", "null"],
      "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"
    },
    "state": {
      "enum": ["resolved", "proposed", "unresolved", "blocked"]
    },
    "source_snapshot_ref": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_snapshot_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "legacy_local_ref": {
      "type": ["string", "null"],
      "pattern": "^#[1-9][0-9]*$"
    },
    "status": {
      "enum": ["pass", "blocked"]
    }
  }
}
