{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/github-project-subagents.v1.schema.json",
  "title": "Bears GitHub Project subagents governance catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "parent_lane", "l2_orchestrator", "l3_worker", "github_surfaces", "forbidden_mutations", "required_validations"],
  "properties": {
    "schema": {"const": "bears-github-project-subagents.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "parent_lane": {"$ref": "#/$defs/lane"},
    "l2_orchestrator": {"$ref": "#/$defs/lane"},
    "l3_worker": {"$ref": "#/$defs/lane"},
    "github_surfaces": {"type": "array", "minItems": 10, "items": {"$ref": "#/$defs/surface"}},
    "forbidden_mutations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "required_validations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "model", "reasoning", "allowed_actions", "forbidden_actions"],
      "properties": {
        "role": {"type": "string", "minLength": 3},
        "model": {"type": "string", "minLength": 3},
        "reasoning": {"type": "string", "enum": ["high", "medium", "surface_default"]},
        "allowed_actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "forbidden_actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "coverage", "allowed_lanes", "mutation_policy"],
      "properties": {
        "name": {"type": "string", "minLength": 2},
        "coverage": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "allowed_lanes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "mutation_policy": {"type": "string", "minLength": 1}
      }
    }
  }
}
