{
  "$id": "https://bears.local/schemas/gitops-degradation-event.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears GitOps degradation event v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-gitops-degradation-event.v1"},
    "event_id": {"type": "string", "minLength": 1},
    "delivery_id": {"type": "string", "minLength": 1},
    "commit_sha": {"type": ["string", "null"]},
    "signal": {"type": "string", "minLength": 1},
    "gitops_state": {"type": "string", "minLength": 1},
    "remediation": {"type": "string", "minLength": 1},
    "delivery_manifest": {"type": "string", "minLength": 1},
    "commit_usage_ledger": {"type": "string", "minLength": 1},
    "evidence_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["schema", "event_id", "delivery_id", "signal", "gitops_state", "remediation", "delivery_manifest", "commit_usage_ledger", "evidence_paths", "errors"]
}
