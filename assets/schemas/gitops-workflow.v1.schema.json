{
  "$id": "https://bears.local/schemas/gitops-workflow.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears GitOps workflow v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-gitops-workflow.v1"},
    "version": {"type": "string", "minLength": 1},
    "owner_issue": {"const": "#421"},
    "states": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "degradation_signals": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "commands": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "transitions": {"type": "array", "items": {"type": "object"}},
    "remediation_policy": {"type": "object"},
    "rollback_policy": {"type": "object"},
    "evidence_authority": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "required": ["schema", "version", "owner_issue", "states", "degradation_signals", "commands", "transitions", "remediation_policy", "rollback_policy", "evidence_authority"]
}
