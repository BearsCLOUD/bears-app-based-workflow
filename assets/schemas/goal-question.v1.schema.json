{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/goal-question.v1.schema.json",
  "title": "Bears goal question packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "question_id", "question", "answer_type", "answer", "decision_ref", "principles_applied", "gates_unlocked", "blocked_by"],
  "properties": {
    "schema": {"const": "bears-goal-question.v1"},
    "question_id": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
    "question_class": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
    "question": {"type": "string", "minLength": 8},
    "answer_type": {"enum": ["enum", "boolean", "path", "issue", "json_ref", "manual_review", "json_evidence"]},
    "answer": {"type": ["string", "null"]},
    "decision_ref": {"type": ["string", "null"]},
    "principles_applied": {"type": "array", "items": {"type": "string"}},
    "gates_unlocked": {"type": "array", "items": {"type": "string"}},
    "blocked_by": {"type": "array", "items": {"type": "string"}}
  }
}
