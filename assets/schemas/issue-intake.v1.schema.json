{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/issue-intake.v1.schema.json",
  "title": "Bears issue intake",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "repo", "number", "title", "state", "url", "body"],
  "properties": {
    "schema": {"const": "bears-issue-intake.v1"},
    "version": {"type": "string"},
    "repo": {"type": "string", "minLength": 3},
    "number": {"type": "integer"},
    "title": {"type": "string", "minLength": 1},
    "state": {"enum": ["OPEN", "CLOSED"]},
    "url": {"type": "string", "minLength": 1},
    "body": {"type": "string"},
    "labels": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "additionalProperties": true,
            "required": ["name"],
            "properties": {
              "name": {"type": "string"}
            }
          }
        ]
      }
    }
  }
}
