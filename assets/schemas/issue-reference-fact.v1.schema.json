{
  "$id": "https://bears.local/schemas/issue-reference-fact.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "author": {
      "type": "string"
    },
    "comment_id": {
      "type": "integer"
    },
    "confidence": {
      "type": "number"
    },
    "errors": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "number": {
      "type": "integer"
    },
    "repo": {
      "minLength": 1,
      "type": "string"
    },
    "requirement_class": {
      "minLength": 1,
      "type": "string"
    },
    "sanitized_excerpt": {
      "type": "string"
    },
    "schema": {
      "const": "bears-issue-reference-fact.v1"
    },
    "source": {
      "minLength": 1,
      "type": "string"
    },
    "state": {
      "minLength": 1,
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "url": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "repo",
    "number",
    "title",
    "url",
    "state",
    "source",
    "timestamp",
    "confidence",
    "requirement_class",
    "sanitized_excerpt"
  ],
  "title": "Bears issue reference fact v1",
  "type": "object"
}
