{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/mcp-agent-policy.v1.schema.json",
  "title": "Bears MCP agent policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "updated",
    "owner_plugin",
    "issue",
    "purpose",
    "default_mcp_policy",
    "commands",
    "output_contract",
    "decision_packet_contract",
    "profiles",
    "tool_rules",
    "opencode_permissions",
    "validation"
  ],
  "properties": {
    "schema": {"const": "bears-mcp-agent-policy.v1"},
    "version": {"type": "string", "minLength": 1},
    "updated": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"},
    "owner_plugin": {"const": "bears"},
    "issue": {"const": "#417"},
    "purpose": {"type": "string", "minLength": 1},
    "default_mcp_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "deny_unknown_profiles", "profile_and_decision_packet_required", "deny_when_decision_packet_missing"],
      "properties": {
        "mode": {"const": "deny_all"},
        "deny_unknown_profiles": {"const": true},
        "profile_and_decision_packet_required": {"const": true},
        "deny_when_decision_packet_missing": {"const": true}
      }
    },
    "commands": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json_only", "packet_schema_prefix", "statuses"],
      "properties": {
        "json_only": {"const": true},
        "packet_schema_prefix": {"type": "string", "minLength": 1},
        "statuses": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "decision_packet_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "required_fields", "allow_fields", "closeout_gate_fields"],
      "properties": {
        "schema": {"const": "bears-mcp-agent-policy-decision-packet.v1"},
        "required_fields": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string"}},
        "allow_fields": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
        "closeout_gate_fields": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/profile"}
    },
    "tool_rules": {"$ref": "#/$defs/toolRules"},
    "opencode_permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_fragment", "allowed_value", "denied_value"],
      "properties": {
        "default_fragment": {"type": "object"},
        "allowed_value": {"const": "allow"},
        "denied_value": {"const": "deny"}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_kind",
        "default_mcp_access",
        "decision_packet_required",
        "allowed_tool_patterns",
        "github_mutation_default",
        "closeout_gate_tools_allowed"
      ],
      "properties": {
        "profile_id": {"type": "string", "minLength": 1},
        "profile_kind": {"enum": ["implementation", "research", "closeout", "review"]},
        "default_mcp_access": {"const": "deny"},
        "decision_packet_required": {"const": true},
        "explicit_read_only_allowlist_required": {"type": "boolean"},
        "read_only_tool_allowlist": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "allowed_tool_patterns": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "github_mutation_default": {"const": "deny"},
        "closeout_gate_tools_allowed": {"type": "boolean"}
      }
    },
    "toolRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mcp_tool_prefix", "github_mutation", "research_shard"],
      "properties": {
        "mcp_tool_prefix": {"const": "mcp__"},
        "github_mutation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default", "tool_patterns", "closeout_exception"],
          "properties": {
            "default": {"const": "deny"},
            "tool_patterns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "closeout_exception": {
              "type": "object",
              "additionalProperties": false,
              "required": ["gate", "required_status", "allowed_tools"],
              "properties": {
                "gate": {"const": "closeout"},
                "required_status": {"const": "pass"},
                "allowed_tools": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
              }
            }
          }
        },
        "research_shard": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default", "explicit_read_only_allowlist_required", "mutation_tools_allowed"],
          "properties": {
            "default": {"const": "deny"},
            "explicit_read_only_allowlist_required": {"const": true},
            "mutation_tools_allowed": {"const": false}
          }
        }
      }
    }
  }
}
