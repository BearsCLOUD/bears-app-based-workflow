{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/metadata-store-policy.v1.schema.json",
  "title": "Bears metadata store policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "commands", "source_of_truth", "materialized_stores"],
  "properties": {
    "schema": {"const": "bears-metadata-store-policy.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "commands": {"type": "array", "items": {"type": "string"}},
    "source_of_truth": {"const": "validated_json_in_git"},
    "materialized_stores": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["store", "status", "authority"], "properties": {"store": {"type": "string"}, "status": {"enum": ["optional", "future", "disabled"]}, "authority": {"const": "cache_only"}, "export_required": {"type": "boolean"}}}},
    "forbidden": {"type": "array", "items": {"type": "string"}}
  }
}
