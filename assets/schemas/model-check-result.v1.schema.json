{
  "$id": "https://bears.local/schemas/model-check-result.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears model check result v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-model-check-result.v1"},
    "goal_id": {"type": "string", "minLength": 1},
    "checked_model": {"type": "string", "minLength": 1},
    "invariants": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "status": {"enum": ["pass", "fail", "manual_review"]},
    "counterexamples": {"type": "array", "items": {"type": "object"}},
    "evidence_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["schema", "goal_id", "checked_model", "invariants", "status", "counterexamples", "evidence_paths"]
}
