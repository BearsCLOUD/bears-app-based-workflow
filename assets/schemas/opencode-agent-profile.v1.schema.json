{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/opencode-agent-profile.v1.schema.json",
  "title": "Bears OpenCode agent profile catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "profiles"],
  "properties": {
    "schema": {"const": "bears-opencode-agent-profiles.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "profiles": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/profile"}}
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "agent_class",
        "mode",
        "enabled_by_default",
        "model_tier",
        "model_ref",
        "model_env_var",
        "permission_profile",
        "workspace_write_policy",
        "allowed_outputs",
        "denied_capabilities",
        "fallback_policy"
      ],
      "properties": {
        "profile_id": {"enum": ["oc_research_shard", "oc_scout", "oc_reviewer", "oc_planner", "oc_executor"]},
        "agent_class": {"type": "string", "minLength": 3},
        "mode": {"enum": ["subagent"]},
        "enabled_by_default": {"type": "boolean"},
        "model_tier": {"enum": ["cheap_required", "standard_allowed", "disabled"]},
        "model_ref": {"type": "string"},
        "model_env_var": {"type": "string"},
        "permission_profile": {"type": "object", "additionalProperties": {"type": ["string", "object"]}},
        "workspace_write_policy": {"enum": ["deny", "explicit_plan_artifacts_only", "disabled"]},
        "allowed_outputs": {"type": "array", "items": {"type": "string"}},
        "denied_capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "fallback_policy": {"enum": ["block", "deterministic_runner"]}
      }
    }
  }
}
