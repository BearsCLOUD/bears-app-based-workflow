{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/plugin-cache-sync-state.v1.schema.json",
  "title": "Bears Plugin Cache Sync State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "updated_at",
    "repository",
    "branch",
    "main_sha",
    "local_commit_validation",
    "cache_sync",
    "delivery_complete",
    "workflow_defect",
    "next_action"
  ],
  "properties": {
    "schema": {
      "const": "bears-plugin-cache-sync-state.v1"
    },
    "updated_at": {
      "type": "string"
    },
    "repository": {
      "const": "BearsCLOUD/bears-codex-workflow-plugin"
    },
    "branch": {
      "const": "main"
    },
    "main_sha": {
      "type": [
        "string",
        "null"
      ]
    },
    "local_commit_validation": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "missing",
            "pending",
            "pass",
            "fail",
            "unknown",
            "dry_run"
          ]
        },
        "proof_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit_sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "selector_confidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "slow_tests_deferred": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "cache_sync": {
      "type": "object",
      "required": [
        "status",
        "action"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_run",
            "pending",
            "success",
            "fail"
          ]
        },
        "action": {
          "type": "string"
        },
        "verify": {
          "type": "object"
        },
        "attempts": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "effective_hooks_proof": {
      "type": "object"
    },
    "delivery_complete": {
      "type": "boolean"
    },
    "workflow_defect": {
      "type": "object",
      "required": [
        "status",
        "action",
        "reason"
      ],
      "properties": {
        "status": {
          "enum": [
            "open",
            "closed"
          ]
        },
        "action": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "tech_debt_matrix_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "next_action": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "delivery_complete": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "local_commit_validation": {
            "properties": {
              "status": {
                "const": "pass"
              }
            },
            "required": [
              "commit_sha",
              "proof_path"
            ]
          },
          "cache_sync": {
            "properties": {
              "status": {
                "const": "success"
              }
            }
          },
          "workflow_defect": {
            "properties": {
              "status": {
                "const": "closed"
              }
            }
          }
        },
        "required": [
          "effective_hooks_proof"
        ]
      }
    }
  ]
}
