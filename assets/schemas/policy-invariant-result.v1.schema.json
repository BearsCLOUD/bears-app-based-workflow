{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/policy-invariant-result.v1.schema.json",
  "title": "Bears policy invariant result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "evaluated_at", "input_ref", "checks", "errors", "summary"],
  "properties": {
    "schema": {"const": "bears-policy-invariant-result.v1"},
    "status": {"enum": ["pass", "fail"]},
    "evaluated_at": {"type": "string"},
    "input_ref": {"type": "string"},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed", "changed_files", "covered_issues", "forbidden_marker_hits"],
      "properties": {
        "passed": {"type": "integer"},
        "failed": {"type": "integer"},
        "changed_files": {"type": "integer"},
        "covered_issues": {"type": "integer"},
        "forbidden_marker_hits": {"type": "integer"}
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "severity", "message", "details"],
        "properties": {
          "id": {"type": "string", "minLength": 3},
          "status": {"enum": ["pass", "fail"]},
          "severity": {"enum": ["blocking", "warning"]},
          "message": {"type": "string"},
          "details": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
