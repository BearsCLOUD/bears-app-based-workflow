{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/principle-decision.v1.schema.json",
  "title": "Bears principle decision packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "decision_id",
    "issue",
    "decision",
    "principles_applied",
    "goals_supported",
    "alternatives_rejected",
    "reason_code",
    "evidence_paths"
  ],
  "properties": {
    "schema": {"const": "bears-principle-decision.v1"},
    "decision_id": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9][a-z0-9_\\.-]*$"},
    "issue": {"type": "string", "pattern": "^(#[0-9]+|null)$"},
    "decision": {"type": "string", "minLength": 3},
    "principles_applied": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "goals_supported": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "alternatives_rejected": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "reason_code": {"type": "string", "minLength": 3},
    "evidence_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
