{
  "$id": "https://bears.local/schemas/prompt-compile-request.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears prompt compile request v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-prompt-compile-request.v1"},
    "goal_id": {"type": "string", "minLength": 1},
    "role_id": {"type": "string", "minLength": 1},
    "execution_unit": {"type": ["string", "null"]},
    "task": {"type": "string", "minLength": 1},
    "required_outputs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "decision_graph": {"type": "string", "minLength": 1},
    "inference_proofs": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string", "minLength": 1},
          {"$ref": "#/$defs/inference_proof"}
        ]
      }
    },
    "context_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string", "minLength": 1},
          {"$ref": "#/$defs/context_request"}
        ]
      }
    },
    "max_tokens": {"type": "integer", "minimum": 1},
    "allow_full_file_read": {"type": "boolean"},
    "context_level": {"enum": ["L0", "L1", "L2", "L3", "L4"]}
  },
  "required": [
    "schema",
    "goal_id",
    "role_id",
    "execution_unit",
    "task",
    "required_outputs",
    "decision_graph",
    "inference_proofs",
    "context_ids",
    "max_tokens",
    "allow_full_file_read"
  ],
  "$defs": {
    "context_request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "context_id": {"type": "string", "minLength": 1},
        "level": {"enum": ["L0", "L1", "L2", "L3", "L4"]},
        "reason": {"type": "string", "minLength": 1}
      },
      "required": ["context_id", "level"]
    },
    "inference_proof": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "proof_id": {"type": "string", "minLength": 1},
        "predicate": {"type": "string", "minLength": 1},
        "arguments": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "status": {"enum": ["accepted", "candidate", "rejected"]},
        "confidence": {"enum": ["accepted", "candidate", "rejected"]},
        "proof_trace": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "required": ["proof_id", "predicate", "arguments"]
    }
  }
}
