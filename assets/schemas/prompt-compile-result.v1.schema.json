{
  "$id": "https://bears.local/schemas/prompt-compile-result.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears prompt compile result v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-prompt-compile-result.v1"},
    "status": {"enum": ["pass", "blocked"]},
    "prompt_id": {"type": "string", "minLength": 1},
    "prompt_hash": {"type": "string", "minLength": 64},
    "goal_id": {"type": "string", "minLength": 1},
    "role_id": {"type": "string", "minLength": 1},
    "execution_unit": {"type": ["string", "null"]},
    "context_pack_hash": {"type": "string", "minLength": 64},
    "max_tokens": {"type": "integer", "minimum": 1},
    "token_estimate": {"type": "integer", "minimum": 0},
    "prompt_text": {"type": "string"},
    "required_output_schema": {"type": "object"},
    "metadata": {"type": "object"},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "required": [
    "schema",
    "status",
    "prompt_id",
    "prompt_hash",
    "goal_id",
    "role_id",
    "execution_unit",
    "context_pack_hash",
    "max_tokens",
    "token_estimate",
    "prompt_text",
    "required_output_schema",
    "metadata",
    "errors"
  ]
}
