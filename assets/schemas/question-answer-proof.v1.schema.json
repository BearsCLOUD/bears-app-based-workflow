{
  "$id": "https://bears.local/schemas/question-answer-proof.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "answer": {
      "minLength": 1,
      "type": "string"
    },
    "answer_type": {
      "enum": [
        "execution",
        "manual_review",
        "research_required",
        "blocked"
      ]
    },
    "blocked_gates": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "evidence_paths": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "evidence_types": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "operator_id": {
      "enum": [
        "resolve_source_of_truth",
        "classify_task_type",
        "find_smallest_verifiable_goal",
        "infer_required_research",
        "infer_required_plan",
        "select_semantic_context",
        "select_role_profile",
        "select_executor",
        "select_model_tier",
        "select_mcp_policy",
        "select_file_scope",
        "select_validation_gate",
        "select_closeout_gate",
        "select_roadmap_update",
        "select_self_improvement_action"
      ]
    },
    "proof_id": {
      "minLength": 1,
      "type": "string"
    },
    "reason": {
      "minLength": 1,
      "type": "string"
    },
    "schema": {
      "const": "bears-question-answer-proof.v1"
    },
    "semantic_fact_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "accepted",
        "candidate",
        "rejected"
      ]
    },
    "unlocked_gates": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "validator": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "proof_id",
    "operator_id",
    "answer",
    "answer_type",
    "status",
    "evidence_paths",
    "evidence_types",
    "semantic_fact_refs",
    "unlocked_gates",
    "blocked_gates",
    "validator"
  ],
  "title": "Bears question answer proof v1",
  "type": "object"
}
