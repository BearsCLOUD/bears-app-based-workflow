{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/release-notes.v1.schema.json",
  "title": "Bears release notes",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "entries", "exemptions"],
  "properties": {
    "schema": {"const": "bears-release-notes.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/entry"}
    },
    "exemptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/exemption"}
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "issue_ref", "impact", "validation", "affected_surfaces", "files"],
      "properties": {
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "issue_ref": {"type": "string", "pattern": "^#[0-9]+$"},
        "impact": {"type": "string", "minLength": 3},
        "validation": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "affected_surfaces": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "exemption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "issue_ref", "reason", "files"],
      "properties": {
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "issue_ref": {"type": "string", "pattern": "^#[0-9]+$"},
        "reason": {"type": "string", "minLength": 3},
        "files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
