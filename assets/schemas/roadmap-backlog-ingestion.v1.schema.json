{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/roadmap-backlog-ingestion.v1.schema.json",
  "title": "Bears roadmap backlog ingestion packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "repo", "updated_at", "source_issues", "existing_nodes", "proposed_nodes", "duplicates", "manual_review", "blocked", "fillability"],
  "properties": {
    "schema": {"const": "bears-roadmap-backlog-ingestion.v1"},
    "version": {"type": "string"},
    "repo": {"type": "string", "minLength": 3},
    "updated_at": {"type": "string", "minLength": 1},
    "source_issues": {"type": "array", "items": {"$ref": "#/$defs/source_issue"}},
    "existing_nodes": {"type": "array", "items": {"$ref": "#/$defs/node_ref"}},
    "proposed_nodes": {"type": "array", "items": {"$ref": "#/$defs/proposed_node"}},
    "duplicates": {"type": "array", "items": {"type": "object"}},
    "manual_review": {"type": "array", "items": {"$ref": "#/$defs/classified_issue"}},
    "blocked": {"type": "array", "items": {"$ref": "#/$defs/classified_issue"}},
    "fillability": {"$ref": "#/$defs/fillability"}
  },
  "$defs": {
    "classification": {"enum": ["already_in_roadmap", "needs_roadmap_node", "duplicate_of_existing_node", "blocked_by_missing_contract", "manual_review", "closeout_candidate", "unsafe_for_autostart"]},
    "source_issue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repo", "number", "issue_ref", "title", "state", "url", "labels", "classification", "risk_class", "source"],
      "properties": {
        "repo": {"type": "string"},
        "number": {"type": "integer"},
        "issue_ref": {"type": "string"},
        "title": {"type": "string"},
        "state": {"type": "string"},
        "url": {"type": "string"},
        "labels": {"type": "array", "items": {"type": "string"}},
        "classification": {"$ref": "#/$defs/classification"},
        "risk_class": {"type": "string"},
        "source": {"type": "string"},
        "required_files": {"type": "array", "items": {"type": "string"}},
        "acceptance_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "classified_issue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["issue_ref", "number", "classification", "reason"],
      "properties": {
        "issue_ref": {"type": "string"},
        "number": {"type": "integer"},
        "classification": {"$ref": "#/$defs/classification"},
        "reason": {"type": "string"}
      }
    },
    "node_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "issue", "state", "node_type"],
      "properties": {
        "node_id": {"type": "string"},
        "issue": {"type": "string"},
        "state": {"type": "string"},
        "node_type": {"type": "string"}
      }
    },
    "proposed_node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["node_id", "issue", "node_type", "state", "owner_role", "source_of_truth", "inputs", "outputs", "depends_on", "decomposes_to", "blocked_by", "autostart_policy", "evidence_paths", "source_issue_url", "risk_class", "required_files", "acceptance_criteria"],
      "properties": {
        "node_id": {"type": "string"},
        "issue": {"type": "string"},
        "node_type": {"type": "string"},
        "state": {"type": "string"},
        "owner_role": {"type": "string"},
        "source_of_truth": {"type": "array", "items": {"type": "string"}},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "outputs": {"type": "array", "items": {"type": "string"}},
        "depends_on": {"type": "array", "items": {"type": "string"}},
        "decomposes_to": {"type": "array", "items": {"type": "string"}},
        "blocked_by": {"type": "array", "items": {"type": "string"}},
        "autostart_policy": {"type": "string"},
        "evidence_paths": {"type": "array", "items": {"type": "string"}},
        "source_issue_url": {"type": "string"},
        "risk_class": {"type": "string"},
        "required_files": {"type": "array", "items": {"type": "string"}},
        "acceptance_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "fillability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open_issue_count", "already_in_roadmap", "needs_node", "safe_autostart_candidates", "manual_review_count", "blocked_count"],
      "properties": {
        "open_issue_count": {"type": "integer"},
        "already_in_roadmap": {"type": "integer"},
        "needs_node": {"type": "integer"},
        "safe_autostart_candidates": {"type": "integer"},
        "manual_review_count": {"type": "integer"},
        "blocked_count": {"type": "integer"}
      }
    }
  }
}
