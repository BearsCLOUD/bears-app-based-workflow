{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/roadmap-issue-coverage.v1.schema.json",
  "title": "Bears roadmap issue coverage catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "status",
    "repo",
    "updated_at",
    "owner_role",
    "source_truth",
    "commands",
    "policy",
    "tracked_open_issues",
    "exemptions",
    "fixtures"
  ],
  "properties": {
    "schema": {"const": "bears-roadmap-issue-coverage.v1"},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["active", "draft", "deprecated"]},
    "repo": {"type": "string", "minLength": 3},
    "updated_at": {"type": "string", "minLength": 1},
    "owner_role": {"type": "string", "minLength": 3},
    "source_truth": {"$ref": "#/$defs/source_truth"},
    "commands": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 3}
    },
    "policy": {"$ref": "#/$defs/policy"},
    "tracked_open_issues": {
      "type": "array",
      "items": {"$ref": "#/$defs/issue_metadata"}
    },
    "exemptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/exemption"}
    },
    "fixtures": {"$ref": "#/$defs/fixtures"}
  },
  "$defs": {
    "source_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roadmap_catalog", "priority_catalog"],
      "properties": {
        "roadmap_catalog": {"type": "string", "minLength": 3},
        "priority_catalog": {"type": "string", "minLength": 3}
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_metadata_only",
        "raw_issue_bodies_allowed",
        "raw_logs_allowed",
        "covered_states",
        "excluded_states",
        "missing_issue_status"
      ],
      "properties": {
        "issue_metadata_only": {"type": "boolean"},
        "raw_issue_bodies_allowed": {"type": "boolean"},
        "raw_logs_allowed": {"type": "boolean"},
        "covered_states": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "excluded_states": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "missing_issue_status": {"enum": ["manual_review", "blocked", "fail"]}
      }
    },
    "issue_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "issue_ref", "title", "state", "url", "labels", "updated_at", "priority"],
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "issue_ref": {"type": "string", "pattern": "^#[0-9]+$"},
        "title": {"type": "string", "minLength": 1},
        "state": {"enum": ["OPEN", "CLOSED"]},
        "url": {"type": "string", "minLength": 1},
        "labels": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "updated_at": {"type": "string", "minLength": 1},
        "priority": {"enum": ["P0", "P1", "P2", "unknown"]}
      }
    },
    "exemption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_ref", "reason", "expires_at"],
      "properties": {
        "issue_ref": {"type": "string", "pattern": "^#[0-9]+$"},
        "reason": {"type": "string", "minLength": 3},
        "expires_at": {"type": "string", "minLength": 1}
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["good_issue_metadata", "good_roadmap", "good_priority", "bad_issue_metadata"],
      "properties": {
        "good_issue_metadata": {"type": "string", "minLength": 3},
        "good_roadmap": {"type": "string", "minLength": 3},
        "good_priority": {"type": "string", "minLength": 3},
        "bad_issue_metadata": {"type": "string", "minLength": 3}
      }
    }
  }
}
