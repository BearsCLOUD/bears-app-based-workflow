{
  "$id": "https://bears.local/schemas/role-patch-plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears role patch plan v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-role-patch-plan.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "role_id": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "allowed_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "forbidden_actions": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "question_gate_required": {"type": "boolean"},
    "evidence_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "required": ["schema", "run_id", "role_id", "reason", "allowed_paths", "forbidden_actions", "question_gate_required", "evidence_paths"]
}
