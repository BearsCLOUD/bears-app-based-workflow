{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/scope-matrix.v1.schema.json",
  "title": "Bears Scope Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "operator_messages_count", "scopes"],
  "properties": {
    "schema": {"const": "bears-scope-matrix.v1"},
    "schema_version": {"type": "string"},
    "operator_messages_count": {"type": "integer", "minimum": 0},
    "scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scope_id",
          "user_message_ref",
          "repo_domain",
          "measurable_output",
          "timebox_min",
          "token_budget",
          "owner_lineage",
          "stages",
          "status"
        ],
        "properties": {
          "scope_id": {"type": "string"},
          "user_message_ref": {"type": "string"},
          "repo_domain": {"enum": ["platform", "gitops", "infra", "product_infra"]},
          "repo_domains": {"type": "array", "items": {"enum": ["platform", "gitops", "infra", "product_infra"]}},
          "measurable_output": {"type": "string", "minLength": 8},
          "timebox_min": {"type": "integer", "minimum": 1},
          "token_budget": {"type": "integer", "minimum": 1},
          "owner_lineage": {"type": "object"},
          "stages": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "status": {"type": "string"},
          "validation_command": {"type": "string"}
        }
      }
    }
  }
}
