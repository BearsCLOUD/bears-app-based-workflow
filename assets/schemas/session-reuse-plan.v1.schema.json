{
  "$defs": {
    "reuse_decision": {
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "reuse_candidate",
            "fresh_required",
            "reuse_denied"
          ]
        },
        "unit_id": {
          "type": "string"
        }
      },
      "required": [
        "unit_id",
        "status",
        "reason",
        "session_id"
      ],
      "type": "object"
    },
    "unit_ref": {
      "additionalProperties": false,
      "properties": {
        "packet_path": {
          "type": "string"
        },
        "target_files": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unit_id": {
          "type": "string"
        }
      },
      "required": [
        "unit_id",
        "packet_path",
        "target_files"
      ],
      "type": "object"
    }
  },
  "$id": "https://bears.local/schemas/session-reuse-plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "context_index_version": {
      "type": "string"
    },
    "delivery_id": {
      "type": "string"
    },
    "errors": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "fanout_groups": {
      "items": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "type": "array"
    },
    "goal_id": {
      "type": "string"
    },
    "reuse_decisions": {
      "items": {
        "$ref": "#/$defs/reuse_decision"
      },
      "type": "array"
    },
    "schema": {
      "const": "bears-session-reuse-plan.v1"
    },
    "state": {
      "enum": [
        "blocked",
        "ready",
        "running",
        "complete"
      ]
    },
    "units": {
      "items": {
        "$ref": "#/$defs/unit_ref"
      },
      "type": "array"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "schema",
    "version",
    "goal_id",
    "delivery_id",
    "state",
    "context_index_version",
    "units",
    "reuse_decisions",
    "fanout_groups",
    "errors"
  ],
  "title": "Bears session reuse plan",
  "type": "object"
}
