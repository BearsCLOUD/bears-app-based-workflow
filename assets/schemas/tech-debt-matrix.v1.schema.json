{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tech-debt-matrix.v1",
  "type": "object",
  "required": [
    "schema_version",
    "updated",
    "owner_plugin",
    "policy",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "tech-debt-matrix.v1"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "owner_plugin": {
      "const": "bears"
    },
    "policy": {
      "type": "object",
      "required": [
        "source_of_truth",
        "github_review_dependency_allowed",
        "state_files_required",
        "local_validation_failure_creates_debt",
        "unrelated_scope_blocking_allowed",
        "closure_requires"
      ],
      "properties": {
        "source_of_truth": {
          "const": "machine_readable_state_files"
        },
        "github_review_dependency_allowed": {
          "const": false
        },
        "state_files_required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "unrelated_scope_blocking_allowed": {
          "const": false
        },
        "closure_requires": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "local_validation_failure_creates_debt": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "severity",
          "source",
          "scope_id",
          "owner_role",
          "created_at",
          "title",
          "evidence_refs",
          "state_refs",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TD-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"
          },
          "status": {
            "enum": [
              "open",
              "in_progress",
              "closed",
              "deferred"
            ]
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "blocker"
            ]
          },
          "source": {
            "enum": [
              "local_validation_failure",
              "ci_failure",
              "workflow_defect",
              "operator_directive",
              "deferred_dirty",
              "runtime_degradation"
            ]
          },
          "scope_id": {
            "type": "string",
            "minLength": 1
          },
          "owner_role": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "state_refs": {
            "type": "object",
            "required": [
              "workflow_state",
              "merge_authority_state"
            ],
            "properties": {
              "workflow_state": {
                "type": "string",
                "minLength": 1
              },
              "merge_authority_state": {
                "type": "string",
                "minLength": 1
              },
              "runtime_activation": {
                "type": "string",
                "minLength": 1
              },
              "plugin_cache_sync_state": {
                "type": "string",
                "minLength": 1
              },
              "local_commit_validation": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
