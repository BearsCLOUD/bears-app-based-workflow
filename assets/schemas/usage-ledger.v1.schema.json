{
  "$id": "https://bears.local/schemas/usage-ledger.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears usage ledger v1",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": {"const": "bears-usage-ledger.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "issue_task_id": {"type": "string", "minLength": 1},
    "level": {"enum": ["L1", "L2", "L3", "L4", "L5", "L6", "L7"]},
    "model_executor": {"type": "string", "minLength": 1},
    "input_estimated_tokens": {"type": "integer", "minimum": 0},
    "output_estimated_tokens": {"type": "integer", "minimum": 0},
    "wall_time_ms": {"type": "integer", "minimum": 0},
    "files_read": {"type": "array", "items": {"type": "string"}},
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "tools_called": {"type": "array", "items": {"type": "string"}},
    "external_facts_count": {"type": "integer", "minimum": 0},
    "retries": {"type": "integer", "minimum": 0},
    "failure_class": {"type": "string"},
    "result_quality_score": {"type": "number", "minimum": 0, "maximum": 1},
    "validation_status": {"enum": ["pending_local_commit_validation", "validated", "failed_validation"]},
    "closeout_allowed": {"type": "boolean"},
    "quality_score_basis": {"type": "string", "minLength": 1}
  },
  "required": ["schema", "run_id", "issue_task_id", "level", "model_executor", "input_estimated_tokens", "output_estimated_tokens", "wall_time_ms", "files_read", "files_changed", "tools_called", "external_facts_count", "retries", "failure_class", "result_quality_score", "validation_status", "closeout_allowed", "quality_score_basis"]
}
