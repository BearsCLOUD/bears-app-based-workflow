{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/validation-state.v1.schema.json",
  "title": "Bears async validation state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "status",
    "updated_at",
    "repo_path",
    "repo_id",
    "commit_sha",
    "job_id",
    "job_path",
    "changed_files",
    "selected_tests",
    "validators",
    "shard_id",
    "timeout_seconds",
    "exit_code",
    "failure_classification",
    "retry_count",
    "sanitized_summary",
    "remediation_packet"
  ],
  "properties": {
    "schema": {
      "const": "bears-validation-state.v1"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "pass",
        "fail",
        "timeout",
        "infra_fail",
        "selector_gap",
        "cancelled",
        "quarantined"
      ]
    },
    "updated_at": {
      "type": "string",
      "minLength": 10
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "repo_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 7
    },
    "job_id": {
      "type": "string",
      "minLength": 3
    },
    "job_path": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selected_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shard_id": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer"
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "failure_classification": {
      "enum": [
        "none",
        "test_fail",
        "timeout",
        "infra_fail",
        "selector_gap",
        "cancelled"
      ]
    },
    "retry_count": {
      "type": "integer"
    },
    "sanitized_summary": {
      "type": "string"
    },
    "remediation_packet": {
      "type": [
        "string",
        "null"
      ]
    },
    "local_commit_validation_proof": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
