{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/workflow-node.v1.schema.json",
  "title": "Bears workflow node",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "node_type",
    "owner_role",
    "repo_boundary",
    "target_paths",
    "allowed_write_scope",
    "forbidden_scope",
    "preconditions",
    "inputs",
    "outputs",
    "allowed_runners",
    "validation_commands",
    "evidence_outputs",
    "blocker_conditions",
    "closeout_conditions",
    "next_nodes"
  ],
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "node_type": {
      "enum": [
        "research",
        "plan",
        "implementation",
        "validation",
        "review",
        "fix",
        "closeout",
        "bounded_loop"
      ]
    },
    "owner_role": {
      "type": "string",
      "minLength": 3
    },
    "repo_boundary": {
      "type": "string",
      "minLength": 3
    },
    "target_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_write_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_runners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocker_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "closeout_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
