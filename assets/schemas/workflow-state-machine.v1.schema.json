{
  "$id": "https://bears.local/schemas/workflow-state-machine.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears workflow state machine v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-workflow-state-machine.v1"},
    "version": {"type": "string", "minLength": 1},
    "owner_issue": {"const": "#439"},
    "states": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "commands": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "transitions": {"type": "array", "items": {"$ref": "workflow-transition.v1.schema.json"}},
    "invariants": {"type": "array", "items": {"$ref": "workflow-invariant.v1.schema.json"}},
    "evidence_authority": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "required": ["schema", "version", "owner_issue", "states", "commands", "transitions", "invariants", "evidence_authority"]
}
