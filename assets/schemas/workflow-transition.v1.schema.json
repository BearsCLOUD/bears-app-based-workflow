{
  "$id": "https://bears.local/schemas/workflow-transition.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bears workflow transition v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "bears-workflow-transition.v1"},
    "goal_id": {"type": "string", "minLength": 1},
    "from_state": {"type": "string", "minLength": 1},
    "to_state": {"type": "string", "minLength": 1},
    "guard": {"type": "string", "minLength": 1},
    "required_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "invariants_checked": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "reason_code": {"type": "string", "minLength": 1}
  },
  "required": ["schema", "goal_id", "from_state", "to_state", "guard", "required_evidence", "invariants_checked", "reason_code"]
}
