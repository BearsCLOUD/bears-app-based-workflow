{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/workflow-tree.v1.schema.json",
  "title": "Bears executable workflow tree",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "goal_id",
    "repo_boundary",
    "root_issue",
    "root_role",
    "state",
    "nodes",
    "edges",
    "required_artifacts",
    "required_decisions",
    "required_validations",
    "closeout_gate"
  ],
  "properties": {
    "schema": {
      "const": "bears-workflow-tree.v1"
    },
    "version": {
      "type": "string"
    },
    "goal_id": {
      "type": "string",
      "minLength": 3
    },
    "repo_boundary": {
      "type": "string",
      "minLength": 3
    },
    "root_issue": {
      "type": "string",
      "pattern": "^#[0-9]+$"
    },
    "root_role": {
      "type": "string",
      "minLength": 3
    },
    "state": {
      "enum": [
        "draft",
        "ready",
        "running",
        "blocked",
        "pass",
        "fail"
      ]
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_validations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "closeout_gate": {
      "$ref": "#/$defs/closeout_gate"
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type",
        "owner_role",
        "repo_boundary",
        "target_paths",
        "allowed_write_scope",
        "forbidden_scope",
        "preconditions",
        "inputs",
        "outputs",
        "allowed_runners",
        "validation_commands",
        "evidence_outputs",
        "blocker_conditions",
        "closeout_conditions",
        "next_nodes"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 3,
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "node_type": {
          "enum": [
            "research",
            "plan",
            "implementation",
            "validation",
            "review",
            "fix",
            "closeout",
            "bounded_loop"
          ]
        },
        "owner_role": {
          "type": "string",
          "minLength": 3
        },
        "repo_boundary": {
          "type": "string",
          "minLength": 3
        },
        "target_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_write_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_runners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validation_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocker_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "closeout_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_nodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "edge_type"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 3
        },
        "to": {
          "type": "string",
          "minLength": 3
        },
        "edge_type": {
          "enum": [
            "sequence",
            "blocked_remediation",
            "bounded_loop"
          ]
        },
        "max_iterations": {
          "type": "integer"
        }
      }
    },
    "closeout_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_node",
        "required_evidence",
        "blocking_statuses"
      ],
      "properties": {
        "required_node": {
          "type": "string",
          "minLength": 3
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocking_statuses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "blocked",
              "fail",
              "pending",
              "missing"
            ]
          }
        }
      }
    }
  }
}
