{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/workspace-dictionary.v1.schema.json",
  "title": "Bears workspace dictionary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "commands", "terms"],
  "properties": {
    "schema": {"const": "bears-workspace-dictionary.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "commands": {"type": "array", "items": {"type": "string"}},
    "terms": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["term_id", "canonical_term", "aliases", "category", "definition", "source_refs", "related_terms", "forbidden_aliases"], "properties": {"term_id": {"type": "string", "minLength": 3}, "canonical_term": {"type": "string", "minLength": 1}, "aliases": {"type": "array", "items": {"type": "string"}}, "category": {"enum": ["workflow", "infra", "python", "database", "agent", "gitops", "domain", "seller", "platform"]}, "definition": {"type": "string", "minLength": 3}, "source_refs": {"type": "array", "items": {"type": "string"}}, "related_terms": {"type": "array", "items": {"type": "string"}}, "forbidden_aliases": {"type": "array", "items": {"type": "string"}}}}},
    "candidate_policy": {"type": "object"}
  }
}
