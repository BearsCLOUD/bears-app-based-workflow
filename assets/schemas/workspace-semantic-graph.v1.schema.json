{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/schemas/workspace-semantic-graph.v1.schema.json",
  "title": "Bears workspace semantic graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated", "owner_role", "commands", "node_types", "edge_types", "nodes", "edges"],
  "properties": {
    "schema": {"const": "bears-workspace-semantic-graph.v1"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "owner_role": {"type": "string", "minLength": 3},
    "commands": {"type": "array", "items": {"type": "string"}},
    "node_types": {"type": "array", "items": {"type": "string"}},
    "edge_types": {"type": "array", "items": {"type": "string"}},
    "nodes": {"type": "array", "items": {"$ref": "workspace-semantic-node.v1.schema.json"}},
    "edges": {"type": "array", "items": {"$ref": "workspace-semantic-edge.v1.schema.json"}},
    "integration_points": {"type": "object"}
  }
}
