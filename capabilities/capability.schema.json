{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.example/schemas/bears-plugin-capability-inventory.v1.schema.json",
  "title": "Bears plugin capability inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "updated",
    "owner_plugin",
    "source_repo",
    "codex_environment_policy",
    "capabilities",
    "rule_coverage",
    "hot_path_legacy_exceptions",
    "cache_validation",
    "validation_commands"
  ],
  "properties": {
    "schema": {
      "const": "bears-plugin-capability-inventory.v1"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "owner_plugin": {
      "const": "bears"
    },
    "source_repo": {
      "const": "BearsCLOUD/bears_plugin"
    },
    "codex_environment_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_surfaces_are_not_capability_sources",
        "mutation_requires_operator_authorization",
        "restricted_data"
      ],
      "properties": {
        "environment_surfaces_are_not_capability_sources": {
          "const": true
        },
        "mutation_requires_operator_authorization": {
          "const": true
        },
        "restricted_data": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      },
      "minItems": 1
    },
    "rule_coverage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleCoverage"
      }
    },
    "hot_path_legacy_exceptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hotPathException"
      }
    },
    "cache_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovery_command",
        "source_vs_cache_command",
        "unknown_status",
        "sync_required_status"
      ],
      "properties": {
        "discovery_command": {
          "type": "string",
          "minLength": 1
        },
        "source_vs_cache_command": {
          "type": "string",
          "minLength": 1
        },
        "unknown_status": {
          "const": "CACHE_PATH_UNKNOWN"
        },
        "sync_required_status": {
          "const": "CACHE_SYNC_REQUIRED"
        }
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pathArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claimArray": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "python_package",
        "lifecycle_state",
        "canonical_source_phase",
        "owner_role",
        "primary_legacy_sources",
        "capability_source_paths",
        "active_skill_front_doors",
        "internal_front_door",
        "legacy_entrypoints",
        "compatibility_entrypoints",
        "schemas",
        "fixtures",
        "tests",
        "validators",
        "forbidden_data",
        "allowed_actions",
        "forbidden_actions",
        "sanitized_evidence_schema",
        "context_budget",
        "cache_sync_required",
        "environment_surface_claims",
        "performance_claims",
        "offload_surface_claims",
        "programmatic_control_claims",
        "hook_claims",
        "reviewer_lane_policy",
        "agent_profiles",
        "open_issues",
        "cutover_blockers",
        "rollback_command"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "python_package": {
          "type": "string",
          "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$"
        },
        "lifecycle_state": {
          "enum": [
            "planned",
            "legacy",
            "dual",
            "capability",
            "deprecated"
          ]
        },
        "canonical_source_phase": {
          "enum": [
            "inventory",
            "legacy",
            "dual",
            "capability",
            "deprecated"
          ]
        },
        "owner_role": {
          "type": "string",
          "minLength": 1
        },
        "primary_legacy_sources": {
          "$ref": "#/$defs/pathArray"
        },
        "capability_source_paths": {
          "$ref": "#/$defs/pathArray"
        },
        "active_skill_front_doors": {
          "$ref": "#/$defs/pathArray"
        },
        "internal_front_door": {
          "type": "string"
        },
        "legacy_entrypoints": {
          "$ref": "#/$defs/stringArray"
        },
        "compatibility_entrypoints": {
          "$ref": "#/$defs/stringArray"
        },
        "schemas": {
          "$ref": "#/$defs/pathArray"
        },
        "fixtures": {
          "$ref": "#/$defs/pathArray"
        },
        "tests": {
          "$ref": "#/$defs/pathArray"
        },
        "validators": {
          "$ref": "#/$defs/stringArray"
        },
        "forbidden_data": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "forbidden_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "sanitized_evidence_schema": {
          "type": "string"
        },
        "context_budget": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hot_path_words",
            "skill_description_chars"
          ],
          "properties": {
            "hot_path_words": {
              "type": "integer",
              "minimum": 0
            },
            "skill_description_chars": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "cache_sync_required": {
          "type": "boolean"
        },
        "environment_surface_claims": {
          "$ref": "#/$defs/claimArray"
        },
        "performance_claims": {
          "$ref": "#/$defs/claimArray"
        },
        "offload_surface_claims": {
          "$ref": "#/$defs/claimArray"
        },
        "programmatic_control_claims": {
          "$ref": "#/$defs/claimArray"
        },
        "hook_claims": {
          "$ref": "#/$defs/claimArray"
        },
        "reviewer_lane_policy": {
          "type": "object"
        },
        "agent_profiles": {
          "$ref": "#/$defs/pathArray"
        },
        "open_issues": {
          "$ref": "#/$defs/stringArray"
        },
        "cutover_blockers": {
          "$ref": "#/$defs/stringArray"
        },
        "rollback_command": {
          "type": "string"
        }
      }
    },
    "ruleCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "source_path",
        "source_anchor",
        "rule_class",
        "owner_capability_id",
        "router_allowed",
        "schema_paths",
        "validator_subcommands",
        "pass_fixture_ids",
        "fail_fixture_ids",
        "failure_class",
        "status_packet_field",
        "legacy_exception_id",
        "sunset_phase"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "source_anchor": {
          "type": "string",
          "minLength": 1
        },
        "rule_class": {
          "enum": [
            "machine_enforced",
            "router_only",
            "legacy_exception"
          ]
        },
        "owner_capability_id": {
          "type": "string",
          "minLength": 1
        },
        "router_allowed": {
          "type": "boolean"
        },
        "schema_paths": {
          "$ref": "#/$defs/pathArray"
        },
        "validator_subcommands": {
          "$ref": "#/$defs/stringArray"
        },
        "pass_fixture_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "fail_fixture_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "failure_class": {
          "type": "string"
        },
        "status_packet_field": {
          "type": "string"
        },
        "legacy_exception_id": {
          "type": "string"
        },
        "sunset_phase": {
          "type": "string"
        }
      }
    },
    "hotPathException": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "field",
        "observed_size",
        "budget",
        "owner_role",
        "shrink_deadline_phase",
        "blocking_rule",
        "validator_command",
        "reviewer_signoff"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "observed_size": {
          "type": "string",
          "minLength": 1
        },
        "budget": {
          "type": "string",
          "minLength": 1
        },
        "owner_role": {
          "type": "string",
          "minLength": 1
        },
        "shrink_deadline_phase": {
          "type": "string",
          "minLength": 1
        },
        "blocking_rule": {
          "type": "string",
          "minLength": 1
        },
        "validator_command": {
          "type": "string",
          "minLength": 1
        },
        "reviewer_signoff": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
