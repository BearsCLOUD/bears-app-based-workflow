{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-context-index-result.v1.schema.json",
  "title": "App context index result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "app_id",
    "status",
    "source_snapshot_digest",
    "traceability_index_ref",
    "process_index_ref",
    "finding_refs",
    "target_status"
  ],
  "properties": {
    "schema": {"const": "app-context-index-result.v1"},
    "app_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["current", "updated", "conflict", "incomplete"]},
    "source_snapshot_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "traceability_index_ref": {"type": "string", "minLength": 1},
    "process_index_ref": {"type": "string", "minLength": 1},
    "finding_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "target_status": {"enum": ["none", "needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]}
  }
}
