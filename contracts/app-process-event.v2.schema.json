{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-process-event.v2.schema.json",
  "title": "app-process-event.v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "run_ref",
    "event_ref",
    "event_kind",
    "stage",
    "status",
    "actor",
    "repo_ref",
    "wave_ref",
    "task_refs",
    "causal_refs",
    "trace_refs",
    "artifact_refs",
    "origin",
    "automation_status"
  ],
  "properties": {
    "run_ref": {
      "type": "string",
      "minLength": 1
    },
    "event_ref": {
      "type": "string",
      "minLength": 1
    },
    "event_kind": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1
    },
    "wave_ref": {
      "type": "string",
      "minLength": 1
    },
    "causal_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "task_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "schema": {
      "const": "app-process-event.v2"
    },
    "origin": {
      "const": "native"
    },
    "automation_status": {
      "enum": [
        "not_run",
        "passed",
        "failed"
      ]
    },
    "task_ref": {
      "type": "string",
      "minLength": 1
    },
    "terminal_result": {
      "enum": [
        "done",
        "failed",
        "blocked"
      ]
    },
    "reviewed_task_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "finding_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "commit_range": {
      "type": "string",
      "minLength": 1
    },
    "remediates_run_ref": {
      "type": "string",
      "minLength": 1
    },
    "build_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_snapshot_digest": {
      "type": "string",
      "minLength": 1
    },
    "journal_digest": {
      "type": "string",
      "minLength": 1
    },
    "audit_receipt_ref": {
      "type": "string",
      "minLength": 1
    }
  }
}
