{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-process-index.v1.schema.json",
  "title": "App process index v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "app_id", "revision", "workflow_definition_ref", "workflow_definition_digest", "source_snapshot_digest", "runs", "events", "links", "findings"],
  "properties": {
    "schema": {"const": "app-process-index.v1"},
    "app_id": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 1},
    "workflow_definition_ref": {"type": "string", "minLength": 1},
    "workflow_definition_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "source_snapshot_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "wave_id", "status", "source_refs"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "wave_id": {"type": "string", "minLength": 1},
          "status": {"enum": ["active", "complete", "blocked"]},
          "source_refs": {"$ref": "#/$defs/refs"}
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "run_ref", "stage", "status", "artifact_refs"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "run_ref": {"type": "string", "minLength": 1},
          "stage": {"type": "string", "minLength": 1},
          "status": {"type": "string", "minLength": 1},
          "artifact_refs": {"$ref": "#/$defs/refs"}
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "from_ref", "to_ref", "source_refs"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["transitions_to", "delegates", "produces", "reviews", "remediates", "rereviews"]},
          "from_ref": {"type": "string", "minLength": 1},
          "to_ref": {"type": "string", "minLength": 1},
          "source_refs": {"$ref": "#/$defs/refs"}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "status", "source_refs"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["invalid-transition", "missing-gate", "ownership-drift", "source-drift", "trace-gap"]},
          "status": {"enum": ["open", "resolved"]},
          "source_refs": {"$ref": "#/$defs/refs"}
        }
      }
    }
  },
  "$defs": {
    "refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
