{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-role-profile-definition.v1.schema.json",
  "title": "app-role-profile-definition.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "name", "description", "identity", "model", "runtime_controls", "capability_requirements", "behavior"],
  "properties": {
    "schema": {"const": "app-role-profile-definition.v1"},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "description": {"type": "string", "minLength": 1, "maxLength": 1024},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "role_kind"],
      "properties": {
        "level": {"enum": ["L1", "L2", "L3"]},
        "role_kind": {"enum": ["orchestrator", "mutation-worker", "specialist"]}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reasoning_effort"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "reasoning_effort": {"enum": ["low", "medium", "high", "max"]}
      }
    },
    "runtime_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sandbox_mode", "web_search", "view_image"],
      "properties": {
        "sandbox_mode": {"enum": ["read-only", "workspace-write"]},
        "web_search": {"enum": ["disabled", "live"]},
        "view_image": {"type": "boolean"}
      }
    },
    "capability_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["native_tools", "plugins"],
      "properties": {
        "native_tools": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 128}},
        "plugins": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "skills", "mcp_servers"],
            "properties": {
              "id": {"type": "string", "minLength": 1, "maxLength": 128},
              "skills": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 128}},
              "mcp_servers": {
                "type": "array",
                "maxItems": 16,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "tools"],
                  "properties": {
                    "id": {"type": "string", "minLength": 1, "maxLength": 128},
                    "tools": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 128}}
                  }
                }
              }
            }
          }
        }
      }
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "forbidden", "required", "ask", "escalate", "conflict", "acceptance", "result", "example"],
      "properties": {
        "allowed": {"$ref": "#/$defs/rules"},
        "forbidden": {"$ref": "#/$defs/rules"},
        "required": {"$ref": "#/$defs/rules"},
        "ask": {"$ref": "#/$defs/rules"},
        "escalate": {"$ref": "#/$defs/rules"},
        "conflict": {"$ref": "#/$defs/rules"},
        "acceptance": {"$ref": "#/$defs/rules"},
        "result": {"$ref": "#/$defs/rules"},
        "example": {"$ref": "#/$defs/rules"}
      }
    }
  },
  "$defs": {
    "rules": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
          "text": {"type": "string", "minLength": 1, "maxLength": 4096}
        }
      }
    }
  }
}
