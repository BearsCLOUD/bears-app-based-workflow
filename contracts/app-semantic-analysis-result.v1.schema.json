{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-semantic-analysis-result.v1.schema.json",
  "title": "app-semantic-analysis-result.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "analysis_ref", "profile_ref", "model_ref", "checklist_ref", "basis_build_ref",
    "input_refs", "coverage", "findings", "unmapped_decision_refs", "unmapped_requirement_refs",
    "open_remediation_refs", "complete", "route"
  ],
  "properties": {
    "schema": {"const": "app-semantic-analysis-result.v1"},
    "analysis_ref": {"type": "string", "minLength": 1},
    "profile_ref": {"type": "string", "minLength": 1},
    "model_ref": {"type": "string", "minLength": 1},
    "checklist_ref": {"type": "string", "minLength": 1},
    "basis_build_ref": {"type": "string", "pattern": "^BUILD-[A-F0-9]{24}$"},
    "input_refs": {"$ref": "#/$defs/non_empty_refs"},
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources", "decisions", "requirements", "dimensions", "tasks", "process_records"],
      "properties": {
        "sources": {"type": "integer", "minimum": 0},
        "decisions": {"type": "integer", "minimum": 0},
        "requirements": {"type": "integer", "minimum": 0},
        "dimensions": {"type": "integer", "minimum": 0},
        "tasks": {"type": "integer", "minimum": 0},
        "process_records": {"type": "integer", "minimum": 0}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_ref", "kind", "subject_refs", "conflict_refs", "route", "summary"],
        "properties": {
          "finding_ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["missing-source", "product-conflict", "decision-conflict", "semantic-gap", "reference-gap", "cycle-gap", "task-gap", "implementation-gap", "evidence-gap", "review-gap", "remediation-gap", "credential-stop", "access-stop", "operator-stop"]},
          "subject_refs": {"$ref": "#/$defs/refs"},
          "conflict_refs": {"$ref": "#/$defs/refs"},
          "route": {"enum": ["needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]},
          "summary": {"type": "string", "minLength": 1}
        },
        "oneOf": [
          {"properties": {"kind": {"const": "missing-source"}, "route": {"const": "needs-research"}}},
          {"properties": {"kind": {"const": "product-conflict"}, "route": {"const": "needs-spec"}}},
          {"properties": {"kind": {"const": "decision-conflict"}, "route": {"const": "needs-spec"}}},
          {"properties": {"kind": {"const": "semantic-gap"}, "route": {"const": "needs-graph"}}},
          {"properties": {"kind": {"const": "reference-gap"}, "route": {"const": "needs-graph"}}},
          {"properties": {"kind": {"const": "cycle-gap"}, "route": {"const": "needs-graph"}}},
          {"properties": {"kind": {"const": "task-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "implementation-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "evidence-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "review-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "remediation-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "credential-stop"}, "route": {"const": "blocked"}}},
          {"properties": {"kind": {"const": "access-stop"}, "route": {"const": "blocked"}}},
          {"properties": {"kind": {"const": "operator-stop"}, "route": {"const": "blocked"}}}
        ]
      }
    },
    "unmapped_decision_refs": {"$ref": "#/$defs/refs"},
    "unmapped_requirement_refs": {"$ref": "#/$defs/refs"},
    "open_remediation_refs": {"$ref": "#/$defs/refs"},
    "complete": {"type": "boolean"},
    "route": {"enum": ["none", "needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]}
  },
  "$defs": {
    "non_empty_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
