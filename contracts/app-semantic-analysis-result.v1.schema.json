{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-semantic-analysis-result.v1.schema.json",
  "title": "app-semantic-analysis-result.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "analysis_ref", "profile_ref", "model_ref", "checklist_ref", "basis_build_ref",
    "input_refs", "coverage", "findings", "unmapped_decision_refs", "unmapped_requirement_refs",
    "open_remediation_refs", "complete", "route"
  ],
  "properties": {
    "schema": {"const": "app-semantic-analysis-result.v1"},
    "analysis_ref": {"type": "string", "minLength": 1},
    "profile_ref": {"type": "string", "minLength": 1},
    "model_ref": {"type": "string", "minLength": 1},
    "checklist_ref": {"type": "string", "minLength": 1},
    "basis_build_ref": {"type": "string", "pattern": "^BUILD-[A-F0-9]{24}$"},
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_refs", "decision_refs", "requirement_refs", "functionality_refs", "dimension_refs",
        "dimension_mapping_refs", "relation_refs", "graph_edge_refs", "functional_map_refs",
        "ledger_refs", "artifact_refs", "evidence_refs", "task_refs", "task_result_refs",
        "review_refs", "remediation_refs", "process_record_refs", "incoming_handoff_refs"
      ],
      "properties": {
        "source_refs": {"$ref": "#/$defs/ref_set_binding"},
        "decision_refs": {"$ref": "#/$defs/ref_set_binding"},
        "requirement_refs": {"$ref": "#/$defs/ref_set_binding"},
        "functionality_refs": {"$ref": "#/$defs/ref_set_binding"},
        "dimension_refs": {"$ref": "#/$defs/ref_set_binding"},
        "dimension_mapping_refs": {"$ref": "#/$defs/ref_set_binding"},
        "relation_refs": {"$ref": "#/$defs/ref_set_binding"},
        "graph_edge_refs": {"$ref": "#/$defs/ref_set_binding"},
        "functional_map_refs": {"$ref": "#/$defs/ref_set_binding"},
        "ledger_refs": {"$ref": "#/$defs/ref_set_binding"},
        "artifact_refs": {"$ref": "#/$defs/ref_set_binding"},
        "evidence_refs": {"$ref": "#/$defs/ref_set_binding"},
        "task_refs": {"$ref": "#/$defs/ref_set_binding"},
        "task_result_refs": {"$ref": "#/$defs/ref_set_binding"},
        "review_refs": {"$ref": "#/$defs/ref_set_binding"},
        "remediation_refs": {"$ref": "#/$defs/ref_set_binding"},
        "process_record_refs": {"$ref": "#/$defs/ref_set_binding"},
        "incoming_handoff_refs": {"$ref": "#/$defs/ref_set_binding"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sources", "decisions", "requirements", "functionalities", "dimensions",
        "dimension_mappings", "relations", "graph_edges", "functional_map", "ledger", "artifacts",
        "evidence", "tasks", "task_results", "reviews", "remediations", "process_records",
        "incoming_handoff"
      ],
      "properties": {
        "sources": {"type": "integer", "minimum": 0},
        "decisions": {"type": "integer", "minimum": 0},
        "requirements": {"type": "integer", "minimum": 0},
        "functionalities": {"type": "integer", "minimum": 0},
        "dimensions": {"type": "integer", "minimum": 0},
        "dimension_mappings": {"type": "integer", "minimum": 0},
        "relations": {"type": "integer", "minimum": 0},
        "graph_edges": {"type": "integer", "minimum": 0},
        "functional_map": {"type": "integer", "minimum": 0},
        "ledger": {"type": "integer", "minimum": 0},
        "artifacts": {"type": "integer", "minimum": 0},
        "evidence": {"type": "integer", "minimum": 0},
        "tasks": {"type": "integer", "minimum": 0},
        "task_results": {"type": "integer", "minimum": 0},
        "reviews": {"type": "integer", "minimum": 0},
        "remediations": {"type": "integer", "minimum": 0},
        "process_records": {"type": "integer", "minimum": 0},
        "incoming_handoff": {"type": "integer", "minimum": 0}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_ref", "kind", "subject_refs", "conflict_refs", "route", "summary"],
        "properties": {
          "finding_ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["missing-source", "product-conflict", "decision-conflict", "semantic-gap", "reference-gap", "cycle-gap", "task-gap", "implementation-gap", "evidence-gap", "review-gap", "remediation-gap", "credential-stop", "access-stop", "operator-stop"]},
          "subject_refs": {"$ref": "#/$defs/refs"},
          "conflict_refs": {"$ref": "#/$defs/refs"},
          "route": {"enum": ["needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]},
          "summary": {"type": "string", "minLength": 1}
        },
        "oneOf": [
          {"properties": {"kind": {"const": "missing-source"}, "route": {"const": "needs-research"}}},
          {"properties": {"kind": {"const": "product-conflict"}, "route": {"const": "needs-spec"}}},
          {"properties": {"kind": {"const": "decision-conflict"}, "route": {"const": "needs-spec"}}},
          {"properties": {"kind": {"const": "semantic-gap"}, "route": {"const": "needs-graph"}}},
          {"properties": {"kind": {"const": "reference-gap"}, "route": {"const": "needs-graph"}}},
          {"properties": {"kind": {"const": "cycle-gap"}, "route": {"const": "needs-graph"}}},
          {"properties": {"kind": {"const": "task-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "implementation-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "evidence-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "review-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "remediation-gap"}, "route": {"const": "needs-plan"}}},
          {"properties": {"kind": {"const": "credential-stop"}, "route": {"const": "blocked"}}},
          {"properties": {"kind": {"const": "access-stop"}, "route": {"const": "blocked"}}},
          {"properties": {"kind": {"const": "operator-stop"}, "route": {"const": "blocked"}}}
        ]
      }
    },
    "unmapped_decision_refs": {"$ref": "#/$defs/refs"},
    "unmapped_requirement_refs": {"$ref": "#/$defs/refs"},
    "open_remediation_refs": {"$ref": "#/$defs/refs"},
    "complete": {"type": "boolean"},
    "route": {"enum": ["none", "needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]}
  },
  "oneOf": [
    {
      "properties": {
        "route": {"const": "none"},
        "complete": {"const": true},
        "findings": {"maxItems": 0},
        "unmapped_decision_refs": {"maxItems": 0},
        "unmapped_requirement_refs": {"maxItems": 0},
        "open_remediation_refs": {"maxItems": 0}
      }
    },
    {
      "properties": {
        "route": {"enum": ["needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]},
        "complete": {"const": false}
      },
      "anyOf": [
        {"properties": {"findings": {"minItems": 1}}},
        {"properties": {"unmapped_decision_refs": {"minItems": 1}}},
        {"properties": {"unmapped_requirement_refs": {"minItems": 1}}},
        {"properties": {"open_remediation_refs": {"minItems": 1}}}
      ]
    }
  ],
  "$defs": {
    "refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "ref_set_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "refs_digest"],
      "properties": {
        "count": {"type": "integer", "minimum": 0},
        "refs_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    }
  }
}
