{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-stage-handoff.v2.schema.json",
  "title": "App stage handoff v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_stage",
    "target_stage",
    "status",
    "app_id",
    "wave_ids",
    "artifact_refs",
    "requirement_refs",
    "functional_map_revision",
    "traceability_index_ref",
    "traceability_index_revision",
    "source_snapshot_digest",
    "process_index_ref",
    "ledger_ref",
    "gap_refs",
    "evidence_refs",
    "dependency_refs",
    "decision_refs",
    "scope_delta",
    "implemented_state_refs",
    "context_index_result_ref"
  ],
  "properties": {
    "schema": {"const": "app-stage-handoff.v2"},
    "source_stage": {"type": "string", "minLength": 1},
    "target_stage": {"enum": ["app-research", "app-specify", "app-functional-graph", "app-plan", "app-dev", "app-analyze", "none"]},
    "status": {"enum": ["constitution-ready", "research-ready", "spec-ready", "graph-ready", "plan-ready", "ready", "waiting", "no-work", "implemented", "pass", "needs-research", "needs-spec", "needs-graph", "needs-plan", "blocked"]},
    "app_id": {"type": "string", "minLength": 1},
    "wave_ids": {"$ref": "#/$defs/refs"},
    "artifact_refs": {"$ref": "#/$defs/refs"},
    "requirement_refs": {"$ref": "#/$defs/refs"},
    "functional_map_revision": {"anyOf": [{"type": "integer", "minimum": 1}, {"const": "none"}]},
    "traceability_index_ref": {"type": "string", "minLength": 1},
    "traceability_index_revision": {"anyOf": [{"type": "integer", "minimum": 1}, {"const": "none"}]},
    "source_snapshot_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "process_index_ref": {"type": "string", "minLength": 1},
    "ledger_ref": {"type": "string", "minLength": 1},
    "gap_refs": {"$ref": "#/$defs/refs"},
    "evidence_refs": {"$ref": "#/$defs/refs"},
    "dependency_refs": {"$ref": "#/$defs/refs"},
    "decision_refs": {"$ref": "#/$defs/refs"},
    "scope_delta": {"type": "string", "minLength": 1},
    "implemented_state_refs": {"$ref": "#/$defs/refs"},
    "context_index_result_ref": {"type": "string", "minLength": 1},
    "app_repo_or_path": {"type": "string", "minLength": 1},
    "constitution_ref": {"type": "string", "minLength": 1},
    "constraint_refs": {"$ref": "#/$defs/refs"},
    "research_unknowns": {"$ref": "#/$defs/refs"},
    "wave_creation_basis": {"type": "string", "minLength": 1},
    "research_refs": {"$ref": "#/$defs/refs"},
    "question_refs": {"$ref": "#/$defs/refs"},
    "source_refs": {"$ref": "#/$defs/refs"},
    "specification_refs": {"$ref": "#/$defs/refs"},
    "required_behavior_refs": {"$ref": "#/$defs/refs"},
    "dependency_coverage_refs": {"$ref": "#/$defs/refs"},
    "state_coverage_refs": {"$ref": "#/$defs/refs"},
    "api_coverage_refs": {"$ref": "#/$defs/refs"},
    "data_coverage_refs": {"$ref": "#/$defs/refs"},
    "integration_coverage_refs": {"$ref": "#/$defs/refs"},
    "error_coverage_refs": {"$ref": "#/$defs/refs"},
    "functional_map_ref": {"type": "string", "minLength": 1},
    "functionality_refs": {"$ref": "#/$defs/refs"},
    "graph_entity_refs": {"$ref": "#/$defs/refs"},
    "coverage_refs": {"$ref": "#/$defs/refs"},
    "replacement_refs": {"$ref": "#/$defs/refs"},
    "task_records": {"type": "array", "items": {"$ref": "#/$defs/task"}},
    "source_handoff_ref": {"type": "string", "minLength": 1},
    "blocked_task_refs": {"$ref": "#/$defs/refs"},
    "dependency_state_evidence_refs": {"$ref": "#/$defs/refs"},
    "plan_refs": {"$ref": "#/$defs/refs"},
    "repo_ref": {"type": "string", "minLength": 1},
    "completed_task_refs": {"$ref": "#/$defs/refs"},
    "failed_task_refs": {"$ref": "#/$defs/refs"},
    "task_result_refs": {"$ref": "#/$defs/refs"},
    "review_result_refs": {"$ref": "#/$defs/refs"},
    "commit_range_refs": {"$ref": "#/$defs/refs"},
    "remediation_task_refs": {"$ref": "#/$defs/refs"},
    "analysis_refs": {"$ref": "#/$defs/refs"},
    "affected_graph_refs": {"$ref": "#/$defs/refs"},
    "ledger_coverage_refs": {"$ref": "#/$defs/refs"},
    "implementation_state_by_requirement": {"type": "object"},
    "blocker_refs": {"$ref": "#/$defs/refs"},
    "operator_action_refs": {"$ref": "#/$defs/refs"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "constitution-ready"}}}, "then": {"properties": {"target_stage": {"const": "app-research"}}, "required": ["app_repo_or_path", "constitution_ref", "constraint_refs", "research_unknowns", "wave_creation_basis"]}},
    {"if": {"properties": {"status": {"const": "research-ready"}}}, "then": {"properties": {"target_stage": {"const": "app-specify"}}, "required": ["constitution_ref", "research_refs", "question_refs", "source_refs"]}},
    {"if": {"properties": {"status": {"const": "spec-ready"}}}, "then": {"properties": {"target_stage": {"const": "app-functional-graph"}}, "required": ["constitution_ref", "research_refs", "specification_refs", "required_behavior_refs", "dependency_coverage_refs", "state_coverage_refs", "api_coverage_refs", "data_coverage_refs", "integration_coverage_refs", "error_coverage_refs"]}},
    {"if": {"properties": {"status": {"const": "graph-ready"}}}, "then": {"properties": {"target_stage": {"const": "app-plan"}}, "required": ["functional_map_ref", "functionality_refs", "graph_entity_refs", "coverage_refs", "replacement_refs"]}},
    {"if": {"properties": {"status": {"enum": ["plan-ready", "ready"]}}}, "then": {"properties": {"target_stage": {"const": "app-dev"}}, "required": ["task_records"]}},
    {"if": {"properties": {"status": {"const": "waiting"}}}, "then": {"properties": {"target_stage": {"const": "app-plan"}}, "required": ["source_handoff_ref", "blocked_task_refs", "dependency_state_evidence_refs"]}},
    {"if": {"properties": {"status": {"const": "no-work"}}}, "then": {"properties": {"target_stage": {"const": "app-analyze"}}, "required": ["plan_refs"]}},
    {"if": {"properties": {"status": {"const": "implemented"}}}, "then": {"properties": {"target_stage": {"const": "app-analyze"}}, "required": ["repo_ref", "completed_task_refs", "failed_task_refs", "task_result_refs", "review_result_refs", "commit_range_refs", "remediation_task_refs"]}},
    {"if": {"properties": {"status": {"const": "pass"}}}, "then": {"properties": {"target_stage": {"const": "none"}}, "required": ["analysis_refs"]}},
    {"if": {"properties": {"status": {"const": "needs-research"}}}, "then": {"properties": {"target_stage": {"const": "app-research"}}, "required": ["question_refs", "source_refs", "research_unknowns"]}},
    {"if": {"properties": {"status": {"const": "needs-spec"}}}, "then": {"properties": {"target_stage": {"const": "app-specify"}}, "required": ["source_handoff_ref", "question_refs"]}},
    {"if": {"properties": {"status": {"const": "needs-graph"}}}, "then": {"properties": {"target_stage": {"const": "app-functional-graph"}}, "required": ["source_handoff_ref", "functional_map_ref", "affected_graph_refs"]}},
    {"if": {"properties": {"status": {"const": "needs-plan"}}}, "then": {"properties": {"target_stage": {"const": "app-plan"}}, "required": ["source_handoff_ref", "ledger_coverage_refs", "implementation_state_by_requirement"]}},
    {"if": {"properties": {"status": {"const": "blocked"}}}, "then": {"properties": {"target_stage": {"const": "none"}}, "required": ["blocker_refs", "operator_action_refs"]}}
  ],
  "$defs": {
    "refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "repo_ref", "batch_id", "wave_id", "queue_sequence", "task_kind", "source_review_refs", "requirement_refs", "functionality_refs", "graph_entity_refs", "target_paths", "allowed_files", "owner_role", "lane", "depends_on", "decision_state", "status", "definition_of_done", "proof_requirement", "ledger_update_contract", "artifact_refs", "automation_evidence_refs", "result_refs"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "repo_ref": {"type": "string", "minLength": 1},
        "batch_id": {"type": "string", "minLength": 1},
        "wave_id": {"type": "string", "minLength": 1},
        "queue_sequence": {"type": "integer", "minimum": 1},
        "task_kind": {"enum": ["implementation", "remediation"]},
        "source_review_refs": {"$ref": "#/$defs/refs"},
        "requirement_refs": {"$ref": "#/$defs/refs"},
        "functionality_refs": {"$ref": "#/$defs/refs"},
        "graph_entity_refs": {"$ref": "#/$defs/refs"},
        "target_paths": {"$ref": "#/$defs/refs"},
        "allowed_files": {"$ref": "#/$defs/refs"},
        "owner_role": {"type": "string", "minLength": 1},
        "lane": {"type": "string", "minLength": 1},
        "depends_on": {"$ref": "#/$defs/refs"},
        "decision_state": {"enum": ["open", "closed"]},
        "status": {"enum": ["planned", "blocked_by_decision", "blocked_by_dependency", "ready", "in_progress", "done", "failed"]},
        "definition_of_done": {"type": "string", "minLength": 1},
        "proof_requirement": {"type": "string", "minLength": 1},
        "ledger_update_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_transitions", "mutable_fields"],
          "properties": {
            "allowed_transitions": {"$ref": "#/$defs/refs"},
            "mutable_fields": {"$ref": "#/$defs/refs"}
          }
        },
        "artifact_refs": {"$ref": "#/$defs/refs"},
        "automation_evidence_refs": {"$ref": "#/$defs/refs"},
        "result_refs": {"$ref": "#/$defs/refs"}
      }
    }
  }
}
