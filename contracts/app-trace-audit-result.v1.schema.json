{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-trace-audit-result.v1.schema.json",
  "title": "app-trace-audit-result.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "profile",
    "complete",
    "truncated",
    "build_ref",
    "source_snapshot_digest",
    "findings",
    "route",
    "next_cursor"
  ],
  "properties": {
    "schema": {
      "const": "app-trace-audit-result.v1"
    },
    "profile": {
      "enum": [
        "semantic",
        "planning",
        "convergence"
      ]
    },
    "complete": {
      "type": "boolean"
    },
    "truncated": {
      "type": "boolean"
    },
    "build_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_snapshot_digest": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array"
    },
    "route": {
      "type": "string",
      "minLength": 1
    },
    "next_cursor": {
      "type": ["string", "null"]
    }
  }
}
