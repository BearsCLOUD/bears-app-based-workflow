{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-traceability-index.v2.schema.json",
  "title": "App traceability index v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "app_id", "revision", "source_snapshot_digest", "generated_from", "roots", "evidence_sinks", "entities", "edges", "aliases", "replacements", "findings"],
  "properties": {
    "schema": {"const": "app-traceability-index.v2"},
    "app_id": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 1},
    "source_snapshot_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "generated_from": {"$ref": "#/$defs/locators"},
    "roots": {"$ref": "#/$defs/refs"},
    "evidence_sinks": {"$ref": "#/$defs/refs"},
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "scope", "source"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["spec", "decision", "requirement", "functionality", "behavior", "state", "api", "data", "integration", "error", "task", "code", "test", "evidence", "commit", "review"]},
          "scope": {"type": "string", "minLength": 1},
          "source": {"$ref": "#/$defs/locator"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "from_ref", "to_ref", "source_refs", "condition_refs", "active"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "from_ref": {"type": "string", "minLength": 1},
          "to_ref": {"type": "string", "minLength": 1},
          "source_refs": {"$ref": "#/$defs/refs"},
          "condition_refs": {"$ref": "#/$defs/refs"},
          "active": {"type": "boolean"}
        }
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["old_ref", "current_ref"],
        "properties": {
          "old_ref": {"type": "string", "minLength": 1},
          "current_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "replacements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["old_ref", "new_refs", "source_refs"],
        "properties": {
          "old_ref": {"type": "string", "minLength": 1},
          "new_refs": {"$ref": "#/$defs/refs"},
          "source_refs": {"$ref": "#/$defs/refs"}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "source_refs", "status"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["missing-source", "conceptual-conflict", "semantic-map-gap", "task-coverage-gap", "operator-stop"]},
          "source_refs": {"$ref": "#/$defs/refs"},
          "status": {"enum": ["open", "resolved"]}
        }
      }
    }
  },
  "$defs": {
    "refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "anchor", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "anchor": {"type": "string"},
        "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "locators": {"type": "array", "items": {"$ref": "#/$defs/locator"}}
  }
}
