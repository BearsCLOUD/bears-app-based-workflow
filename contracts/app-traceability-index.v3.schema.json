{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-traceability-index.v3.schema.json",
  "title": "app-traceability-index.v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "app_id",
    "build_ref",
    "source_snapshot_digest",
    "generated_from",
    "roots",
    "evidence_sinks",
    "entities",
    "edges",
    "replacements",
    "findings"
  ],
  "properties": {
    "schema": {
      "const": "app-traceability-index.v3"
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "build_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_snapshot_digest": {
      "type": "string",
      "minLength": 1
    },
    "generated_from": {
      "type": "array",
      "maxItems": 2048
    },
    "roots": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence_sinks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "entities": {
      "type": "array",
      "maxItems": 25000
    },
    "edges": {
      "type": "array",
      "maxItems": 100000
    },
    "replacements": {
      "type": "array"
    },
    "findings": {
      "type": "array"
    }
  }
}
