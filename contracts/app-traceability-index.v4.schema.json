{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.cloud/contracts/app-traceability-index.v4.schema.json",
  "title": "app-traceability-index.v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "app_id", "build_ref", "source_snapshot_digest", "generated_from", "roots", "evidence_sinks", "entities", "edges", "replacements", "findings"],
  "properties": {
    "schema": {"const": "app-traceability-index.v4"},
    "app_id": {"type": "string", "minLength": 1},
    "build_ref": {"type": "string", "minLength": 1},
    "source_snapshot_digest": {"type": "string", "minLength": 1},
    "generated_from": {"type": "array", "items": {"type": "object"}},
    "roots": {"$ref": "#/$defs/refs"},
    "evidence_sinks": {"$ref": "#/$defs/refs"},
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "scope", "active", "source"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["spec", "decision", "requirement", "functionality", "behavior", "dependency", "state", "api", "data", "integration", "error", "task", "code", "configuration", "document", "evidence"]},
          "scope": {"type": "string", "minLength": 1},
          "active": {"type": "boolean"},
          "source": {"type": "object"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "kind", "from_ref", "to_ref", "source_refs", "condition_refs", "active"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"enum": ["depends_on", "constrains", "defines", "decomposes_to", "implemented_by", "evidenced_by", "replaces", "remediates"]},
          "from_ref": {"type": "string", "minLength": 1},
          "to_ref": {"type": "string", "minLength": 1},
          "source_refs": {"$ref": "#/$defs/refs"},
          "condition_refs": {"$ref": "#/$defs/refs"},
          "active": {"type": "boolean"}
        }
      }
    },
    "replacements": {"type": "array"},
    "findings": {"type": "array"}
  },
  "$defs": {
    "refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
