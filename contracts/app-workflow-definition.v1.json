{
  "schema": "app-workflow-definition.v1",
  "handoff_schema": "contracts/app-stage-handoff.v2.schema.json",
  "context_index_result_schema": "contracts/app-context-index-result.v1.schema.json",
  "traceability_index_schema": "contracts/app-traceability-index.v2.schema.json",
  "process_index_schema": "contracts/app-process-index.v1.schema.json",
  "entry_gate": {
    "skill": "app-context-index",
    "run_at": [
      "run-start",
      "wave-start",
      "source-digest-change",
      "needs-index"
    ],
    "unchanged_action": "reuse-current-index"
  },
  "stages": [
    {"name": "app-constitution", "owns": ["docs/app-constitution.md"]},
    {"name": "app-research", "owns": ["waves/index.md", "waves/*/research.md"]},
    {"name": "app-specify", "owns": ["waves/*/spec.md"]},
    {"name": "app-functional-graph", "owns": ["docs/app-functional-map.v2.json"]},
    {"name": "app-context-index", "owns": ["docs/app-traceability-index.v2.json", "docs/app-process-index.v1.json"]},
    {"name": "app-plan", "owns": ["waves/*/plan.md", "docs/app-task-ledger.v1.json"]},
    {"name": "app-dev", "owns": ["task-authorized-targets", "ledger-execution-fields"]},
    {"name": "app-analyze", "owns": ["waves/*/analysis.md"]}
  ],
  "routes": {
    "constitution-ready": "app-research",
    "needs-research": "app-research",
    "research-ready": "app-specify",
    "needs-spec": "app-specify",
    "spec-ready": "app-functional-graph",
    "needs-graph": "app-functional-graph",
    "graph-ready": "app-plan",
    "waiting": "app-plan",
    "needs-plan": "app-plan",
    "no-work": "app-analyze",
    "implemented": "app-analyze",
    "plan-ready": "app-dev",
    "ready": "app-dev",
    "pass": "none",
    "blocked": "none"
  },
  "finding_routes": {
    "missing-source": "needs-research",
    "conceptual-conflict": "needs-spec",
    "semantic-map-gap": "needs-graph",
    "task-coverage-gap": "needs-plan",
    "operator-stop": "blocked"
  },
  "app_dev_process": {
    "states": ["ready", "in_progress", "done", "failed"],
    "transitions": [
      ["ready", "in_progress"],
      ["in_progress", "done"],
      ["in_progress", "failed"]
    ],
    "required_events": [
      "delegation-gate",
      "task-result",
      "immutable-review",
      "remediation-anchor",
      "remediation-task",
      "rereview",
      "repo-handoff"
    ]
  },
  "graph": {
    "roots": ["spec", "decision", "requirement"],
    "evidence_sinks": ["evidence"],
    "entity_kinds": [
      "spec",
      "decision",
      "requirement",
      "functionality",
      "behavior",
      "state",
      "api",
      "data",
      "integration",
      "error",
      "task",
      "code",
      "test",
      "evidence",
      "commit",
      "review"
    ],
    "edge_types": {
      "depends_on": {"family": "dependency", "direction": "dependent-to-prerequisite", "from_kinds": ["functionality", "behavior", "state", "api", "data", "integration", "error", "task", "code", "test"], "to_kinds": ["functionality", "behavior", "state", "api", "data", "integration", "error", "task", "code", "test"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "constrains": {"family": "dependency", "direction": "dependent-to-prerequisite", "from_kinds": ["decision", "requirement", "functionality", "task"], "to_kinds": ["decision", "requirement", "functionality", "task"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "defines": {"family": "trace", "direction": "source-to-target", "from_kinds": ["spec", "decision", "requirement"], "to_kinds": ["decision", "requirement", "functionality", "behavior", "state", "api", "data", "integration", "error"], "transitive": false, "impact": true, "cycle": "forbidden"},
      "decomposes_to": {"family": "trace", "direction": "source-to-target", "from_kinds": ["requirement", "functionality"], "to_kinds": ["functionality", "task"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "implemented_by": {"family": "trace", "direction": "source-to-target", "from_kinds": ["requirement", "functionality", "behavior", "task"], "to_kinds": ["code"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "verified_by": {"family": "trace", "direction": "source-to-target", "from_kinds": ["behavior", "api", "code"], "to_kinds": ["test"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "evidenced_by": {"family": "trace", "direction": "source-to-target", "from_kinds": ["code", "test", "commit", "review"], "to_kinds": ["evidence"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "replaces": {"family": "replacement", "direction": "old-to-current", "from_kinds": ["spec", "decision", "requirement", "functionality", "behavior", "state", "api", "data", "integration", "error", "task", "code", "test", "evidence", "commit", "review"], "to_kinds": ["spec", "decision", "requirement", "functionality", "behavior", "state", "api", "data", "integration", "error", "task", "code", "test", "evidence", "commit", "review"], "transitive": true, "impact": true, "cycle": "forbidden"},
      "transitions_to": {"family": "process", "direction": "source-to-target", "from_kinds": [], "to_kinds": [], "transitive": false, "impact": false, "cycle": "controlled"},
      "remediates": {"family": "process", "direction": "finding-to-task", "from_kinds": ["review"], "to_kinds": ["task"], "transitive": false, "impact": true, "cycle": "controlled"}
    }
  }
}
