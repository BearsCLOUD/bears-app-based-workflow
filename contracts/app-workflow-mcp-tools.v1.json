{
  "schema": "app-workflow-mcp-tools.v1",
  "runtime": {
    "language": "python3-stdlib",
    "transport": "stdio",
    "request_limit_bytes": 1048576,
    "response_limit_bytes": 524288,
    "default_page_size": 50,
    "maximum_page_size": 200,
    "default_depth": 4,
    "maximum_depth": 16
  },
  "servers": {
    "app-workflow": {
      "access": "read-only",
      "tools": [
        "project_list",
        "project_status",
        "graph_read",
        "graph_search",
        "graph_open",
        "dependency_slice",
        "impact_analysis",
        "graph_trace",
        "graph_diagnostics",
        "topological_plan",
        "workflow_state",
        "workflow_validate"
      ]
    },
    "app-workflow-maintainer": {
      "access": "mutation",
      "tools": [
        "project_register",
        "project_rebind",
        "project_unregister",
        "project_migrate_json",
        "wave_initialize",
        "phase_record",
        "graph_apply",
        "plan_replace",
        "task_record_change",
        "review_record",
        "correction_record",
        "analysis_record",
        "workflow_mark_audited"
      ]
    }
  },
  "mutation_preconditions": [
    "request_id",
    "expected_revision",
    "expected_logical_digest"
  ],
  "wave_mutation_precondition": "owner_session_ref",
  "relation_types": [
    "depends_on",
    "constrains",
    "defines",
    "decomposes_to",
    "implemented_by",
    "evidenced_by",
    "replaces",
    "remediates"
  ],
  "lifecycle": {
    "record_statuses": ["active", "retired"],
    "physical_delete_exposed": false,
    "replacement_field": "replacement_ref",
    "source_refs_required_for": ["entity", "observation", "relation"]
  },
  "transactions": {
    "graph_apply": "whole-batch",
    "plan_replace": "whole-batch",
    "journal_mode": "DELETE",
    "synchronous": "FULL",
    "busy_timeout_seconds": 5,
    "wal_allowed": false
  },
  "audit": {
    "validation_writes": false,
    "digest_basis": "canonically-sorted-logical-database-rows-and-exact-file-sha256",
    "attestation": "same-revision-transaction",
    "later_mutation": "stales-active-attestation"
  },
  "migration": {
    "accepted": ["app-functional-map.v5", "workflow-state.v1"],
    "requires_empty_database": true,
    "requires_source_sha256": true,
    "requires_parity_check": true,
    "requires_reaudit": true,
    "v4_behavior": "open-new-wave-and-retain-json-as-evidence"
  },
  "omitted_upstream_surfaces": [
    "memory://knowledge-graph",
    "live-subscriptions",
    "jsonl-rewrite-storage"
  ]
}
