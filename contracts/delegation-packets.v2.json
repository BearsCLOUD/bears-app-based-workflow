{
  "schema": "plugin-delegation-contract.v2",
  "active_schemas": {
    "entry": "delegation-entry.v1",
    "authority": "assignment-authority.v1",
    "transport": "typed-agent-dispatch.v1",
    "dispatch": "dispatch-packet.v3",
    "result": "result-packet.v2",
    "app_task": "app-task-dispatch.v2",
    "repo_lane": "repo-lane-dispatch.v1"
  },
  "delegation_entry": {
    "context_states": [
      "clean",
      "compact-only",
      "overlapping-raw-direct-access"
    ],
    "outcomes": {
      "missing_or_invalid_delegation_gate": "DIRECT_REQUIRED",
      "overlapping_raw_direct_access": "FRESH_TASK_REQUIRED",
      "profile_binding_or_profile_unavailable": "DELEGATION_BLOCKED",
      "invalid_packet_or_identity": "PACKET_REJECTED"
    }
  },
  "assignment_authority_required_fields": [
    "schema",
    "assignment_authority_ref",
    "delegation_authority_ref",
    "workstream_id",
    "repo_ref",
    "trust_boundary",
    "authorized_role",
    "authorized_agent_level",
    "authorized_role_kind"
  ],
  "typed_dispatch": {
    "required_profile_binding": {
      "packet_role": "<exact dispatch role>",
      "packet_identity_fields": [
        "role",
        "agent_level",
        "role_kind"
      ],
      "profile_instruction_ref": "<installed config_file for exact dispatch role>"
    },
    "transport_agent_type": {
      "required": false,
      "when_available": "<exact dispatch role>"
    },
    "task_name_authoritative": false,
    "fork_turns": "none",
    "conversation_inheritance": false,
    "parent_execution_fallback": false,
    "allowed_l3_caller_levels": [
      "L2",
      "solo-l2"
    ],
    "allowed_l3_caller_role_kinds": [
      "repo-orchestrator"
    ]
  },
  "repo_lane_dispatch_required_fields": [
    "schema",
    "delegation_authority_ref",
    "workstream_id",
    "repo_ref",
    "repo_cwd",
    "trust_boundary",
    "caller_role",
    "caller_role_kind",
    "role",
    "agent_level",
    "role_kind",
    "orchestrator_session_id",
    "session_action",
    "current_stage",
    "build_ref",
    "source_snapshot_digest",
    "journal_digest",
    "dependency_refs",
    "capacity_state",
    "instruction_refs",
    "stage_payload"
  ],
  "repo_l2_lifecycle": {
    "schema": "repo-lane-dispatch.v1",
    "caller_role": "workflow-orchestrator",
    "callee_role": "domain-lane-orchestrator",
    "caller_role_kind": "workflow-orchestrator",
    "callee_role_kind": "repo-orchestrator",
    "session_field": "orchestrator_session_id",
    "dispatch_actions": [
      "start",
      "continue"
    ],
    "result_actions": [
      "continue",
      "close"
    ],
    "start_transport": "collaboration.spawn_agent",
    "continue_transport": "collaboration.followup_task",
    "fork_turns": "none",
    "one_persistent_session_per_repo_ref": true,
    "l2_owns_all_delegated_app_stages": true,
    "l1_may_select_routes": false,
    "l1_may_write_journal": false,
    "l1_may_dispatch_l3": false,
    "l2_may_select_routes": true,
    "l2_may_write_journal": true,
    "l2_may_dispatch_l3": true
  },
  "dispatch_required_fields": [
    "schema",
    "delegation_authority_ref",
    "assignment_authority_ref",
    "task_id",
    "workstream_id",
    "assignment_id",
    "repo_ref",
    "trust_boundary",
    "stage",
    "caller_level",
    "orchestrator_session_id",
    "caller_role_kind",
    "caller_role",
    "role",
    "agent_level",
    "role_kind",
    "session_action",
    "worker_session_id",
    "critic_session_id",
    "selection_basis",
    "capability_boundary",
    "cwd",
    "target_paths",
    "instruction_refs",
    "inputs",
    "stage_payload",
    "allowed_actions",
    "forbidden_actions",
    "risk",
    "completion_criteria",
    "return_schema",
    "evidence_refs"
  ],
  "result_required_fields": [
    "schema",
    "delegation_authority_ref",
    "assignment_authority_ref",
    "task_id",
    "workstream_id",
    "assignment_id",
    "repo_ref",
    "trust_boundary",
    "orchestrator_session_id",
    "caller_role_kind",
    "caller_role",
    "role",
    "agent_level",
    "role_kind",
    "session_action",
    "session_state",
    "worker_session_id",
    "critic_session_id",
    "status",
    "consumed_input_refs",
    "consumed_authority_refs",
    "facts",
    "files_read",
    "files_changed",
    "commands_run",
    "git_state",
    "evidence",
    "risks",
    "next_action"
  ],
  "persistent_l3_lifecycle": {
    "role_kinds": [
      "mutation-worker",
      "primary-critic"
    ],
    "dispatch_actions": [
      "start",
      "continue"
    ],
    "result_actions": [
      "continue",
      "close"
    ],
    "worker_session_field": "worker_session_id",
    "critic_session_field": "critic_session_id",
    "continue_transport": "collaboration.followup_task",
    "closed_session_reuse": false
  },
  "helper_lifecycle": {
    "role_kind": "helper",
    "dispatch_action": "start",
    "result_action": "close",
    "worker_session_id": "none",
    "critic_session_id": "none",
    "reusable": false
  },
  "app_task_required_fields": [
    "schema",
    "task_record",
    "repo_ref",
    "repo_cwd",
    "batch_id",
    "wave_id",
    "wave_session_id",
    "queue_sequence",
    "wave_dispatch_action",
    "previous_task_result_ref"
  ],
  "role_metadata": {
    "source": "agents/*.toml developer_instructions Role identity line",
    "allowed_role_kinds": [
      "workflow-orchestrator",
      "repo-orchestrator",
      "mutation-worker",
      "primary-critic",
      "helper"
    ],
    "fixed_role_count": false,
    "role_kind_authority": true,
    "level_authority": false,
    "specialization_authority": false
  },
  "authority_by_role_kind": {
    "workflow-orchestrator": {
      "authority": "Coordinate persistent repository lanes through native collaboration without app-stage, route, journal, or L3 authority.",
      "may_mutate_assigned_targets": false,
      "may_coordinate_repo_lanes": true,
      "may_own_app_stages": false,
      "may_select_routes": false,
      "may_write_journal": false,
      "may_dispatch_l3": false,
      "may_classify_repo_blockers": false,
      "persistent": true
    },
    "repo-orchestrator": {
      "authority": "Own one persistent repository app-stage lifecycle with route, journal, and bounded L3 dispatch authority.",
      "may_mutate_assigned_targets": false,
      "may_coordinate_repo_lanes": false,
      "may_own_app_stages": true,
      "may_select_routes": true,
      "may_write_journal": true,
      "may_dispatch_l3": true,
      "may_classify_repo_blockers": true,
      "persistent": true
    },
    "mutation-worker": {
      "authority": "Mutate only assigned targets and return one bounded committed result without route or journal authority.",
      "may_mutate_assigned_targets": true,
      "may_coordinate_repo_lanes": false,
      "may_own_app_stages": false,
      "may_select_routes": false,
      "may_write_journal": false,
      "may_dispatch_l3": false,
      "may_classify_repo_blockers": false,
      "persistent": true
    },
    "primary-critic": {
      "authority": "Judge one immutable assigned scope and return findings without mutation, route, or journal authority.",
      "may_mutate_assigned_targets": false,
      "may_coordinate_repo_lanes": false,
      "may_own_app_stages": false,
      "may_select_routes": false,
      "may_write_journal": false,
      "may_dispatch_l3": false,
      "may_classify_repo_blockers": false,
      "persistent": true
    },
    "helper": {
      "authority": "Return one bounded read-only fact packet without mutation, route, journal, or continuation authority.",
      "may_mutate_assigned_targets": false,
      "may_coordinate_repo_lanes": false,
      "may_own_app_stages": false,
      "may_select_routes": false,
      "may_write_journal": false,
      "may_dispatch_l3": false,
      "may_classify_repo_blockers": false,
      "persistent": false
    }
  },
  "result_statuses": [
    "done",
    "partial",
    "blocked"
  ],
  "sanitized_reference_only": true
}
