class InstallError(Exception):
    """A failure whose code is safe to expose."""

    def __init__(self, code: str):
        super().__init__(code)
        self.code = code


def safe_component(value: str) -> str:
    clean = re.sub(r"[^A-Za-z0-9._+-]+", "_", value)
    return clean[:96] or "unknown"


def parse_cli() -> argparse.Namespace:
    argv = sys.argv[1:]
    operation = "install"
    if argv and argv[0] in {"install", "uninstall"}:
        operation = argv.pop(0)
    parser = argparse.ArgumentParser(
        prog="./install",
        description="Register or unregister plugin-owned Codex agent profiles.",
    )
    parser.add_argument("--codex-home", type=Path)
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args(argv)
    args.operation = operation
    return args


def plugin_metadata(plugin_root: Path) -> tuple[str, list[tuple[str, Path]]]:
    manifest = plugin_root / ".codex-plugin" / "plugin.json"
    try:
        manifest_data = json.loads(manifest.read_text(encoding="utf-8"))
        version = manifest_data["version"]
    except (OSError, UnicodeError, json.JSONDecodeError, KeyError, TypeError):
        raise InstallError("plugin-manifest-invalid") from None
    if not isinstance(version, str) or not version:
        raise InstallError("plugin-version-invalid")

    agents_dir = plugin_root / "agents"
    try:
        paths = sorted(agents_dir.glob("*.toml"))
    except OSError:
        raise InstallError("profile-catalog-unreadable") from None
    if len(paths) != ROLE_COUNT:
        raise InstallError("profile-count-invalid")

    profiles: list[tuple[str, Path]] = []
    required = {
        "name",
        "description",
        "model",
        "model_reasoning_effort",
        "sandbox_mode",
        "developer_instructions",
    }
    seen: set[str] = set()
    for path in paths:
        try:
            if path.is_symlink() or not path.is_file():
                raise InstallError("profile-path-invalid")
            with path.open("rb") as stream:
                data = tomllib.load(stream)
        except InstallError:
            raise
        except (OSError, tomllib.TOMLDecodeError):
            raise InstallError("profile-toml-invalid") from None
        if not required.issubset(data):
            raise InstallError("profile-fields-missing")
        name = data.get("name")
        if not isinstance(name, str) or name != path.stem or name in seen:
            raise InstallError("profile-name-invalid")
        seen.add(name)
        profiles.append((name, path.resolve()))
    return version, profiles


def build_block(version: str, profiles: list[tuple[str, Path]]) -> bytes:
    lines = [BEGIN_MARKER.decode(), f"# plugin_version = {json.dumps(version)}"]
    for name, path in profiles:
        lines.extend(
            (
                f"[agents.{json.dumps(name)}]",
                f"config_file = {json.dumps(str(path))}",
            )
        )
    lines.append(END_MARKER.decode())
    return ("\n".join(lines) + "\n").encode("utf-8")


def find_managed_block(data: bytes) -> tuple[int, int, bytes] | None:
    begin_count = data.count(BEGIN_MARKER)
    end_count = data.count(END_MARKER)
    if begin_count == 0 and end_count == 0:
        return None
    if begin_count != 1 or end_count != 1:
        raise InstallError("managed-block-conflict")
    start = data.find(BEGIN_MARKER)
    end_start = data.find(END_MARKER)
    if end_start < start:
        raise InstallError("managed-block-conflict")
    end = end_start + len(END_MARKER)
    if data[end : end + 2] == b"\r\n":
        end += 2
    elif data[end : end + 1] == b"\n":
        end += 1
    return start, end, data[start:end]


def digest_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def stat_identity(value: os.stat_result) -> dict[str, int]:
    return {
        "device": value.st_dev,
        "inode": value.st_ino,
        "mode": stat.S_IMODE(value.st_mode),
        "uid": value.st_uid,
        "gid": value.st_gid,
        "links": value.st_nlink,
        "size": value.st_size,
        "mtime_ns": value.st_mtime_ns,
        "ctime_ns": value.st_ctime_ns,
    }


def stable_stat_identity(value: os.stat_result) -> dict[str, int]:
    identity = stat_identity(value)
    del identity["ctime_ns"]
    return identity


def fsync_directory(path: Path, code: str) -> None:
    flags = os.O_RDONLY | os.O_DIRECTORY
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        directory_fd = os.open(path, flags)
        try:
            os.fsync(directory_fd)
        finally:
            os.close(directory_fd)
    except OSError:
        raise InstallError(code) from None


def open_directory_fd(path: Path, code: str) -> int:
    flags = os.O_RDONLY | os.O_DIRECTORY
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        directory_fd = os.open(path, flags)
        if not stat.S_ISDIR(os.fstat(directory_fd).st_mode):
            raise InstallError(code)
        return directory_fd
    except InstallError:
        if "directory_fd" in locals():
            os.close(directory_fd)
        raise
    except OSError:
        raise InstallError(code) from None


def open_codex_home_fd(path: Path, *, create: bool) -> int | None:
    """Bind an absolute CODEX_HOME by component-wise no-follow traversal."""
    if not path.is_absolute() or ".." in path.parts:
        raise InstallError("codex-home-invalid")
    flags = os.O_RDONLY | os.O_DIRECTORY
    if not hasattr(os, "O_NOFOLLOW"):
        raise InstallError("secure-path-unsupported")
    flags |= os.O_NOFOLLOW
    try:
        current_fd = os.open("/", flags)
    except OSError:
        raise InstallError("codex-home-invalid") from None
    components = [part for part in path.parts if part not in {"/", ""}]
    try:
        for index, component in enumerate(components):
            next_fd = -1
            try:
                next_fd = os.open(component, flags, dir_fd=current_fd)
            except FileNotFoundError:
                if not create:
                    os.close(current_fd)
                    return None
                try:
                    os.mkdir(component, mode=0o700, dir_fd=current_fd)
                    fsync_directory_fd(current_fd, "codex-home-create-failed")
                    next_fd = os.open(component, flags, dir_fd=current_fd)
                except (FileExistsError, OSError):
                    raise InstallError("codex-home-create-failed") from None
            except OSError:
                raise InstallError("codex-home-invalid") from None
            component_stat = os.fstat(next_fd)
            final = index == len(components) - 1
            unsafe_writable = bool(
                stat.S_IMODE(component_stat.st_mode) & 0o022
                and not stat.S_IMODE(component_stat.st_mode) & stat.S_ISVTX
            )
            if (
                not stat.S_ISDIR(component_stat.st_mode)
                or component_stat.st_uid not in {0, os.geteuid()}
                or unsafe_writable
                or (final and component_stat.st_uid != os.geteuid())
            ):
                os.close(next_fd)
                raise InstallError("codex-home-invalid")
            os.close(current_fd)
            current_fd = next_fd
        if not components:
            root_stat = os.fstat(current_fd)
            if root_stat.st_uid != os.geteuid():
                raise InstallError("codex-home-invalid")
        return current_fd
    except InstallError:
        if current_fd >= 0:
            os.close(current_fd)
        raise


def assert_codex_home_binding(
    codex_home_fd: int,
    path: Path,
) -> None:
    """Fail if the pathname no longer resolves to the bound home inode."""
    rebound_fd = open_codex_home_fd(path, create=False)
    if rebound_fd is None:
        raise InstallError("codex-home-rebound")
    try:
        bound_stat = os.fstat(codex_home_fd)
        rebound_stat = os.fstat(rebound_fd)
        if (
            bound_stat.st_dev != rebound_stat.st_dev
            or bound_stat.st_ino != rebound_stat.st_ino
        ):
            raise InstallError("codex-home-rebound")
    except OSError:
        raise InstallError("codex-home-rebound") from None
    finally:
        os.close(rebound_fd)


def bound_home_path(codex_home_fd: int) -> Path:
    """Return a process-local path pinned to an already authenticated fd."""
    proc_path = Path("/proc/self/fd") / str(codex_home_fd)
    try:
        proc_stat = proc_path.stat()
        bound_stat = os.fstat(codex_home_fd)
    except OSError:
        raise InstallError("secure-path-unsupported") from None
    if proc_stat.st_dev != bound_stat.st_dev or proc_stat.st_ino != bound_stat.st_ino:
        raise InstallError("secure-path-unsupported")
    return proc_path


def current_codex_home_fd() -> int:
    if _BOUND_CODEX_HOME_FD < 0:
        raise InstallError("codex-home-unbound")
    return _BOUND_CODEX_HOME_FD


def verify_current_codex_home() -> int:
    codex_home_fd = current_codex_home_fd()
    if _BOUND_CODEX_HOME_PATH is None:
        raise InstallError("codex-home-unbound")
    assert_codex_home_binding(codex_home_fd, _BOUND_CODEX_HOME_PATH)
    return codex_home_fd


def fsync_directory_fd(directory_fd: int, code: str) -> None:
    try:
        os.fsync(directory_fd)
    except OSError:
        raise InstallError(code) from None


def read_regular_snapshot_at(
    directory_fd: int,
    name: str,
    *,
    invalid_code: str,
    unreadable_code: str,
    oversized_code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> tuple[bytes, os.stat_result | None]:
    if not name or name in {".", ".."} or "/" in name:
        raise InstallError(invalid_code)
    flags = os.O_RDONLY
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        fd = os.open(name, flags, dir_fd=directory_fd)
    except FileNotFoundError:
        return b"", None
    except OSError as error:
        if error.errno in {errno.ELOOP, errno.EISDIR, errno.ENOTDIR}:
            raise InstallError(invalid_code) from None
        raise InstallError(unreadable_code) from None
    try:
        before = os.fstat(fd)
        if not stat.S_ISREG(before.st_mode):
            raise InstallError(invalid_code)
        with os.fdopen(fd, "rb", closefd=True) as stream:
            fd = -1
            data = stream.read(max_bytes + 1)
            after = os.fstat(stream.fileno())
        if len(data) > max_bytes:
            raise InstallError(oversized_code)
        if stat_identity(before) != stat_identity(after):
            raise InstallError("snapshot-raced")
        return data, after
    except InstallError:
        raise
    except OSError:
        raise InstallError(unreadable_code) from None
    finally:
        if fd >= 0:
            os.close(fd)


def read_regular_snapshot(
    path: Path,
    *,
    invalid_code: str,
    unreadable_code: str,
    oversized_code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> tuple[bytes, os.stat_result | None]:
    flags = os.O_RDONLY
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        fd = os.open(path, flags)
    except FileNotFoundError:
        return b"", None
    except OSError as error:
        if error.errno in {errno.ELOOP, errno.EISDIR, errno.ENOTDIR} or path.is_symlink():
            raise InstallError(invalid_code) from None
        raise InstallError(unreadable_code) from None
    try:
        before = os.fstat(fd)
        if not stat.S_ISREG(before.st_mode):
            raise InstallError(invalid_code)
        with os.fdopen(fd, "rb", closefd=True) as stream:
            fd = -1
            data = stream.read(max_bytes + 1)
            after = os.fstat(stream.fileno())
        if len(data) > max_bytes:
            raise InstallError(oversized_code)
        if stat_identity(before) != stat_identity(after):
            raise InstallError("snapshot-raced")
        return data, after
    except InstallError:
        raise
    except OSError:
        raise InstallError(unreadable_code) from None
    finally:
        if fd >= 0:
            os.close(fd)


def snapshot_matches(
    current_data: bytes,
    current_stat: os.stat_result | None,
    expected_data: bytes,
    expected_stat: os.stat_result | None,
) -> bool:
    if expected_stat is None:
        return current_stat is None and expected_data == b"" and current_data == b""
    return (
        current_stat is not None
        and current_data == expected_data
        and stat_identity(current_stat) == stat_identity(expected_stat)
    )


def stable_snapshot_matches(
    current_data: bytes,
    current_stat: os.stat_result | None,
    expected_data: bytes,
    expected_stat: os.stat_result | None,
) -> bool:
    if expected_stat is None:
        return current_stat is None and expected_data == b"" and current_data == b""
    return (
        current_stat is not None
        and current_data == expected_data
        and stable_stat_identity(current_stat) == stable_stat_identity(expected_stat)
    )


def assert_preimage(
    path: Path,
    expected_data: bytes,
    expected_stat: os.stat_result | None,
    *,
    code: str,
    invalid_code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> None:
    current_data, current_stat = read_regular_snapshot(
        path,
        invalid_code=invalid_code,
        unreadable_code=code,
        oversized_code=code,
        max_bytes=max_bytes,
    )
    if not snapshot_matches(current_data, current_stat, expected_data, expected_stat):
        raise InstallError(code)


def assert_preimage_at(
    directory_fd: int,
    name: str,
    expected_data: bytes,
    expected_stat: os.stat_result | None,
    *,
    code: str,
    invalid_code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> None:
    current_data, current_stat = read_regular_snapshot_at(
        directory_fd,
        name,
        invalid_code=invalid_code,
        unreadable_code=code,
        oversized_code=code,
        max_bytes=max_bytes,
    )
    if not snapshot_matches(current_data, current_stat, expected_data, expected_stat):
        raise InstallError(code)


def profile_ownership(profiles: list[tuple[str, Path]]) -> list[dict[str, str]]:
    ownership: list[dict[str, str]] = []
    for name, path in profiles:
        if path.is_symlink() or not path.is_file():
            raise InstallError("profile-path-invalid")
        try:
            content_digest = digest_bytes(path.read_bytes())
        except OSError:
            raise InstallError("profile-catalog-unreadable") from None
        ownership.append(
            {
                "name": name,
                "config_file": str(path),
                "sha256": content_digest,
            }
        )
    return ownership


def load_toml_bytes(data: bytes) -> dict[str, Any]:
    try:
        parsed = tomllib.loads(data.decode("utf-8")) if data else {}
    except (UnicodeError, tomllib.TOMLDecodeError):
        raise InstallError("config-toml-invalid") from None
    if not isinstance(parsed, dict):
        raise InstallError("config-toml-invalid")
    return parsed


def remove_stale_registrations(
    data: bytes,
    parsed: dict[str, Any],
    owned_registrations: set[tuple[str, str]],
) -> tuple[bytes, bool]:
    agents = parsed.get("agents", {})
    if not isinstance(agents, dict):
        raise InstallError("agents-table-invalid")
    names = [name for name in sorted(STALE_ROLE_NAMES) if name in agents]
    if not names:
        return data, False
    for name in names:
        entry = agents[name]
        if not isinstance(entry, dict) or set(entry) != {"config_file"}:
            raise InstallError("legacy-registration-conflict")
        config_file = entry.get("config_file")
        if (
            not isinstance(config_file, str)
            or (name, config_file) not in owned_registrations
        ):
            raise InstallError("legacy-ownership-conflict")
    try:
        text = data.decode("utf-8")
    except UnicodeError:
        raise InstallError("config-toml-invalid") from None
    lines = text.splitlines(keepends=True)
    table_header = re.compile(r"^\s*\[")
    assignment = re.compile(r"^\s*config_file\s*=")
    remove: set[int] = set()
    for name in names:
        escaped = re.escape(name)
        header = re.compile(
            rf'^\s*\[agents(?:\.{escaped}|\."{escaped}")\]\s*(?:#.*)?(?:\r?\n)?$'
        )
        header_indexes = [index for index, line in enumerate(lines) if header.fullmatch(line)]
        if len(header_indexes) != 1:
            raise InstallError("legacy-registration-conflict")
        start = header_indexes[0]
        stop = len(lines)
        for index in range(start + 1, len(lines)):
            if table_header.match(lines[index]):
                stop = index
                break
        assignment_indexes: list[int] = []
        for index in range(start + 1, stop):
            stripped = lines[index].strip()
            if not stripped or stripped.startswith("#"):
                continue
            if assignment.match(lines[index]):
                assignment_indexes.append(index)
            else:
                raise InstallError("legacy-registration-conflict")
        if len(assignment_indexes) != 1:
            raise InstallError("legacy-registration-conflict")
        remove.update((start, assignment_indexes[0]))
    result = "".join(line for index, line in enumerate(lines) if index not in remove).encode("utf-8")
    load_toml_bytes(result)
    return result, True


def reject_unmanaged_roles(parsed: dict[str, Any], role_names: set[str]) -> None:
    agents = parsed.get("agents", {})
    if not isinstance(agents, dict):
        raise InstallError("agents-table-invalid")
    if role_names.intersection(agents):
        raise InstallError("unmanaged-role-conflict")


def load_state(
    path: Path,
) -> tuple[dict[str, Any] | None, bytes | None, os.stat_result | None]:
    raw, state_stat = read_regular_snapshot(
        path,
        invalid_code="receipt-path-invalid",
        unreadable_code="receipt-invalid",
        oversized_code="receipt-too-large",
    )
    if state_stat is None:
        return None, None, None
    try:
        state = json.loads(raw.decode("utf-8"))
    except (UnicodeError, json.JSONDecodeError):
        raise InstallError("receipt-invalid") from None
    if not isinstance(state, dict) or state.get("schema") != STATE_SCHEMA:
        raise InstallError("receipt-invalid")
    if state.get("plugin") != PLUGIN_ID:
        raise InstallError("receipt-invalid")
    return state, raw, state_stat


def receipt_profile_ownership(
    state: dict[str, Any],
) -> dict[tuple[str, str], str] | None:
    if "managed_profiles" not in state:
        return None
    raw_profiles = state["managed_profiles"]
    if not isinstance(raw_profiles, list):
        raise InstallError("receipt-invalid")
    ownership: dict[tuple[str, str], str] = {}
    for record in raw_profiles:
        if not isinstance(record, dict):
            raise InstallError("receipt-invalid")
        name = record.get("name")
        config_file = record.get("config_file")
        content_digest = record.get("sha256")
        if (
            not isinstance(name, str)
            or not name
            or not isinstance(config_file, str)
            or not Path(config_file).is_absolute()
            or not isinstance(content_digest, str)
            or re.fullmatch(r"[0-9a-f]{64}", content_digest) is None
        ):
            raise InstallError("receipt-invalid")
        key = (name, config_file)
        if key in ownership:
            raise InstallError("receipt-invalid")
        ownership[key] = content_digest
    return ownership


def managed_registration_ownership(
    managed_block: bytes,
    state: dict[str, Any],
) -> tuple[dict[tuple[str, str], str], bool]:
    parsed = load_toml_bytes(managed_block)
    agents = parsed.get("agents", {})
    if not isinstance(agents, dict):
        raise InstallError("managed-block-conflict")
    recorded = receipt_profile_ownership(state)
    registrations: set[tuple[str, str]] = set()
    for name, entry in agents.items():
        if (
            not isinstance(name, str)
            or not isinstance(entry, dict)
            or set(entry) != {"config_file"}
            or not isinstance(entry.get("config_file"), str)
        ):
            raise InstallError("managed-block-conflict")
        key = (name, entry["config_file"])
        if key in registrations:
            raise InstallError("managed-block-conflict")
        registrations.add(key)
    if recorded is None:
        return {}, True
    if set(recorded) != registrations:
        raise InstallError("receipt-invalid")
    return recorded, False


def read_regular_or_empty(path: Path) -> tuple[bytes, os.stat_result | None]:
    return read_regular_snapshot(
        path,
        invalid_code="config-path-invalid",
        unreadable_code="config-unreadable",
        oversized_code="config-too-large",
    )


def ensure_safe_directory(path: Path, *, create: bool) -> None:
    if _BOUND_CODEX_HOME_FD >= 0 and path == bound_home_path(
        current_codex_home_fd()
    ):
        verify_current_codex_home()
        return
    if path.exists():
        if path.is_symlink() or not path.is_dir():
            raise InstallError("directory-path-invalid")
        return
    if not create:
        return
    parent = path.parent
    if parent != path:
        ensure_safe_directory(parent, create=True)
    try:
        path.mkdir(mode=0o700)
    except FileExistsError:
        pass
    except OSError:
        raise InstallError("directory-create-failed") from None
    if path.is_symlink() or not path.is_dir():
        raise InstallError("directory-path-invalid")


def archive_candidates(
    codex_home: Path,
    owned_registrations: dict[tuple[str, str], str],
    *,
    allow_legacy_digest_fallback: bool,
) -> tuple[list[tuple[Path, str]], set[tuple[str, str]]]:
    agents_dir = codex_home / "agents"
    if agents_dir.is_symlink():
        raise InstallError("global-agents-path-invalid")
    if not agents_dir.exists():
        return [], set()
    if not agents_dir.is_dir():
        raise InstallError("global-agents-path-invalid")
    candidates: list[tuple[Path, str]] = []
    retirement_ownership: set[tuple[str, str]] = set()
    for filename in sorted(LEGACY_PROFILE_FILES):
        path = agents_dir / filename
        ownership_path = (
            path
            if _BOUND_CODEX_HOME_PATH is None
            else _BOUND_CODEX_HOME_PATH / "agents" / filename
        )
        content, path_stat = read_regular_snapshot(
            path,
            invalid_code="legacy-profile-path-invalid",
            unreadable_code="legacy-profile-unreadable",
            oversized_code="legacy-profile-too-large",
        )
        if path_stat is None:
            continue
        name = path.stem
        ownership_key = (name, str(ownership_path))
        expected_digest = owned_registrations.get(ownership_key)
        canonical_legacy_path = (
            codex_home / "agents" / f"{name}.toml"
            if _BOUND_CODEX_HOME_PATH is None
            else _BOUND_CODEX_HOME_PATH / "agents" / f"{name}.toml"
        )
        if (
            expected_digest is None
            and allow_legacy_digest_fallback
            and ownership_path == canonical_legacy_path
        ):
            expected_digest = LEGACY_RETIRED_PROFILE_DIGESTS.get(name)
        if expected_digest is None:
            raise InstallError("legacy-ownership-conflict")
        content_digest = digest_bytes(content)
        if content_digest != expected_digest:
            raise InstallError("legacy-ownership-conflict")
        candidates.append((path, content_digest))
        retirement_ownership.add(ownership_key)
    return candidates, retirement_ownership


def choose_archive_dir(codex_home: Path, version: str, digest: str) -> Path:
    parent = codex_home / "archive" / PLUGIN_ID / safe_component(version)
    stem = f"sync-{digest[:12]}"
    for sequence in range(1, 1000):
        candidate = parent / f"{stem}-{sequence:03d}"
        if not candidate.exists():
            return candidate
    raise InstallError("archive-capacity-exceeded")


def state_document(
    *,
    version: str,
    installed: bool,
    digest: str | None,
    added_joiner: bool,
    archives: list[dict[str, Any]],
    managed_profiles: list[dict[str, str]],
) -> dict[str, Any]:
    return {
        "schema": STATE_SCHEMA,
        "plugin": PLUGIN_ID,
        "version": version,
        "status": "installed" if installed else "uninstalled",
        "changed": True,
        "role_count": ROLE_COUNT,
        "managed_digest": digest,
        "managed_joiner_added": added_joiner,
        "managed_profiles": managed_profiles,
        "archives": archives,
    }


def encode_state(state: dict[str, Any]) -> bytes:
    return (json.dumps(state, indent=2, sort_keys=True) + "\n").encode("utf-8")


def atomic_write(
    path: Path,
    data: bytes,
    previous_stat: os.stat_result | None,
    *,
    default_mode: int = 0o600,
    metadata: dict[str, int] | None = None,
    expected_data: bytes | None = None,
    expected_stat: os.stat_result | None = None,
    preimage_code: str = "atomic-preimage-drift",
    invalid_code: str = "atomic-target-invalid",
) -> None:
    ensure_safe_directory(path.parent, create=True)
    if path.is_symlink() or (path.exists() and not path.is_file()):
        raise InstallError(invalid_code)
    if metadata is not None:
        mode = metadata["mode"]
        uid = metadata["uid"]
        gid = metadata["gid"]
    else:
        mode = stat.S_IMODE(previous_stat.st_mode) if previous_stat else default_mode
        uid = previous_stat.st_uid if previous_stat else os.geteuid()
        gid = previous_stat.st_gid if previous_stat else os.getegid()
    fd = -1
    temp_name = ""
    try:
        fd, temp_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
        current = os.fstat(fd)
        if (
            not stat.S_ISREG(current.st_mode)
            or current.st_nlink != 1
            or current.st_uid != os.geteuid()
            or stat.S_IMODE(current.st_mode) & 0o077
        ):
            raise InstallError("atomic-temp-unsafe")
        with os.fdopen(fd, "wb", closefd=True) as stream:
            fd = -1
            stream.write(data)
            stream.flush()
            os.fsync(stream.fileno())
            if current.st_uid != uid or current.st_gid != gid:
                os.fchown(stream.fileno(), uid, gid)
            os.fchmod(stream.fileno(), mode)
            final_temp = os.fstat(stream.fileno())
            if (
                not stat.S_ISREG(final_temp.st_mode)
                or final_temp.st_nlink != 1
                or final_temp.st_uid != uid
                or final_temp.st_gid != gid
                or stat.S_IMODE(final_temp.st_mode) != mode
            ):
                raise InstallError("atomic-temp-unsafe")
            os.fsync(stream.fileno())
        if expected_data is not None:
            assert_preimage(
                path,
                expected_data,
                expected_stat,
                code=preimage_code,
                invalid_code=invalid_code,
            )
        os.replace(temp_name, path)
        temp_name = ""
        fsync_directory(path.parent, "atomic-write-failed")
    except InstallError:
        raise
    except (OSError, PermissionError):
        raise InstallError("atomic-write-failed") from None
    finally:
        if fd >= 0:
            os.close(fd)
        if temp_name:
            try:
                os.unlink(temp_name)
            except OSError:
                pass


def atomic_write_at(
    directory_fd: int,
    name: str,
    data: bytes,
    previous_stat: os.stat_result | None,
    *,
    expected_data: bytes,
    expected_stat: os.stat_result | None,
    preimage_code: str,
    invalid_code: str,
) -> None:
    if not name or name in {".", ".."} or "/" in name:
        raise InstallError(invalid_code)
    mode = stat.S_IMODE(previous_stat.st_mode) if previous_stat else 0o600
    uid = previous_stat.st_uid if previous_stat else os.geteuid()
    gid = previous_stat.st_gid if previous_stat else os.getegid()
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    fd = -1
    temp_name = ""
    try:
        for _ in range(32):
            temp_name = f".{name}.{os.urandom(16).hex()}"
            try:
                fd = os.open(temp_name, flags, 0o600, dir_fd=directory_fd)
                break
            except FileExistsError:
                temp_name = ""
        if fd < 0:
            raise InstallError("atomic-write-failed")
        current = os.fstat(fd)
        if (
            not stat.S_ISREG(current.st_mode)
            or current.st_nlink != 1
            or current.st_uid != os.geteuid()
            or stat.S_IMODE(current.st_mode) & 0o077
        ):
            raise InstallError("atomic-temp-unsafe")
        with os.fdopen(fd, "wb", closefd=True) as stream:
            fd = -1
            stream.write(data)
            stream.flush()
            os.fsync(stream.fileno())
            if current.st_uid != uid or current.st_gid != gid:
                os.fchown(stream.fileno(), uid, gid)
            os.fchmod(stream.fileno(), mode)
            final_temp = os.fstat(stream.fileno())
            if (
                not stat.S_ISREG(final_temp.st_mode)
                or final_temp.st_nlink != 1
                or final_temp.st_uid != uid
                or final_temp.st_gid != gid
                or stat.S_IMODE(final_temp.st_mode) != mode
            ):
                raise InstallError("atomic-temp-unsafe")
            os.fsync(stream.fileno())
        assert_preimage_at(
            directory_fd,
            name,
            expected_data,
            expected_stat,
            code=preimage_code,
            invalid_code=invalid_code,
            max_bytes=MAX_JOURNAL_BYTES,
        )
        if expected_stat is None:
            if not rename_no_replace(
                directory_fd,
                temp_name,
                directory_fd,
                name,
                preimage_code,
            ):
                raise InstallError(preimage_code)
        else:
            raise InstallError("unsafe-name-replacement-disabled")
        published_data, published_stat = read_regular_snapshot_at(
            directory_fd,
            name,
            invalid_code=invalid_code,
            unreadable_code=preimage_code,
            oversized_code=preimage_code,
            max_bytes=MAX_JOURNAL_BYTES,
        )
        if not stable_snapshot_matches(
            published_data,
            published_stat,
            data,
            final_temp,
        ):
            raise InstallError(preimage_code)
        temp_name = ""
        fsync_directory_fd(directory_fd, "atomic-write-failed")
    except InstallError:
        raise
    except (OSError, PermissionError):
        raise InstallError("atomic-write-failed") from None
    finally:
        if fd >= 0:
            os.close(fd)
        # A failed unpublished random entry is retained rather than removed by
        # name; recovery never mistakes it for a journal generation.


def transaction_journal_path(codex_home: Path) -> Path:
    return codex_home / TRANSACTION_DIRECTORY / TRANSACTION_JOURNAL


def assert_private_transaction_directory_fd(directory_fd: int) -> None:
    try:
        directory_stat = os.fstat(directory_fd)
    except OSError:
        raise InstallError("transaction-directory-invalid") from None
    if (
        not stat.S_ISDIR(directory_stat.st_mode)
        or directory_stat.st_uid != os.geteuid()
        or stat.S_IMODE(directory_stat.st_mode) & 0o077
        or directory_stat.st_nlink != 2
    ):
        raise InstallError("transaction-directory-unsafe")


def open_private_transaction_directory(
    codex_home_fd: int,
    *,
    create: bool,
) -> int | None:
    flags = os.O_RDONLY | os.O_DIRECTORY
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    directory_fd = -1
    try:
        try:
            directory_fd = os.open(
                TRANSACTION_DIRECTORY,
                flags,
                dir_fd=codex_home_fd,
            )
        except FileNotFoundError:
            if not create:
                return None
            try:
                os.mkdir(
                    TRANSACTION_DIRECTORY,
                    mode=0o700,
                    dir_fd=codex_home_fd,
                )
                fsync_directory_fd(
                    codex_home_fd,
                    "transaction-directory-create-failed",
                )
            except FileExistsError:
                pass
            except OSError:
                raise InstallError("transaction-directory-create-failed") from None
            try:
                directory_fd = os.open(
                    TRANSACTION_DIRECTORY,
                    flags,
                    dir_fd=codex_home_fd,
                )
            except OSError:
                raise InstallError("transaction-directory-unsafe") from None
        except OSError:
            raise InstallError("transaction-directory-unsafe") from None
        assert_private_transaction_directory_fd(directory_fd)
        result = directory_fd
        directory_fd = -1
        return result
    finally:
        if directory_fd >= 0:
            os.close(directory_fd)


def assert_transaction_directory_binding(
    directory_fd: int,
    codex_home_fd: int,
) -> None:
    assert_private_transaction_directory_fd(directory_fd)
    rebound_fd = open_private_transaction_directory(codex_home_fd, create=False)
    if rebound_fd is None:
        raise InstallError("transaction-directory-unsafe")
    try:
        original_stat = os.fstat(directory_fd)
        rebound_stat = os.fstat(rebound_fd)
        if (
            original_stat.st_dev != rebound_stat.st_dev
            or original_stat.st_ino != rebound_stat.st_ino
        ):
            raise InstallError("transaction-directory-unsafe")
    except OSError:
        raise InstallError("transaction-directory-invalid") from None
    finally:
        os.close(rebound_fd)


def file_image(data: bytes | None, file_stat: os.stat_result | None) -> dict[str, Any]:
    if data is None:
        return {
            "exists": False,
            "content": "",
            "sha256": digest_bytes(b""),
            "metadata": None,
        }
    return {
        "exists": True,
        "content": base64.b64encode(data).decode("ascii"),
        "sha256": digest_bytes(data),
        "metadata": None if file_stat is None else stat_identity(file_stat),
    }


def decode_file_image(value: Any) -> tuple[bytes | None, dict[str, int] | None]:
    if not isinstance(value, dict) or set(value) != {
        "exists",
        "content",
        "sha256",
        "metadata",
    }:
        raise InstallError("transaction-journal-invalid")
    exists = value["exists"]
    encoded = value["content"]
    content_digest = value["sha256"]
    metadata = value["metadata"]
    if (
        not isinstance(exists, bool)
        or not isinstance(encoded, str)
        or not isinstance(content_digest, str)
        or re.fullmatch(r"[0-9a-f]{64}", content_digest) is None
    ):
        raise InstallError("transaction-journal-invalid")
    try:
        data = base64.b64decode(encoded.encode("ascii"), validate=True)
    except (UnicodeError, ValueError, binascii.Error):
        raise InstallError("transaction-journal-invalid") from None
    if len(data) > MAX_PREIMAGE_BYTES or digest_bytes(data) != content_digest:
        raise InstallError("transaction-journal-invalid")
    if not exists:
        if data or metadata is not None:
            raise InstallError("transaction-journal-invalid")
        return None, None
    if metadata is not None:
        identity_keys = {
            "device",
            "inode",
            "mode",
            "uid",
            "gid",
            "links",
            "size",
            "mtime_ns",
            "ctime_ns",
        }
        if (
            not isinstance(metadata, dict)
            or set(metadata) != identity_keys
            or any(not isinstance(item, int) for item in metadata.values())
            or metadata["mode"] < 0
            or metadata["mode"] > 0o7777
            or metadata["uid"] < 0
            or metadata["gid"] < 0
            or metadata["size"] != len(data)
        ):
            raise InstallError("transaction-journal-invalid")
    return data, metadata


def transaction_document(plan: dict[str, Any]) -> dict[str, Any]:
    archive_dir: Path | None = plan["archive_dir"]
    logical_home = _BOUND_CODEX_HOME_PATH or plan["codex_home"]
    io_home = plan["codex_home"]
    transaction_dir = transaction_journal_path(logical_home).parent
    logical_archive_dir = (
        None
        if archive_dir is None
        else logical_home / archive_dir.relative_to(io_home)
    )
    archives = [
        {
            "source": str(logical_home / source.relative_to(io_home)),
            "destination": str(logical_archive_dir / source.name),
            "sha256": content_digest,
        }
        for source, content_digest in plan["candidates"]
    ]
    config_preimage = (
        None if plan["config_stat"] is None else plan["config_data"]
    )
    return {
        "schema": TRANSACTION_SCHEMA,
        "journal": {
            "id": plan["journal_id"],
            "generation": 0,
            "previous_sha256": None,
            "previous_identity": None,
        },
        "plugin": PLUGIN_ID,
        "operation": plan["operation"],
        "paths": {
            "config": str(logical_home / "config.toml"),
            "receipt": str(
                logical_home / "state" / f"{PLUGIN_ID}-role-sync.json"
            ),
            "archive_directory": (
                None if logical_archive_dir is None else str(logical_archive_dir)
            ),
        },
        "preimages": {
            "config": file_image(config_preimage, plan["config_stat"]),
            "receipt": file_image(plan["state_data"], plan["state_stat"]),
        },
        "desired": {
            "config": file_image(plan["desired_config"], None),
            "receipt": file_image(plan["desired_state"], None),
        },
        "config_exchange": {
            "changed": plan["config_changed"],
            "staging": plan["config_staging"],
            "prepared": str(transaction_dir / CONFIG_PREPARED),
            "displaced": str(transaction_dir / CONFIG_DISPLACED),
            "observed": str(transaction_dir / CONFIG_OBSERVED),
            "publication": {"phase": "planned", "identity": None},
        },
        "archives": archives,
    }


def validate_transaction_document(
    value: Any,
    codex_home: Path,
) -> dict[str, Any]:
    if not isinstance(value, dict):
        raise InstallError("transaction-journal-invalid")
    schema = value.get("schema")
    legacy = schema == LEGACY_TRANSACTION_SCHEMA
    provenance = schema == PROVENANCE_TRANSACTION_SCHEMA
    expected_keys = {
        "schema",
        "plugin",
        "operation",
        "paths",
        "preimages",
        "desired",
        "archives",
    }
    generation_journal = schema == TRANSACTION_SCHEMA and "journal" in value
    if generation_journal:
        expected_keys.add("journal")
    if not legacy:
        expected_keys.add("config_exchange")
    if set(value) != expected_keys:
        raise InstallError("transaction-journal-invalid")
    if (
        schema
        not in {
            LEGACY_TRANSACTION_SCHEMA,
            PROVENANCE_TRANSACTION_SCHEMA,
            TRANSACTION_SCHEMA,
        }
        or value["plugin"] != PLUGIN_ID
        or value["operation"] not in {"install", "uninstall"}
    ):
        raise InstallError("transaction-journal-invalid")
    if generation_journal:
        journal = value["journal"]
        previous_identity = (
            journal.get("previous_identity") if isinstance(journal, dict) else None
        )
        stable_identity_keys = {
            "device",
            "inode",
            "mode",
            "uid",
            "gid",
            "links",
            "size",
            "mtime_ns",
        }
        if (
            not isinstance(journal, dict)
            or set(journal)
            != {"id", "generation", "previous_sha256", "previous_identity"}
            or not isinstance(journal["id"], str)
            or re.fullmatch(r"[0-9a-f]{32}", journal["id"]) is None
            or not isinstance(journal["generation"], int)
            or journal["generation"] < 0
            or journal["generation"] > 99999999
            or (
                journal["generation"] == 0
                and (
                    journal["previous_sha256"] is not None
                    or previous_identity is not None
                )
            )
            or (
                journal["generation"] > 0
                and (
                    not isinstance(journal["previous_sha256"], str)
                    or re.fullmatch(
                        r"[0-9a-f]{64}", journal["previous_sha256"]
                    )
                    is None
                    or not isinstance(previous_identity, dict)
                    or set(previous_identity) != stable_identity_keys
                    or any(
                        not isinstance(item, int)
                        for item in previous_identity.values()
                    )
                )
            )
        ):
            raise InstallError("transaction-journal-invalid")
    if not legacy:
        exchange = value["config_exchange"]
        transaction_dir = transaction_journal_path(codex_home).parent
        exchange_keys = {"changed", "prepared", "displaced", "observed"}
        if not provenance:
            exchange_keys.update({"staging", "publication"})
        if (
            not isinstance(exchange, dict)
            or set(exchange) != exchange_keys
            or not isinstance(exchange["changed"], bool)
            or exchange["prepared"] != str(transaction_dir / CONFIG_PREPARED)
            or exchange["displaced"] != str(transaction_dir / CONFIG_DISPLACED)
            or exchange["observed"] != str(transaction_dir / CONFIG_OBSERVED)
        ):
            raise InstallError("transaction-journal-invalid")
        if not provenance:
            staging_raw = exchange["staging"]
            if not isinstance(staging_raw, str):
                raise InstallError("transaction-journal-invalid")
            staging = Path(staging_raw)
            publication = exchange["publication"]
            identity = (
                publication.get("identity")
                if isinstance(publication, dict)
                else None
            )
            stable_identity_keys = {
                "device",
                "inode",
                "mode",
                "uid",
                "gid",
                "links",
                "size",
                "mtime_ns",
            }
            if (
                staging.parent != transaction_dir
                or re.fullmatch(
                    rf"{re.escape(CONFIG_STAGING_PREFIX)}\.[0-9a-f]{{32}}",
                    staging.name,
                )
                is None
                or not isinstance(publication, dict)
                or set(publication) != {"phase", "identity"}
                or publication["phase"]
                not in {"planned", "publishing", "published"}
                or (
                    publication["phase"] == "planned"
                    and identity is not None
                )
                or (
                    publication["phase"] != "planned"
                    and (
                        not isinstance(identity, dict)
                        or set(identity) != stable_identity_keys
                        or any(not isinstance(item, int) for item in identity.values())
                        or identity["mode"] < 0
                        or identity["mode"] > 0o7777
                        or identity["uid"] < 0
                        or identity["gid"] < 0
                        or identity["links"] < 1
                        or identity["size"] < 0
                    )
                )
            ):
                raise InstallError("transaction-journal-invalid")
    paths = value["paths"]
    preimages = value["preimages"]
    desired = value["desired"]
    archives = value["archives"]
    if (
        not isinstance(paths, dict)
        or set(paths) != {"config", "receipt", "archive_directory"}
        or paths["config"] != str(codex_home / "config.toml")
        or paths["receipt"]
        != str(codex_home / "state" / f"{PLUGIN_ID}-role-sync.json")
        or not isinstance(preimages, dict)
        or set(preimages) != {"config", "receipt"}
        or not isinstance(desired, dict)
        or set(desired) != {"config", "receipt"}
        or not isinstance(archives, list)
        or len(archives) > len(LEGACY_PROFILE_FILES)
    ):
        raise InstallError("transaction-journal-invalid")
    for image in (*preimages.values(), *desired.values()):
        decode_file_image(image)
    if schema == TRANSACTION_SCHEMA:
        publication = value["config_exchange"]["publication"]
        if publication["identity"] is not None:
            desired_config, _ = decode_file_image(desired["config"])
            if (
                desired_config is None
                or publication["identity"]["size"] != len(desired_config)
            ):
                raise InstallError("transaction-journal-invalid")
    raw_archive_dir = paths["archive_directory"]
    if raw_archive_dir is None:
        if archives:
            raise InstallError("transaction-journal-invalid")
        archive_dir = None
    elif isinstance(raw_archive_dir, str):
        archive_dir = Path(raw_archive_dir)
        try:
            archive_dir.relative_to(codex_home / "archive" / PLUGIN_ID)
        except ValueError:
            raise InstallError("transaction-journal-invalid") from None
        if not archive_dir.is_absolute() or ".." in archive_dir.parts:
            raise InstallError("transaction-journal-invalid")
    else:
        raise InstallError("transaction-journal-invalid")
    seen_sources: set[str] = set()
    seen_destinations: set[str] = set()
    for record in archives:
        if not isinstance(record, dict) or set(record) != {
            "source",
            "destination",
            "sha256",
        }:
            raise InstallError("transaction-journal-invalid")
        source_raw = record["source"]
        destination_raw = record["destination"]
        content_digest = record["sha256"]
        if (
            not isinstance(source_raw, str)
            or not isinstance(destination_raw, str)
            or not isinstance(content_digest, str)
            or re.fullmatch(r"[0-9a-f]{64}", content_digest) is None
        ):
            raise InstallError("transaction-journal-invalid")
        source = Path(source_raw)
        destination = Path(destination_raw)
        if (
            archive_dir is None
            or source.parent != codex_home / "agents"
            or source.name not in LEGACY_PROFILE_FILES
            or destination.parent != archive_dir
            or destination.name != source.name
            or source_raw in seen_sources
            or destination_raw in seen_destinations
        ):
            raise InstallError("transaction-journal-invalid")
        seen_sources.add(source_raw)
        seen_destinations.add(destination_raw)
    return value


def write_transaction_journal(
    plan: dict[str, Any],
) -> tuple[dict[str, Any], Path, bytes, os.stat_result, int]:
    logical_home = _BOUND_CODEX_HOME_PATH or plan["codex_home"]
    journal_path = transaction_journal_path(logical_home)
    transaction_fd = open_private_transaction_directory(
        verify_current_codex_home(),
        create=True,
    )
    if transaction_fd is None:
        raise InstallError("transaction-directory-create-failed")
    try:
        staging_token = os.urandom(16).hex()
        plan["journal_id"] = os.urandom(16).hex()
    except OSError:
        os.close(transaction_fd)
        raise InstallError("transaction-journal-write-failed") from None
    plan["config_staging"] = str(
        journal_path.parent / f"{CONFIG_STAGING_PREFIX}.{staging_token}"
    )
    try:
        document = transaction_document(plan)
        raw, journal_stat, journal_path = persist_transaction_journal(
            document,
            journal_path,
            transaction_fd,
            expected_raw=b"",
            expected_stat=None,
        )
        return document, journal_path, raw, journal_stat, transaction_fd
    except InstallError:
        os.close(transaction_fd)
        raise


def persist_transaction_journal(
    document: dict[str, Any],
    journal_path: Path,
    transaction_fd: int,
    *,
    expected_raw: bytes,
    expected_stat: os.stat_result | None,
) -> tuple[bytes, os.stat_result, Path]:
    assert_transaction_directory_binding(
        transaction_fd,
        verify_current_codex_home(),
    )
    logical_home = _BOUND_CODEX_HOME_PATH or journal_path.parent.parent
    if expected_stat is not None:
        current_raw, current_stat = read_regular_snapshot_at(
            transaction_fd,
            journal_path.name,
            invalid_code="transaction-journal-unsafe",
            unreadable_code="transaction-journal-conflict",
            oversized_code="transaction-journal-too-large",
            max_bytes=MAX_JOURNAL_BYTES,
        )
        if not snapshot_matches(
            current_raw,
            current_stat,
            expected_raw,
            expected_stat,
        ):
            raise InstallError("transaction-journal-conflict")
        journal = document.get("journal")
        if not isinstance(journal, dict):
            raise InstallError("transaction-journal-conflict")
        journal["generation"] += 1
        journal["previous_sha256"] = digest_bytes(expected_raw)
        journal["previous_identity"] = stable_stat_identity(expected_stat)
    validate_transaction_document(document, logical_home)
    raw = (json.dumps(document, sort_keys=True, separators=(",", ":")) + "\n").encode(
        "utf-8"
    )
    if len(raw) > MAX_JOURNAL_BYTES:
        raise InstallError("transaction-journal-too-large")
    journal = document["journal"]
    generation_name = (
        f"{TRANSACTION_JOURNAL}.{journal['id']}."
        f"{journal['generation']:08d}"
    )
    atomic_write_at(
        transaction_fd,
        generation_name,
        raw,
        None,
        expected_data=b"",
        expected_stat=None,
        preimage_code="transaction-journal-conflict",
        invalid_code="transaction-journal-unsafe",
    )
    persisted, journal_stat = read_regular_snapshot_at(
        transaction_fd,
        generation_name,
        invalid_code="transaction-journal-unsafe",
        unreadable_code="transaction-journal-unreadable",
        oversized_code="transaction-journal-too-large",
        max_bytes=MAX_JOURNAL_BYTES,
    )
    if (
        journal_stat is None
        or persisted != raw
        or journal_stat.st_uid != os.geteuid()
        or journal_stat.st_nlink != 1
        or stat.S_IMODE(journal_stat.st_mode) != 0o600
    ):
        raise InstallError("transaction-journal-unsafe")
    return raw, journal_stat, journal_path.with_name(generation_name)


def relative_to_home(path: Path, codex_home: Path) -> str:
    try:
        return str(path.relative_to(codex_home))
    except ValueError:
        raise InstallError("archive-path-invalid") from None


def plan_operation(
    *,
    operation: str,
    codex_home: Path,
    version: str,
    profiles: list[tuple[str, Path]],
    block: bytes,
) -> dict[str, Any]:
    config_path = codex_home / "config.toml"
    state_path = codex_home / "state" / f"{PLUGIN_ID}-role-sync.json"
    config_data, config_stat = read_regular_or_empty(config_path)
    state, state_raw, state_stat = load_state(state_path)
    managed = find_managed_block(config_data)
    block_digest = digest_bytes(block)
    current_profiles = profile_ownership(profiles)
    existing_archives = [] if state is None else state.get("archives", [])
    if not isinstance(existing_archives, list):
        raise InstallError("receipt-invalid")

    owned_registrations: dict[tuple[str, str], str] = {}
    allow_legacy_digest_fallback = False
    if managed is not None:
        current_digest = digest_bytes(managed[2])
        if state is None or state.get("status") != "installed":
            raise InstallError("managed-block-unowned")
        if state.get("managed_digest") != current_digest:
            raise InstallError("managed-block-drift")
        (
            owned_registrations,
            allow_legacy_digest_fallback,
        ) = managed_registration_ownership(managed[2], state)
    elif state is not None and state.get("status") == "installed":
        raise InstallError("managed-block-missing")
    elif state is not None:
        receipt_profile_ownership(state)

    candidates: list[tuple[Path, str]] = []
    archive_dir: Path | None = None
    legacy_removed = False
    role_names = {name for name, _ in profiles}

    if operation == "install":
        candidates, retirement_ownership = archive_candidates(
            codex_home,
            owned_registrations,
            allow_legacy_digest_fallback=allow_legacy_digest_fallback,
        )
        if managed is None:
            parsed = load_toml_bytes(config_data)
            config_base, legacy_removed = remove_stale_registrations(
                config_data,
                parsed,
                retirement_ownership,
            )
            parsed_base = load_toml_bytes(config_base)
            reject_unmanaged_roles(parsed_base, role_names)
            added_joiner = bool(config_base and not config_base.endswith((b"\n", b"\r")))
            desired_config = config_base + (b"\n" if added_joiner else b"") + block
        else:
            added_joiner = bool(state.get("managed_joiner_added", False))
            desired_config = config_data[: managed[0]] + block + config_data[managed[1] :]
            unmanaged = config_data[: managed[0]] + config_data[managed[1] :]
            parsed_unmanaged = load_toml_bytes(unmanaged)
            remove_stale_registrations(
                unmanaged,
                parsed_unmanaged,
                set(),
            )
            reject_unmanaged_roles(parsed_unmanaged, role_names)
        if candidates:
            archive_dir = choose_archive_dir(codex_home, version, block_digest)
            archive_entry = {
                "directory": relative_to_home(archive_dir, codex_home),
                "count": len(candidates),
                "files": [
                    {
                        "source": relative_to_home(path, codex_home),
                        "archived": relative_to_home(
                            archive_dir / path.name,
                            codex_home,
                        ),
                        "sha256": content_digest,
                    }
                    for path, content_digest in candidates
                ],
            }
            archives = [*existing_archives, archive_entry]
        else:
            archives = existing_archives
        desired_state = state_document(
            version=version,
            installed=True,
            digest=block_digest,
            added_joiner=added_joiner,
            archives=archives,
            managed_profiles=current_profiles,
        )
    else:
        candidates = []
        archive_dir = None
        legacy_removed = False
        if managed is None:
            desired_config = config_data
            if state is None:
                desired_state = None
            else:
                desired_state = state_document(
                    version=version,
                    installed=False,
                    digest=None,
                    added_joiner=False,
                    archives=existing_archives,
                    managed_profiles=[],
                )
        else:
            remove_start = managed[0]
            if bool(state.get("managed_joiner_added", False)):
                if remove_start < 1 or config_data[remove_start - 1 : remove_start] != b"\n":
                    raise InstallError("managed-joiner-conflict")
                remove_start -= 1
            desired_config = config_data[:remove_start] + config_data[managed[1] :]
            desired_state = state_document(
                version=version,
                installed=False,
                digest=None,
                added_joiner=False,
                archives=existing_archives,
                managed_profiles=[],
            )

    desired_state_raw = None if desired_state is None else encode_state(desired_state)
    config_changed = desired_config != config_data
    state_changed = desired_state_raw != state_raw
    changed = config_changed or state_changed or bool(candidates)
    return {
        "operation": operation,
        "codex_home": codex_home,
        "config_path": config_path,
        "config_data": config_data,
        "config_stat": config_stat,
        "desired_config": desired_config,
        "config_changed": config_changed,
        "state_path": state_path,
        "state_data": state_raw,
        "state_stat": state_stat,
        "desired_state": desired_state_raw,
        "state_changed": state_changed,
        "candidates": candidates,
        "archive_dir": archive_dir,
        "legacy_removed": legacy_removed,
        "changed": changed,
        "digest": block_digest,
        "archive_history_count": len(existing_archives),
    }


def load_transaction_journal(
    codex_home: Path,
    transaction_fd: int | None = None,
) -> tuple[dict[str, Any], Path, bytes, os.stat_result, int] | None:
    journal_path = transaction_journal_path(codex_home)
    if transaction_fd is None:
        loaded_fd = open_private_transaction_directory(
            verify_current_codex_home(),
            create=False,
        )
        if loaded_fd is None:
            return None
    else:
        assert_transaction_directory_binding(
            transaction_fd,
            verify_current_codex_home(),
        )
        try:
            loaded_fd = os.dup(transaction_fd)
        except OSError:
            raise InstallError("transaction-directory-invalid") from None
    try:
        try:
            names = os.listdir(loaded_fd)
        except OSError:
            raise InstallError("transaction-journal-unreadable") from None
        pattern = re.compile(
            rf"{re.escape(journal_path.name)}\.([0-9a-f]{{32}})\.([0-9]{{8}})"
        )
        generations = [
            (match.group(1), int(match.group(2)), name)
            for name in names
            if (match := pattern.fullmatch(name)) is not None
        ]
        _, fixed_stat = read_regular_snapshot_at(
            loaded_fd,
            journal_path.name,
            invalid_code="transaction-journal-unsafe",
            unreadable_code="transaction-journal-unreadable",
            oversized_code="transaction-journal-too-large",
            max_bytes=MAX_JOURNAL_BYTES,
        )
        if fixed_stat is not None and generations:
            raise InstallError("transaction-journal-conflict")
        if fixed_stat is not None:
            candidate_names = [journal_path.name]
            candidate_generations = [0]
        elif generations:
            journal_ids = {journal_id for journal_id, _, _ in generations}
            if len(journal_ids) != 1:
                raise InstallError("transaction-journal-conflict")
            ordered = sorted(generations, key=lambda item: item[1])
            first_generation = ordered[0][1]
            if [generation for _, generation, _ in ordered] != list(
                range(first_generation, first_generation + len(ordered))
            ):
                raise InstallError("transaction-journal-conflict")
            candidate_names = [name for _, _, name in ordered]
            candidate_generations = [generation for _, generation, _ in ordered]
        else:
            os.close(loaded_fd)
            return None

        previous_raw: bytes | None = None
        previous_stat: os.stat_result | None = None
        latest: tuple[dict[str, Any], str, bytes, os.stat_result] | None = None
        for index, name in enumerate(candidate_names):
            generation = candidate_generations[index]
            raw, journal_stat = read_regular_snapshot_at(
                loaded_fd,
                name,
                invalid_code="transaction-journal-unsafe",
                unreadable_code="transaction-journal-unreadable",
                oversized_code="transaction-journal-too-large",
                max_bytes=MAX_JOURNAL_BYTES,
            )
            if (
                journal_stat is None
                or journal_stat.st_uid != os.geteuid()
                or journal_stat.st_nlink != 1
                or stat.S_IMODE(journal_stat.st_mode) != 0o600
            ):
                raise InstallError("transaction-journal-unsafe")
            try:
                parsed = json.loads(raw.decode("utf-8"))
            except (UnicodeError, json.JSONDecodeError):
                raise InstallError("transaction-journal-invalid") from None
            document = validate_transaction_document(parsed, codex_home)
            journal = document.get("journal")
            if len(candidate_names) > 1 or generations:
                if (
                    not isinstance(journal, dict)
                    or journal["generation"] != generation
                    or journal["id"] != generations[0][0]
                    or (
                        index > 0
                        and (
                            journal["previous_sha256"]
                            != digest_bytes(previous_raw or b"")
                            or journal["previous_identity"]
                            != stable_stat_identity(previous_stat)
                        )
                    )
                ):
                    raise InstallError("transaction-journal-conflict")
            previous_raw = raw
            previous_stat = journal_stat
            latest = (document, name, raw, journal_stat)
        if latest is None:
            raise InstallError("transaction-journal-invalid")
        document, name, raw, journal_stat = latest
        return (
            document,
            journal_path.with_name(name),
            raw,
            journal_stat,
            loaded_fd,
        )
    except InstallError:
        os.close(loaded_fd)
        raise


def uses_config_exchange(document: dict[str, Any]) -> bool:
    return (
        document["schema"]
        in {PROVENANCE_TRANSACTION_SCHEMA, TRANSACTION_SCHEMA}
        and document["config_exchange"]["changed"]
    )


def uses_publication_provenance(document: dict[str, Any]) -> bool:
    return document["schema"] == TRANSACTION_SCHEMA and uses_config_exchange(document)


def same_inode(left: os.stat_result | None, right: os.stat_result | None) -> bool:
    return (
        left is not None
        and right is not None
        and left.st_dev == right.st_dev
        and left.st_ino == right.st_ino
    )


def exact_image_match(
    data: bytes,
    file_stat: os.stat_result | None,
    image: dict[str, Any],
) -> bool:
    expected_data, metadata = decode_file_image(image)
    if expected_data is None:
        return file_stat is None
    return (
        file_stat is not None
        and metadata is not None
        and data == expected_data
        and stable_stat_identity(file_stat)
        == {key: value for key, value in metadata.items() if key != "ctime_ns"}
    )


def open_config_exchange_directories(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> tuple[int, int]:
    codex_home_fd = verify_current_codex_home()
    assert_transaction_directory_binding(
        authenticated_transaction_fd,
        codex_home_fd,
    )
    try:
        home_fd = os.dup(codex_home_fd)
    except OSError:
        raise InstallError("transaction-config-conflict") from None
    try:
        transaction_fd = os.dup(authenticated_transaction_fd)
    except OSError:
        os.close(home_fd)
        raise InstallError("transaction-config-conflict") from None
    return home_fd, transaction_fd


def exchange_snapshot(
    directory_fd: int,
    name: str,
) -> tuple[bytes, os.stat_result | None]:
    return read_regular_snapshot_at(
        directory_fd,
        name,
        invalid_code="transaction-config-conflict",
        unreadable_code="transaction-config-conflict",
        oversized_code="transaction-config-conflict",
    )


def rename_no_replace(
    source_fd: int,
    source: str,
    destination_fd: int,
    destination: str,
    code: str,
) -> bool:
    """Atomically move one descriptor-relative entry without replacing another."""
    try:
        renameat2 = ctypes.CDLL(None, use_errno=True).renameat2
    except (AttributeError, OSError):
        raise InstallError("atomic-rename-unsupported") from None
    renameat2.argtypes = (
        ctypes.c_int,
        ctypes.c_char_p,
        ctypes.c_int,
        ctypes.c_char_p,
        ctypes.c_uint,
    )
    renameat2.restype = ctypes.c_int
    result = renameat2(
        source_fd,
        os.fsencode(source),
        destination_fd,
        os.fsencode(destination),
        1,  # RENAME_NOREPLACE
    )
    if result == 0:
        return True
    error_number = ctypes.get_errno()
    if error_number in {errno.EEXIST, errno.ENOTEMPTY}:
        return False
    raise InstallError(code) from None


def quarantine_entry(
    source_fd: int,
    source: str,
    transaction_fd: int,
    *,
    expected_data: bytes,
    expected_stat: os.stat_result,
    label: str,
    code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> tuple[str, bytes, os.stat_result]:
    """Move a named source first, then authenticate the moved inode."""
    quarantine_name: str | None = None
    for _ in range(32):
        try:
            candidate = f".{safe_component(label)}.quarantine.{os.urandom(16).hex()}"
        except OSError:
            raise InstallError(code) from None
        if rename_no_replace(
            source_fd,
            source,
            transaction_fd,
            candidate,
            code,
        ):
            quarantine_name = candidate
            break
    if quarantine_name is None:
        raise InstallError(code)
    fsync_directory_fd(source_fd, code)
    if source_fd != transaction_fd:
        fsync_directory_fd(transaction_fd, code)
    moved_data, moved_stat = read_regular_snapshot_at(
        transaction_fd,
        quarantine_name,
        invalid_code=code,
        unreadable_code=code,
        oversized_code=code,
        max_bytes=max_bytes,
    )
    if (
        moved_stat is None
        or not stable_snapshot_matches(
            moved_data,
            moved_stat,
            expected_data,
            expected_stat,
        )
    ):
        raise InstallError(code)
    return quarantine_name, moved_data, moved_stat


def unlink_authenticated_quarantine(
    transaction_fd: int,
    name: str,
    expected_data: bytes,
    expected_stat: os.stat_result,
    *,
    code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> None:
    current_data, current_stat = read_regular_snapshot_at(
        transaction_fd,
        name,
        invalid_code=code,
        unreadable_code=code,
        oversized_code=code,
        max_bytes=max_bytes,
    )
    if not stable_snapshot_matches(
        current_data,
        current_stat,
        expected_data,
        expected_stat,
    ):
        raise InstallError(code)
    try:
        os.unlink(name, dir_fd=transaction_fd)
        fsync_directory_fd(transaction_fd, code)
    except OSError:
        raise InstallError(code) from None


def unlink_exchange_artifact(
    transaction_fd: int,
    name: str,
    code: str,
) -> None:
    artifact_data, artifact_stat = exchange_snapshot(transaction_fd, name)
    if artifact_stat is None:
        return
    quarantine_name, moved_data, moved_stat = quarantine_entry(
        transaction_fd,
        name,
        transaction_fd,
        expected_data=artifact_data,
        expected_stat=artifact_stat,
        label=name,
        code=code,
    )
    unlink_authenticated_quarantine(
        transaction_fd,
        quarantine_name,
        moved_data,
        moved_stat,
        code=code,
    )


def config_staging_name(document: dict[str, Any]) -> str:
    return Path(document["config_exchange"]["staging"]).name


def expected_config_metadata(document: dict[str, Any]) -> dict[str, int]:
    _, metadata = decode_file_image(document["preimages"]["config"])
    if metadata is not None:
        return {
            "mode": metadata["mode"],
            "uid": metadata["uid"],
            "gid": metadata["gid"],
        }
    return {"mode": 0o600, "uid": os.geteuid(), "gid": os.getegid()}


def desired_config_snapshot_matches(
    document: dict[str, Any],
    data: bytes,
    file_stat: os.stat_result | None,
    *,
    links: int,
) -> bool:
    desired_data, _ = decode_file_image(document["desired"]["config"])
    metadata = expected_config_metadata(document)
    return (
        desired_data is not None
        and file_stat is not None
        and data == desired_data
        and stat.S_IMODE(file_stat.st_mode) == metadata["mode"]
        and file_stat.st_uid == metadata["uid"]
        and file_stat.st_gid == metadata["gid"]
        and file_stat.st_nlink == links
        and file_stat.st_size == len(desired_data)
    )


def publication_snapshot_matches(
    document: dict[str, Any],
    data: bytes,
    file_stat: os.stat_result | None,
    *,
    link_delta: int = 0,
) -> bool:
    publication = document["config_exchange"]["publication"]
    identity = publication["identity"]
    desired_data, _ = decode_file_image(document["desired"]["config"])
    if identity is None or desired_data is None or file_stat is None:
        return False
    expected_identity = dict(identity)
    expected_identity["links"] += link_delta
    return (
        data == desired_data
        and stable_stat_identity(file_stat) == expected_identity
    )


def incomplete_staging_names(
    document: dict[str, Any],
    label: str,
) -> tuple[str, str]:
    journal = document.get("journal")
    if isinstance(journal, dict) and isinstance(journal.get("id"), str):
        correlation = journal["id"]
    else:
        encoded = json.dumps(
            document,
            sort_keys=True,
            separators=(",", ":"),
        ).encode("utf-8")
        correlation = digest_bytes(encoded)[:32]
    safe_label = safe_component(label)
    return (
        f"{CONFIG_INCOMPLETE_MARKER_PREFIX}.{correlation}.{safe_label}",
        f"{CONFIG_INCOMPLETE_RETAINED_PREFIX}.{correlation}.{safe_label}",
    )


def retain_incomplete_staging(
    document: dict[str, Any],
    transaction_fd: int,
    source_name: str,
    label: str,
    source_data: bytes | None = None,
    source_stat: os.stat_result | None = None,
) -> bool:
    """Durably identify and retain a partial prepared inode before recovery."""
    marker_name, retained_name = incomplete_staging_names(document, label)
    marker_raw, marker_stat = exchange_snapshot(transaction_fd, marker_name)
    if marker_stat is None:
        if source_data is None or source_stat is None:
            return False
        marker = {
            "schema": "bears-config-incomplete-staging.v1",
            "source": source_name,
            "retained": retained_name,
            "sha256": digest_bytes(source_data),
            "identity": stable_stat_identity(source_stat),
        }
        marker_raw = (
            json.dumps(marker, sort_keys=True, separators=(",", ":")) + "\n"
        ).encode("utf-8")
        atomic_write_at(
            transaction_fd,
            marker_name,
            marker_raw,
            None,
            expected_data=b"",
            expected_stat=None,
            preimage_code="transaction-config-conflict",
            invalid_code="transaction-config-conflict",
        )
        marker_raw, marker_stat = exchange_snapshot(transaction_fd, marker_name)
    try:
        marker = json.loads(marker_raw.decode("utf-8"))
    except (UnicodeError, json.JSONDecodeError):
        raise InstallError("transaction-config-conflict") from None
    if (
        marker_stat is None
        or marker_stat.st_uid != os.geteuid()
        or marker_stat.st_nlink != 1
        or stat.S_IMODE(marker_stat.st_mode) != 0o600
        or not isinstance(marker, dict)
        or set(marker) != {"schema", "source", "retained", "sha256", "identity"}
        or marker["schema"] != "bears-config-incomplete-staging.v1"
        or marker["source"] != source_name
        or marker["retained"] != retained_name
        or not isinstance(marker["sha256"], str)
        or re.fullmatch(r"[0-9a-f]{64}", marker["sha256"]) is None
        or not isinstance(marker["identity"], dict)
        or set(marker["identity"])
        != {"device", "inode", "mode", "uid", "gid", "links", "size", "mtime_ns"}
        or any(not isinstance(item, int) for item in marker["identity"].values())
    ):
        raise InstallError("transaction-config-conflict")
    retained_data, retained_stat = exchange_snapshot(transaction_fd, retained_name)
    if retained_stat is None:
        source_data, source_stat = exchange_snapshot(transaction_fd, source_name)
        if source_stat is None:
            raise InstallError("transaction-config-conflict")
        if not rename_no_replace(
            transaction_fd,
            source_name,
            transaction_fd,
            retained_name,
            "transaction-config-conflict",
        ):
            raise InstallError("transaction-config-conflict")
        fsync_directory_fd(transaction_fd, "transaction-config-conflict")
        retained_data, retained_stat = exchange_snapshot(
            transaction_fd,
            retained_name,
        )
    if (
        retained_stat is None
        or digest_bytes(retained_data) != marker["sha256"]
        or stable_stat_identity(retained_stat) != marker["identity"]
    ):
        raise InstallError("transaction-config-conflict")
    return True


def discard_config_staging_artifact(
    document: dict[str, Any],
    transaction_fd: int,
) -> bool:
    name = config_staging_name(document)
    if retain_incomplete_staging(document, transaction_fd, name, "staging"):
        return True
    staging_data, staging_stat = exchange_snapshot(transaction_fd, name)
    if staging_stat is None:
        return False
    if not desired_config_snapshot_matches(
        document,
        staging_data,
        staging_stat,
        links=1,
    ):
        return retain_incomplete_staging(
            document,
            transaction_fd,
            name,
            "staging",
            staging_data,
            staging_stat,
        )
    unlink_exchange_artifact(
        transaction_fd,
        name,
        "transaction-config-conflict",
    )
    return False


def create_prepared_config(
    plan: dict[str, Any],
    document: dict[str, Any],
    transaction_fd: int,
) -> None:
    staging_name = config_staging_name(document)
    for name in (
        staging_name,
        CONFIG_PREPARED,
        CONFIG_DISPLACED,
        CONFIG_OBSERVED,
    ):
        _, artifact_stat = exchange_snapshot(transaction_fd, name)
        if artifact_stat is not None:
            raise InstallError("config-exchange-artifact-conflict")
    previous_stat = plan["config_stat"]
    mode = stat.S_IMODE(previous_stat.st_mode) if previous_stat else 0o600
    uid = previous_stat.st_uid if previous_stat else os.geteuid()
    gid = previous_stat.st_gid if previous_stat else os.getegid()
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    fd = -1
    try:
        fd = os.open(staging_name, flags, 0o600, dir_fd=transaction_fd)
        initial = os.fstat(fd)
        if (
            not stat.S_ISREG(initial.st_mode)
            or initial.st_nlink != 1
            or initial.st_uid != os.geteuid()
            or stat.S_IMODE(initial.st_mode) & 0o077
        ):
            raise InstallError("atomic-temp-unsafe")
        with os.fdopen(fd, "wb", closefd=True) as stream:
            fd = -1
            stream.write(plan["desired_config"])
            stream.flush()
            os.fsync(stream.fileno())
            if initial.st_uid != uid or initial.st_gid != gid:
                os.fchown(stream.fileno(), uid, gid)
            os.fchmod(stream.fileno(), mode)
            final = os.fstat(stream.fileno())
            if (
                not stat.S_ISREG(final.st_mode)
                or final.st_nlink != 1
                or final.st_uid != uid
                or final.st_gid != gid
                or stat.S_IMODE(final.st_mode) != mode
            ):
                raise InstallError("atomic-temp-unsafe")
            os.fsync(stream.fileno())
        staged_data, staged_stat = exchange_snapshot(transaction_fd, staging_name)
        if (
            not stable_snapshot_matches(
                staged_data,
                staged_stat,
                plan["desired_config"],
                final,
            )
            or not desired_config_snapshot_matches(
                document,
                staged_data,
                staged_stat,
                links=1,
            )
        ):
            raise InstallError("atomic-temp-unsafe")
        quarantine_name, staged_data, staged_stat = quarantine_entry(
            transaction_fd,
            staging_name,
            transaction_fd,
            expected_data=staged_data,
            expected_stat=staged_stat,
            label="prepared-promotion",
            code="atomic-write-failed",
        )
        if not rename_no_replace(
            transaction_fd,
            quarantine_name,
            transaction_fd,
            CONFIG_PREPARED,
            "atomic-write-failed",
        ):
            raise InstallError("config-exchange-artifact-conflict")
        fsync_directory_fd(transaction_fd, "atomic-write-failed")
        prepared_data, prepared_stat = exchange_snapshot(
            transaction_fd, CONFIG_PREPARED
        )
        if not desired_config_snapshot_matches(
            document,
            prepared_data,
            prepared_stat,
            links=1,
        ):
            raise InstallError("atomic-temp-unsafe")
    except InstallError:
        raise
    except OSError:
        raise InstallError("atomic-write-failed") from None
    finally:
        if fd >= 0:
            os.close(fd)


def displace_and_publish_config(
    plan: dict[str, Any],
    document: dict[str, Any],
    journal_path: Path,
    journal_raw: bytes,
    journal_stat: os.stat_result,
    authenticated_transaction_fd: int,
) -> tuple[Path, bytes, os.stat_result]:
    home_fd, transaction_fd = open_config_exchange_directories(
        document,
        authenticated_transaction_fd,
    )
    try:
        create_prepared_config(plan, document, transaction_fd)
        if plan["config_stat"] is not None:
            quarantine_name, displaced_data, displaced_stat = quarantine_entry(
                home_fd,
                "config.toml",
                transaction_fd,
                expected_data=plan["config_data"],
                expected_stat=plan["config_stat"],
                label="config-displacement",
                code="config-preimage-drift",
            )
            if not rename_no_replace(
                transaction_fd,
                quarantine_name,
                transaction_fd,
                CONFIG_DISPLACED,
                "config-preimage-drift",
            ):
                raise InstallError("config-exchange-artifact-conflict")
            fsync_directory_fd(home_fd, "atomic-write-failed")
            fsync_directory_fd(transaction_fd, "atomic-write-failed")
            displaced_data, displaced_stat = exchange_snapshot(
                transaction_fd, CONFIG_DISPLACED
            )
            if not stable_snapshot_matches(
                displaced_data,
                displaced_stat,
                plan["config_data"],
                plan["config_stat"],
            ):
                raise InstallError("config-preimage-drift")
        else:
            current_data, current_stat = read_regular_snapshot_at(
                home_fd,
                "config.toml",
                invalid_code="config-path-invalid",
                unreadable_code="config-preimage-drift",
                oversized_code="config-preimage-drift",
            )
            if current_stat is not None or current_data:
                raise InstallError("config-preimage-drift")
        prepared_data, prepared_stat = exchange_snapshot(
            transaction_fd, CONFIG_PREPARED
        )
        if not desired_config_snapshot_matches(
            document,
            prepared_data,
            prepared_stat,
            links=1,
        ):
            raise InstallError("transaction-config-conflict")
        document["config_exchange"]["publication"] = {
            "phase": "publishing",
            "identity": stable_stat_identity(prepared_stat),
        }
        journal_raw, journal_stat, journal_path = persist_transaction_journal(
            document,
            journal_path,
            transaction_fd,
            expected_raw=journal_raw,
            expected_stat=journal_stat,
        )
        quarantine_name, prepared_data, prepared_stat = quarantine_entry(
            transaction_fd,
            CONFIG_PREPARED,
            transaction_fd,
            expected_data=prepared_data,
            expected_stat=prepared_stat,
            label="config-publication",
            code="transaction-config-conflict",
        )
        if not publication_snapshot_matches(
            document,
            prepared_data,
            prepared_stat,
        ):
            raise InstallError("transaction-config-conflict")
        if not rename_no_replace(
            transaction_fd,
            quarantine_name,
            home_fd,
            "config.toml",
            "atomic-write-failed",
        ):
            raise InstallError("config-publish-conflict")
        fsync_directory_fd(home_fd, "atomic-write-failed")
        fsync_directory_fd(transaction_fd, "atomic-write-failed")
        published_data, published_stat = exchange_snapshot(home_fd, "config.toml")
        if not publication_snapshot_matches(
            document,
            published_data,
            published_stat,
        ):
            raise InstallError("transaction-config-conflict")
        document["config_exchange"]["publication"]["phase"] = "published"
        journal_raw, journal_stat, journal_path = persist_transaction_journal(
            document,
            journal_path,
            transaction_fd,
            expected_raw=journal_raw,
            expected_stat=journal_stat,
        )
        return journal_path, journal_raw, journal_stat
    finally:
        os.close(transaction_fd)
        os.close(home_fd)


def image_matches_snapshot(
    data: bytes,
    file_stat: os.stat_result | None,
    image: dict[str, Any],
    *,
    metadata_required: bool,
) -> bool:
    expected_data, metadata = decode_file_image(image)
    if expected_data is None:
        return file_stat is None
    if file_stat is None or data != expected_data:
        return False
    if metadata_required and metadata is not None:
        return (
            stat.S_IMODE(file_stat.st_mode) == metadata["mode"]
            and file_stat.st_uid == metadata["uid"]
            and file_stat.st_gid == metadata["gid"]
        )
    return True


def read_transaction_target(path: Path, code: str) -> tuple[bytes, os.stat_result | None]:
    path = bind_codex_path(path, code)
    return read_regular_snapshot(
        path,
        invalid_code=code,
        unreadable_code=code,
        oversized_code=code,
    )


def bind_codex_path(path: Path, code: str) -> Path:
    """Map a validated logical CODEX_HOME path onto the pinned home fd."""
    if _BOUND_CODEX_HOME_PATH is None:
        return path
    io_home = bound_home_path(verify_current_codex_home())
    try:
        relative = path.relative_to(_BOUND_CODEX_HOME_PATH)
    except ValueError:
        try:
            path.relative_to(io_home)
        except ValueError:
            raise InstallError(code) from None
        return path
    if ".." in relative.parts:
        raise InstallError(code)
    return io_home / relative


def restore_exchange_artifact(
    home_fd: int,
    transaction_fd: int,
    name: str,
) -> bool:
    source_data, source_stat = exchange_snapshot(transaction_fd, name)
    if source_stat is None:
        raise InstallError("transaction-config-conflict")
    quarantine_name, source_data, source_stat = quarantine_entry(
        transaction_fd,
        name,
        transaction_fd,
        expected_data=source_data,
        expected_stat=source_stat,
        label=f"restore-{name}",
        code="transaction-config-conflict",
    )
    if not rename_no_replace(
        transaction_fd,
        quarantine_name,
        home_fd,
        "config.toml",
        "transaction-config-conflict",
    ):
        return False
    fsync_directory_fd(home_fd, "transaction-config-conflict")
    fsync_directory_fd(transaction_fd, "transaction-config-conflict")
    restored_data, restored_stat = exchange_snapshot(home_fd, "config.toml")
    if not stable_snapshot_matches(
        restored_data,
        restored_stat,
        source_data,
        source_stat,
    ):
        raise InstallError("transaction-config-conflict")
    return True


def retain_exchange_artifact(
    transaction_fd: int,
    name: str,
    data: bytes,
    file_stat: os.stat_result,
    label: str,
) -> str:
    backup_name: str | None = None
    for _ in range(32):
        try:
            candidate = (
                f"{CONFIG_CONFLICT_BACKUP_PREFIX}.{label}."
                f"{os.urandom(16).hex()}"
            )
        except OSError:
            raise InstallError("transaction-config-conflict") from None
        if rename_no_replace(
            transaction_fd,
            name,
            transaction_fd,
            candidate,
            "transaction-config-conflict",
        ):
            backup_name = candidate
            break
    if backup_name is None:
        raise InstallError("transaction-config-conflict")
    fsync_directory_fd(transaction_fd, "transaction-config-conflict")
    retained_data, retained_stat = exchange_snapshot(transaction_fd, backup_name)
    if not stable_snapshot_matches(
        retained_data,
        retained_stat,
        data,
        file_stat,
    ):
        raise InstallError("transaction-config-conflict")
    return backup_name


def preserve_exchange_artifact(
    home_fd: int,
    transaction_fd: int,
    name: str,
    data: bytes,
    file_stat: os.stat_result,
    label: str,
) -> None:
    _, current_stat = exchange_snapshot(home_fd, "config.toml")
    if same_inode(current_stat, file_stat):
        unlink_exchange_artifact(
            transaction_fd,
            name,
            "transaction-config-conflict",
        )
        return
    if current_stat is None and restore_exchange_artifact(
        home_fd,
        transaction_fd,
        name,
    ):
        return
    retain_exchange_artifact(
        transaction_fd,
        name,
        data,
        file_stat,
        label,
    )


def move_live_config_to_observed(
    home_fd: int,
    transaction_fd: int,
) -> tuple[bytes, os.stat_result | None]:
    _, observed_stat = exchange_snapshot(transaction_fd, CONFIG_OBSERVED)
    if observed_stat is not None:
        raise InstallError("transaction-config-conflict")
    current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
    if current_stat is None:
        return b"", None
    quarantine_name, current_data, current_stat = quarantine_entry(
        home_fd,
        "config.toml",
        transaction_fd,
        expected_data=current_data,
        expected_stat=current_stat,
        label="observed-config",
        code="transaction-config-conflict",
    )
    if not rename_no_replace(
        transaction_fd,
        quarantine_name,
        transaction_fd,
        CONFIG_OBSERVED,
        "transaction-config-conflict",
    ):
        raise InstallError("transaction-config-conflict")
    fsync_directory_fd(home_fd, "transaction-config-conflict")
    fsync_directory_fd(transaction_fd, "transaction-config-conflict")
    return exchange_snapshot(transaction_fd, CONFIG_OBSERVED)


def exchange_snapshot_position(
    data: bytes,
    file_stat: os.stat_result | None,
    preimage: dict[str, Any],
    desired: dict[str, Any],
) -> str:
    if exact_image_match(data, file_stat, preimage):
        return "preimage"
    if image_matches_snapshot(
        data,
        file_stat,
        desired,
        metadata_required=False,
    ):
        return "desired"
    if file_stat is None:
        return "missing"
    return "writer"


def remove_desired_exchange_artifact(
    transaction_fd: int,
    name: str,
    desired: dict[str, Any],
) -> bool:
    data, file_stat = exchange_snapshot(transaction_fd, name)
    if file_stat is None:
        return True
    if not image_matches_snapshot(
        data,
        file_stat,
        desired,
        metadata_required=False,
    ):
        return False
    unlink_exchange_artifact(
        transaction_fd,
        name,
        "transaction-config-conflict",
    )
    return True


def resolve_prepared_config(
    document: dict[str, Any],
    transaction_fd: int,
    desired: dict[str, Any],
) -> bool:
    if retain_incomplete_staging(
        document,
        transaction_fd,
        CONFIG_PREPARED,
        "prepared",
    ):
        return True
    prepared_data, prepared_stat = exchange_snapshot(
        transaction_fd, CONFIG_PREPARED
    )
    if prepared_stat is None:
        return False
    if image_matches_snapshot(
        prepared_data,
        prepared_stat,
        desired,
        metadata_required=False,
    ):
        unlink_exchange_artifact(
            transaction_fd,
            CONFIG_PREPARED,
            "transaction-config-conflict",
        )
        return False
    retain_incomplete_staging(
        document,
        transaction_fd,
        CONFIG_PREPARED,
        "prepared",
        prepared_data,
        prepared_stat,
    )
    return True


def retain_displaced_preimage(
    transaction_fd: int,
    preimage: dict[str, Any],
) -> None:
    displaced_data, displaced_stat = exchange_snapshot(
        transaction_fd, CONFIG_DISPLACED
    )
    if displaced_stat is None:
        return
    if not exact_image_match(displaced_data, displaced_stat, preimage):
        raise InstallError("transaction-config-conflict")
    retain_exchange_artifact(
        transaction_fd,
        CONFIG_DISPLACED,
        displaced_data,
        displaced_stat,
        "preimage",
    )


def image_matches_expected_link_delta(
    data: bytes,
    file_stat: os.stat_result | None,
    image: dict[str, Any],
    *,
    delta: int,
) -> bool:
    expected_data, metadata = decode_file_image(image)
    if expected_data is None or metadata is None or file_stat is None:
        return False
    expected_identity = {
        key: value for key, value in metadata.items() if key != "ctime_ns"
    }
    expected_identity["links"] += delta
    return (
        data == expected_data
        and stable_stat_identity(file_stat) == expected_identity
    )


def repair_v2_preimage_link_transitions(
    document: dict[str, Any],
    home_fd: int,
    transaction_fd: int,
) -> bool:
    """Finish authenticated v2 hardlink moves interrupted before source unlink."""
    preimage = document["preimages"]["config"]
    current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
    try:
        transaction_names = os.listdir(transaction_fd)
    except OSError:
        raise InstallError("transaction-config-conflict") from None
    backup_pattern = re.compile(
        rf"{re.escape(CONFIG_CONFLICT_BACKUP_PREFIX)}\.preimage\.[0-9a-f]{{32}}"
    )
    backup_names = [
        name
        for name in transaction_names
        if backup_pattern.fullmatch(name) is not None
    ]
    retained_preimage = False
    for source_name in (CONFIG_DISPLACED, CONFIG_OBSERVED):
        source_data, source_stat = exchange_snapshot(transaction_fd, source_name)
        if not image_matches_expected_link_delta(
            source_data,
            source_stat,
            preimage,
            delta=1,
        ):
            continue
        if (
            same_inode(source_stat, current_stat)
            and image_matches_expected_link_delta(
                current_data,
                current_stat,
                preimage,
                delta=1,
            )
        ):
            unlink_exchange_artifact(
                transaction_fd,
                source_name,
                "transaction-config-conflict",
            )
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
            continue
        matching_backups = []
        for backup_name in backup_names:
            _, backup_stat = exchange_snapshot(transaction_fd, backup_name)
            if same_inode(source_stat, backup_stat):
                matching_backups.append(backup_name)
        if len(matching_backups) == 1:
            unlink_exchange_artifact(
                transaction_fd,
                source_name,
                "transaction-config-conflict",
            )
            retained_preimage = True
    return retained_preimage


def prepared_config_is_owned(
    document: dict[str, Any],
    data: bytes,
    file_stat: os.stat_result | None,
    *,
    link_delta: int = 0,
) -> bool:
    publication = document["config_exchange"]["publication"]
    if publication["identity"] is not None:
        return publication_snapshot_matches(
            document,
            data,
            file_stat,
            link_delta=link_delta,
        )
    return desired_config_snapshot_matches(
        document,
        data,
        file_stat,
        links=1 + link_delta,
    )


def retain_v3_exchange_conflict(
    document: dict[str, Any],
    home_fd: int,
    transaction_fd: int,
) -> str:
    """Preserve writer state and retire only authenticated v3 artifacts."""
    incomplete_staging = discard_config_staging_artifact(document, transaction_fd)
    preimage = document["preimages"]["config"]
    prepared_data, prepared_stat = exchange_snapshot(
        transaction_fd, CONFIG_PREPARED
    )
    if prepared_stat is not None:
        if prepared_config_is_owned(document, prepared_data, prepared_stat):
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_PREPARED,
                "transaction-config-conflict",
            )
        else:
            retain_incomplete_staging(
                document,
                transaction_fd,
                CONFIG_PREPARED,
                "prepared",
                prepared_data,
                prepared_stat,
            )
            incomplete_staging = True
    observed_data, observed_stat = exchange_snapshot(
        transaction_fd, CONFIG_OBSERVED
    )
    if observed_stat is not None:
        if publication_snapshot_matches(
            document,
            observed_data,
            observed_stat,
        ):
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_OBSERVED,
                "transaction-config-conflict",
            )
        else:
            preserve_exchange_artifact(
                home_fd,
                transaction_fd,
                CONFIG_OBSERVED,
                observed_data,
                observed_stat,
                "writer",
            )
    displaced_data, displaced_stat = exchange_snapshot(
        transaction_fd, CONFIG_DISPLACED
    )
    if displaced_stat is not None:
        if exact_image_match(displaced_data, displaced_stat, preimage):
            retain_displaced_preimage(transaction_fd, preimage)
        else:
            preserve_exchange_artifact(
                home_fd,
                transaction_fd,
                CONFIG_DISPLACED,
                displaced_data,
                displaced_stat,
                "writer",
            )
    if incomplete_staging:
        return "config-incomplete-staging"
    return "config-writer-conflict"


def restore_config_exchange_preimage_v3(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> str | None:
    home_fd, transaction_fd = open_config_exchange_directories(
        document,
        authenticated_transaction_fd,
    )
    try:
        incomplete_staging = discard_config_staging_artifact(
            document,
            transaction_fd,
        )
        preimage = document["preimages"]["config"]
        prepared_data, prepared_stat = exchange_snapshot(
            transaction_fd, CONFIG_PREPARED
        )
        displaced_data, displaced_stat = exchange_snapshot(
            transaction_fd, CONFIG_DISPLACED
        )
        observed_data, observed_stat = exchange_snapshot(
            transaction_fd, CONFIG_OBSERVED
        )
        try:
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        except InstallError:
            return retain_v3_exchange_conflict(
                document,
                home_fd,
                transaction_fd,
            )

        if (
            prepared_stat is not None
            and current_stat is not None
            and same_inode(prepared_stat, current_stat)
            and prepared_config_is_owned(
                document,
                prepared_data,
                prepared_stat,
                link_delta=1,
            )
            and publication_snapshot_matches(
                document,
                current_data,
                current_stat,
                link_delta=1,
            )
        ):
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_PREPARED,
                "transaction-config-conflict",
            )
            prepared_data, prepared_stat = b"", None
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")

        displaced_is_preimage = (
            displaced_stat is not None
            and exact_image_match(displaced_data, displaced_stat, preimage)
        )
        current_is_preimage = exact_image_match(current_data, current_stat, preimage)
        current_is_publication = publication_snapshot_matches(
            document,
            current_data,
            current_stat,
        )
        observed_is_publication = (
            observed_stat is not None
            and publication_snapshot_matches(
                document,
                observed_data,
                observed_stat,
            )
        )
        prepared_is_owned = (
            prepared_stat is not None
            and prepared_config_is_owned(document, prepared_data, prepared_stat)
        )

        writer_conflict = False
        if prepared_stat is not None and not prepared_is_owned:
            writer_conflict = True
        if observed_stat is not None and not observed_is_publication:
            writer_conflict = True
        if displaced_stat is not None and not displaced_is_preimage:
            writer_conflict = True
        if current_stat is not None and not (
            current_is_publication
            or (current_is_preimage and displaced_stat is None)
        ):
            writer_conflict = True
        if (
            prepared_stat is not None
            and current_stat is not None
            and not current_is_preimage
        ):
            writer_conflict = True
        publication = document["config_exchange"]["publication"]
        if (
            publication["identity"] is not None
            and prepared_stat is None
            and not current_is_publication
            and not observed_is_publication
            and not (current_is_preimage and displaced_stat is None)
        ):
            writer_conflict = True
        if writer_conflict:
            return retain_v3_exchange_conflict(
                document,
                home_fd,
                transaction_fd,
            )

        if prepared_is_owned:
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_PREPARED,
                "transaction-config-conflict",
            )
        if current_is_publication:
            observed_data, observed_stat = move_live_config_to_observed(
                home_fd,
                transaction_fd,
            )
            if not publication_snapshot_matches(
                document,
                observed_data,
                observed_stat,
            ):
                raise InstallError("transaction-config-conflict")
            observed_is_publication = True

        current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        if displaced_is_preimage:
            if current_stat is not None:
                return retain_v3_exchange_conflict(
                    document,
                    home_fd,
                    transaction_fd,
                )
            if not restore_exchange_artifact(
                home_fd,
                transaction_fd,
                CONFIG_DISPLACED,
            ):
                return retain_v3_exchange_conflict(
                    document,
                    home_fd,
                    transaction_fd,
                )
        if observed_is_publication:
            observed_data, observed_stat = exchange_snapshot(
                transaction_fd, CONFIG_OBSERVED
            )
            if not publication_snapshot_matches(
                document,
                observed_data,
                observed_stat,
            ):
                raise InstallError("transaction-config-conflict")
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_OBSERVED,
                "transaction-config-conflict",
            )

        final_data, final_stat = exchange_snapshot(home_fd, "config.toml")
        if not exact_image_match(final_data, final_stat, preimage):
            raise InstallError("transaction-config-conflict")
        if incomplete_staging:
            return "config-incomplete-staging"
        return None
    finally:
        os.close(transaction_fd)
        os.close(home_fd)


def restore_config_exchange_preimage(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> str | None:
    if uses_publication_provenance(document):
        return restore_config_exchange_preimage_v3(
            document,
            authenticated_transaction_fd,
        )
    home_fd, transaction_fd = open_config_exchange_directories(
        document,
        authenticated_transaction_fd,
    )
    try:
        writer_conflict = repair_v2_preimage_link_transitions(
            document,
            home_fd,
            transaction_fd,
        )
        preimage = document["preimages"]["config"]
        desired = document["desired"]["config"]
        desired_observed = False
        incomplete_staging = False

        observed_data, observed_stat = exchange_snapshot(
            transaction_fd, CONFIG_OBSERVED
        )
        if observed_stat is not None:
            _, current_stat = exchange_snapshot(home_fd, "config.toml")
            observed_position = exchange_snapshot_position(
                observed_data,
                observed_stat,
                preimage,
                desired,
            )
            if observed_position == "desired" and current_stat is None:
                desired_observed = True
            elif observed_position == "desired":
                unlink_exchange_artifact(
                    transaction_fd,
                    CONFIG_OBSERVED,
                    "transaction-config-conflict",
                )
            elif observed_position == "preimage":
                preserve_exchange_artifact(
                    home_fd,
                    transaction_fd,
                    CONFIG_OBSERVED,
                    observed_data,
                    observed_stat,
                    "preimage",
                )
            else:
                preserve_exchange_artifact(
                    home_fd,
                    transaction_fd,
                    CONFIG_OBSERVED,
                    observed_data,
                    observed_stat,
                    "writer",
                )
                writer_conflict = True

        if not writer_conflict:
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
            if current_stat is not None and not exact_image_match(
                current_data,
                current_stat,
                preimage,
            ):
                if desired_observed:
                    if not remove_desired_exchange_artifact(
                        transaction_fd,
                        CONFIG_OBSERVED,
                        desired,
                    ):
                        observed_data, observed_stat = exchange_snapshot(
                            transaction_fd, CONFIG_OBSERVED
                        )
                        if observed_stat is None:
                            raise InstallError("transaction-config-conflict")
                        preserve_exchange_artifact(
                            home_fd,
                            transaction_fd,
                            CONFIG_OBSERVED,
                            observed_data,
                            observed_stat,
                            "writer",
                        )
                        writer_conflict = True
                    desired_observed = False
                if not writer_conflict:
                    observed_data, observed_stat = move_live_config_to_observed(
                        home_fd,
                        transaction_fd,
                    )
                    if observed_stat is not None:
                        observed_position = exchange_snapshot_position(
                            observed_data,
                            observed_stat,
                            preimage,
                            desired,
                        )
                        if observed_position == "desired":
                            desired_observed = True
                        elif observed_position == "preimage":
                            preserve_exchange_artifact(
                                home_fd,
                                transaction_fd,
                                CONFIG_OBSERVED,
                                observed_data,
                                observed_stat,
                                "preimage",
                            )
                        else:
                            preserve_exchange_artifact(
                                home_fd,
                                transaction_fd,
                                CONFIG_OBSERVED,
                                observed_data,
                                observed_stat,
                                "writer",
                            )
                            writer_conflict = True

        if resolve_prepared_config(document, transaction_fd, desired):
            incomplete_staging = True

        if desired_observed:
            if remove_desired_exchange_artifact(
                transaction_fd,
                CONFIG_OBSERVED,
                desired,
            ):
                desired_observed = False
            else:
                observed_data, observed_stat = exchange_snapshot(
                    transaction_fd, CONFIG_OBSERVED
                )
                if observed_stat is None:
                    raise InstallError("transaction-config-conflict")
                preserve_exchange_artifact(
                    home_fd,
                    transaction_fd,
                    CONFIG_OBSERVED,
                    observed_data,
                    observed_stat,
                    "writer",
                )
                writer_conflict = True
                desired_observed = False

        if writer_conflict:
            retain_displaced_preimage(transaction_fd, preimage)
            if incomplete_staging:
                return "config-incomplete-staging"
            return "config-writer-conflict"

        displaced_data, displaced_stat = exchange_snapshot(
            transaction_fd, CONFIG_DISPLACED
        )
        if displaced_stat is not None and not exact_image_match(
            displaced_data,
            displaced_stat,
            preimage,
        ):
            raise InstallError("transaction-config-conflict")
        current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        if exact_image_match(current_data, current_stat, preimage):
            if same_inode(current_stat, displaced_stat):
                unlink_exchange_artifact(
                    transaction_fd,
                    CONFIG_DISPLACED,
                    "transaction-config-conflict",
                )
        elif current_stat is None and displaced_stat is not None:
            if not restore_exchange_artifact(
                home_fd,
                transaction_fd,
                CONFIG_DISPLACED,
            ):
                retain_displaced_preimage(transaction_fd, preimage)
                if incomplete_staging:
                    return "config-incomplete-staging"
                return "config-writer-conflict"
        elif current_stat is not None:
            retain_displaced_preimage(transaction_fd, preimage)
            if incomplete_staging:
                return "config-incomplete-staging"
            return "config-writer-conflict"

        final_data, final_stat = exchange_snapshot(home_fd, "config.toml")
        if not exact_image_match(final_data, final_stat, preimage):
            raise InstallError("transaction-config-conflict")
        if incomplete_staging:
            return "config-incomplete-staging"
        return None
    finally:
        os.close(transaction_fd)
        os.close(home_fd)


def finalize_config_exchange_v3(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> str | None:
    home_fd, transaction_fd = open_config_exchange_directories(
        document,
        authenticated_transaction_fd,
    )
    try:
        incomplete_staging = discard_config_staging_artifact(
            document,
            transaction_fd,
        )
        try:
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        except InstallError:
            return retain_v3_exchange_conflict(
                document,
                home_fd,
                transaction_fd,
            )
        prepared_data, prepared_stat = exchange_snapshot(
            transaction_fd, CONFIG_PREPARED
        )
        if (
            prepared_stat is not None
            and current_stat is not None
            and same_inode(prepared_stat, current_stat)
            and prepared_config_is_owned(
                document,
                prepared_data,
                prepared_stat,
                link_delta=1,
            )
            and publication_snapshot_matches(
                document,
                current_data,
                current_stat,
                link_delta=1,
            )
        ):
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_PREPARED,
                "transaction-config-conflict",
            )
            prepared_stat = None
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        if prepared_stat is not None or not publication_snapshot_matches(
            document,
            current_data,
            current_stat,
        ):
            return retain_v3_exchange_conflict(
                document,
                home_fd,
                transaction_fd,
            )
        observed_data, observed_stat = exchange_snapshot(
            transaction_fd, CONFIG_OBSERVED
        )
        if observed_stat is not None:
            if not publication_snapshot_matches(
                document,
                observed_data,
                observed_stat,
            ):
                return retain_v3_exchange_conflict(
                    document,
                    home_fd,
                    transaction_fd,
                )
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_OBSERVED,
                "transaction-config-conflict",
            )
        displaced_data, displaced_stat = exchange_snapshot(
            transaction_fd, CONFIG_DISPLACED
        )
        if displaced_stat is not None:
            if not exact_image_match(
                displaced_data,
                displaced_stat,
                document["preimages"]["config"],
            ):
                return retain_v3_exchange_conflict(
                    document,
                    home_fd,
                    transaction_fd,
                )
        assert_transaction_directory_binding(
            transaction_fd,
            verify_current_codex_home(),
        )
        try:
            commit_data, commit_stat = exchange_snapshot(home_fd, "config.toml")
        except InstallError:
            return retain_v3_exchange_conflict(
                document,
                home_fd,
                transaction_fd,
            )
        if not publication_snapshot_matches(document, commit_data, commit_stat):
            return retain_v3_exchange_conflict(
                document,
                home_fd,
                transaction_fd,
            )
        if displaced_stat is not None:
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_DISPLACED,
                "transaction-config-conflict",
            )
        if incomplete_staging:
            return "config-incomplete-staging"
        return None
    finally:
        os.close(transaction_fd)
        os.close(home_fd)


def finalize_config_exchange(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> str | None:
    if not uses_config_exchange(document):
        return None
    if uses_publication_provenance(document):
        return finalize_config_exchange_v3(
            document,
            authenticated_transaction_fd,
        )
    home_fd, transaction_fd = open_config_exchange_directories(
        document,
        authenticated_transaction_fd,
    )
    try:
        writer_conflict = repair_v2_preimage_link_transitions(
            document,
            home_fd,
            transaction_fd,
        )
        desired = document["desired"]["config"]
        preimage = document["preimages"]["config"]
        incomplete_staging = False
        current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        if not image_matches_snapshot(
            current_data,
            current_stat,
            desired,
            metadata_required=False,
        ):
            raise InstallError("transaction-config-conflict")
        observed_data, observed_stat = exchange_snapshot(
            transaction_fd, CONFIG_OBSERVED
        )
        if observed_stat is not None:
            if image_matches_snapshot(
                observed_data,
                observed_stat,
                desired,
                metadata_required=False,
            ):
                unlink_exchange_artifact(
                    transaction_fd,
                    CONFIG_OBSERVED,
                    "transaction-config-conflict",
                )
            else:
                preserve_exchange_artifact(
                    home_fd,
                    transaction_fd,
                    CONFIG_OBSERVED,
                    observed_data,
                    observed_stat,
                    "writer",
                )
                writer_conflict = True
        if resolve_prepared_config(document, transaction_fd, desired):
            incomplete_staging = True
        if writer_conflict:
            retain_displaced_preimage(transaction_fd, preimage)
            if incomplete_staging:
                return "config-incomplete-staging"
            return "config-writer-conflict"
        displaced_data, displaced_stat = exchange_snapshot(
            transaction_fd, CONFIG_DISPLACED
        )
        if displaced_stat is not None:
            if not exact_image_match(
                displaced_data,
                displaced_stat,
                preimage,
            ):
                raise InstallError("transaction-config-conflict")
            unlink_exchange_artifact(
                transaction_fd,
                CONFIG_DISPLACED,
                "transaction-config-conflict",
            )
        if incomplete_staging:
            return "config-incomplete-staging"
        return None
    finally:
        os.close(transaction_fd)
        os.close(home_fd)


def classify_file_position(
    path: Path,
    preimage: dict[str, Any],
    desired: dict[str, Any],
    code: str,
) -> str:
    data, file_stat = read_transaction_target(path, code)
    if image_matches_snapshot(data, file_stat, preimage, metadata_required=True):
        return "preimage"
    if image_matches_snapshot(data, file_stat, desired, metadata_required=False):
        return "desired"
    raise InstallError(code)


def archive_position(record: dict[str, str]) -> str:
    source = Path(record["source"])
    destination = Path(record["destination"])
    source_data, source_stat = read_transaction_target(
        source, "transaction-archive-conflict"
    )
    destination_data, destination_stat = read_transaction_target(
        destination, "transaction-archive-conflict"
    )
    expected_digest = record["sha256"]
    source_matches = (
        source_stat is not None and digest_bytes(source_data) == expected_digest
    )
    destination_matches = (
        destination_stat is not None
        and digest_bytes(destination_data) == expected_digest
    )
    if source_matches and destination_stat is None:
        return "preimage"
    if source_stat is None and destination_matches:
        return "desired"
    raise InstallError("transaction-archive-conflict")


def validate_transaction_archive_directory(document: dict[str, Any]) -> None:
    raw_path = document["paths"]["archive_directory"]
    if raw_path is None:
        return
    archive_dir = bind_codex_path(
        Path(raw_path),
        "transaction-archive-conflict",
    )
    try:
        archive_stat = archive_dir.lstat()
    except FileNotFoundError:
        return
    except OSError:
        raise InstallError("transaction-archive-conflict") from None
    if (
        not stat.S_ISDIR(archive_stat.st_mode)
        or archive_dir.is_symlink()
        or archive_stat.st_uid != os.geteuid()
        or stat.S_IMODE(archive_stat.st_mode) & 0o077
    ):
        raise InstallError("transaction-archive-conflict")


def config_exchange_converged_v3(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> bool:
    home_fd, transaction_fd = open_config_exchange_directories(
        document,
        authenticated_transaction_fd,
    )
    try:
        for label in ("staging", "prepared"):
            marker_name, _ = incomplete_staging_names(document, label)
            _, marker_stat = exchange_snapshot(transaction_fd, marker_name)
            if marker_stat is not None:
                return False
        try:
            staging_stat = os.stat(
                config_staging_name(document),
                dir_fd=transaction_fd,
                follow_symlinks=False,
            )
        except FileNotFoundError:
            staging_stat = None
        except OSError:
            raise InstallError("transaction-config-conflict") from None
        if staging_stat is not None and not stat.S_ISREG(staging_stat.st_mode):
            raise InstallError("transaction-config-conflict")
        _, prepared_stat = exchange_snapshot(transaction_fd, CONFIG_PREPARED)
        _, observed_stat = exchange_snapshot(transaction_fd, CONFIG_OBSERVED)
        try:
            current_data, current_stat = exchange_snapshot(home_fd, "config.toml")
        except InstallError:
            return False
        return (
            staging_stat is None
            and prepared_stat is None
            and observed_stat is None
            and publication_snapshot_matches(
                document,
                current_data,
                current_stat,
            )
        )
    finally:
        os.close(transaction_fd)
        os.close(home_fd)


def transaction_converged(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> bool:
    validate_transaction_archive_directory(document)
    paths = document["paths"]
    desired = document["desired"]
    target_keys = (
        ("receipt",)
        if uses_publication_provenance(document)
        else ("config", "receipt")
    )
    for key in target_keys:
        data, file_stat = read_transaction_target(
            Path(paths[key]), f"transaction-{key}-conflict"
        )
        if not image_matches_snapshot(
            data,
            file_stat,
            desired[key],
            metadata_required=False,
        ):
            return False
    if uses_publication_provenance(document) and not config_exchange_converged_v3(
        document,
        authenticated_transaction_fd,
    ):
        return False
    return all(archive_position(record) == "desired" for record in document["archives"])


def non_config_targets_at_preimage(document: dict[str, Any]) -> bool:
    validate_transaction_archive_directory(document)
    paths = document["paths"]
    if classify_file_position(
        Path(paths["receipt"]),
        document["preimages"]["receipt"],
        document["desired"]["receipt"],
        "transaction-receipt-conflict",
    ) != "preimage":
        return False
    return all(archive_position(record) == "preimage" for record in document["archives"])


def durable_unlink(
    path: Path,
    expected_data: bytes,
    expected_stat: os.stat_result,
    *,
    code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> None:
    assert_preimage(
        path,
        expected_data,
        expected_stat,
        code=code,
        invalid_code=code,
        max_bytes=max_bytes,
    )
    try:
        path.unlink()
        fsync_directory(path.parent, code)
    except OSError:
        raise InstallError(code) from None


def durable_unlink_at(
    directory_fd: int,
    directory_path: Path,
    name: str,
    expected_data: bytes,
    expected_stat: os.stat_result,
    *,
    code: str,
    max_bytes: int = MAX_PREIMAGE_BYTES,
) -> None:
    assert_transaction_directory_binding(
        directory_fd,
        verify_current_codex_home(),
    )
    assert_preimage_at(
        directory_fd,
        name,
        expected_data,
        expected_stat,
        code=code,
        invalid_code=code,
        max_bytes=max_bytes,
    )
    quarantine_name, moved_data, moved_stat = quarantine_entry(
        directory_fd,
        name,
        directory_fd,
        expected_data=expected_data,
        expected_stat=expected_stat,
        label=f"retire-{name}",
        code=code,
        max_bytes=max_bytes,
    )
    unlink_authenticated_quarantine(
        directory_fd,
        quarantine_name,
        moved_data,
        moved_stat,
        code=code,
        max_bytes=max_bytes,
    )


def retire_transaction_journal(
    document: dict[str, Any],
    journal_path: Path,
    journal_raw: bytes,
    journal_stat: os.stat_result,
    transaction_fd: int,
) -> None:
    """Retire immutable generations oldest-first, preserving crash recovery."""
    loaded = load_transaction_journal(
        _BOUND_CODEX_HOME_PATH or journal_path.parent.parent,
        transaction_fd,
    )
    if loaded is None:
        raise InstallError("transaction-journal-remove-failed")
    loaded_document, loaded_path, loaded_raw, loaded_stat, loaded_fd = loaded
    os.close(loaded_fd)
    if (
        loaded_path.name != journal_path.name
        or not snapshot_matches(
            loaded_raw,
            loaded_stat,
            journal_raw,
            journal_stat,
        )
    ):
        raise InstallError("transaction-journal-conflict")
    journal = loaded_document.get("journal")
    if not isinstance(journal, dict):
        durable_unlink_at(
            transaction_fd,
            journal_path.parent,
            journal_path.name,
            journal_raw,
            journal_stat,
            code="transaction-journal-remove-failed",
            max_bytes=MAX_JOURNAL_BYTES,
        )
        return
    pattern = re.compile(
        rf"{re.escape(TRANSACTION_JOURNAL)}\.{journal['id']}\.([0-9]{{8}})"
    )
    try:
        names = sorted(
            (
                (int(match.group(1)), name)
                for name in os.listdir(transaction_fd)
                if (match := pattern.fullmatch(name)) is not None
            ),
            key=lambda item: item[0],
        )
    except OSError:
        raise InstallError("transaction-journal-remove-failed") from None
    if not names or names[-1][1] != journal_path.name:
        raise InstallError("transaction-journal-conflict")
    for generation, name in names:
        raw, file_stat = read_regular_snapshot_at(
            transaction_fd,
            name,
            invalid_code="transaction-journal-unsafe",
            unreadable_code="transaction-journal-unreadable",
            oversized_code="transaction-journal-too-large",
            max_bytes=MAX_JOURNAL_BYTES,
        )
        if file_stat is None:
            raise InstallError("transaction-journal-conflict")
        try:
            candidate = validate_transaction_document(
                json.loads(raw.decode("utf-8")),
                _BOUND_CODEX_HOME_PATH or journal_path.parent.parent,
            )
        except (UnicodeError, json.JSONDecodeError):
            raise InstallError("transaction-journal-invalid") from None
        candidate_journal = candidate.get("journal")
        if (
            not isinstance(candidate_journal, dict)
            or candidate_journal["id"] != journal["id"]
            or candidate_journal["generation"] != generation
            or (
                name == journal_path.name
                and not snapshot_matches(
                    raw,
                    file_stat,
                    journal_raw,
                    journal_stat,
                )
            )
        ):
            raise InstallError("transaction-journal-conflict")
        durable_unlink_at(
            transaction_fd,
            journal_path.parent,
            name,
            raw,
            file_stat,
            code="transaction-journal-remove-failed",
            max_bytes=MAX_JOURNAL_BYTES,
        )


def restore_file_preimage(
    path: Path,
    preimage: dict[str, Any],
    desired: dict[str, Any],
    code: str,
) -> None:
    path = bind_codex_path(path, code)
    position = classify_file_position(path, preimage, desired, code)
    if position == "preimage":
        return
    current_data, current_stat = read_transaction_target(path, code)
    preimage_data, metadata = decode_file_image(preimage)
    if preimage_data is None:
        if current_stat is None:
            return
        durable_unlink(path, current_data, current_stat, code=code)
        return
    atomic_write(
        path,
        preimage_data,
        current_stat,
        metadata=metadata,
        expected_data=current_data,
        expected_stat=current_stat,
        preimage_code=code,
        invalid_code=code,
    )


def remove_transaction_archive_directory(document: dict[str, Any]) -> None:
    raw_path = document["paths"]["archive_directory"]
    if raw_path is None:
        return
    archive_dir = bind_codex_path(
        Path(raw_path),
        "transaction-archive-conflict",
    )
    try:
        archive_dir.rmdir()
        fsync_directory(archive_dir.parent, "transaction-archive-conflict")
    except FileNotFoundError:
        return
    except OSError:
        raise InstallError("transaction-archive-conflict") from None


def restore_transaction_preimages(
    document: dict[str, Any],
    authenticated_transaction_fd: int,
) -> str | None:
    validate_transaction_archive_directory(document)
    paths = document["paths"]
    preimages = document["preimages"]
    desired = document["desired"]
    target_keys = (
        ("receipt",)
        if uses_config_exchange(document)
        else ("config", "receipt")
    )
    positions = {
        key: classify_file_position(
            Path(paths[key]),
            preimages[key],
            desired[key],
            f"transaction-{key}-conflict",
        )
        for key in target_keys
    }
    archive_positions = [archive_position(record) for record in document["archives"]]
    config_error: str | None = None
    if uses_config_exchange(document):
        config_error = restore_config_exchange_preimage(
            document,
            authenticated_transaction_fd,
        )
    elif positions["config"] == "desired":
        restore_file_preimage(
            Path(paths["config"]),
            preimages["config"],
            desired["config"],
            "transaction-config-conflict",
        )
    for record, position in zip(document["archives"], archive_positions):
        if position == "preimage":
            continue
        source = bind_codex_path(
            Path(record["source"]),
            "transaction-archive-conflict",
        )
        destination = bind_codex_path(
            Path(record["destination"]),
            "transaction-archive-conflict",
        )
        if archive_position(record) != "desired":
            raise InstallError("transaction-archive-conflict")
        try:
            os.replace(destination, source)
            fsync_directory(source.parent, "transaction-archive-conflict")
            fsync_directory(destination.parent, "transaction-archive-conflict")
        except OSError:
            raise InstallError("transaction-archive-conflict") from None
    if positions["receipt"] == "desired":
        restore_file_preimage(
            Path(paths["receipt"]),
            preimages["receipt"],
            desired["receipt"],
            "transaction-receipt-conflict",
        )
    remove_transaction_archive_directory(document)
    verification_keys = (
        ("receipt",)
        if uses_config_exchange(document)
        else ("config", "receipt")
    )
    for key in verification_keys:
        if classify_file_position(
            Path(paths[key]),
            preimages[key],
            desired[key],
            f"transaction-{key}-conflict",
        ) != "preimage":
            raise InstallError("rollback-failed")
    if any(archive_position(record) != "preimage" for record in document["archives"]):
        raise InstallError("rollback-failed")
    return config_error


def recover_unfinished_transaction(codex_home: Path) -> bool:
    loaded = load_transaction_journal(codex_home)
    if loaded is None:
        return False
    document, journal_path, raw, journal_stat, transaction_fd = loaded
    try:
        if transaction_converged(document, transaction_fd):
            config_error = finalize_config_exchange(document, transaction_fd)
        else:
            config_error = restore_transaction_preimages(document, transaction_fd)
        retire_transaction_journal(
            document,
            journal_path,
            raw,
            journal_stat,
            transaction_fd,
        )
    finally:
        os.close(transaction_fd)
    if config_error is not None:
        raise InstallError(config_error)
    return True


def move_archives(
    candidates: list[tuple[Path, str]],
    archive_dir: Path,
) -> list[tuple[Path, Path]]:
    ensure_safe_directory(archive_dir.parent, create=True)
    if archive_dir.exists():
        raise InstallError("archive-conflict")
    try:
        archive_dir.mkdir(mode=0o700)
        fsync_directory(archive_dir.parent, "archive-create-failed")
    except OSError:
        raise InstallError("archive-create-failed") from None
    moved: list[tuple[Path, Path]] = []
    try:
        destination_names: set[str] = set()
        for source, expected_digest in candidates:
            if source.name in destination_names:
                raise InstallError("archive-conflict")
            destination_names.add(source.name)
            source_data, source_stat = read_transaction_target(
                source, "legacy-ownership-conflict"
            )
            if source_stat is None or digest_bytes(source_data) != expected_digest:
                raise InstallError("legacy-ownership-conflict")
            destination = archive_dir / source.name
            if destination.is_symlink() or destination.exists():
                raise InstallError("archive-conflict")
            os.replace(source, destination)
            moved.append((source, destination))
        fsync_directory(archive_dir, "archive-move-failed")
        for parent in {source.parent for source, _ in candidates}:
            fsync_directory(parent, "archive-move-failed")
    except (OSError, InstallError) as error:
        restored = True
        for source, destination in reversed(moved):
            try:
                os.replace(destination, source)
            except OSError:
                restored = False
        try:
            archive_dir.rmdir()
        except OSError:
            restored = False
        if restored:
            try:
                fsync_directory(archive_dir.parent, "rollback-failed")
                for parent in {source.parent for source, _ in candidates}:
                    fsync_directory(parent, "rollback-failed")
            except InstallError:
                restored = False
        if not restored:
            raise InstallError("rollback-failed") from None
        if isinstance(error, InstallError):
            raise error
        raise InstallError("archive-move-failed") from None
    return moved


def apply_plan(plan: dict[str, Any]) -> None:
    transaction_fd = -1
    try:
        document, journal_path, journal_raw, journal_stat, transaction_fd = (
            write_transaction_journal(plan)
        )
        assert_preimage(
            plan["config_path"],
            plan["config_data"],
            plan["config_stat"],
            code="config-preimage-drift",
            invalid_code="config-path-invalid",
        )
        if plan["config_changed"]:
            journal_path, journal_raw, journal_stat = displace_and_publish_config(
                plan,
                document,
                journal_path,
                journal_raw,
                journal_stat,
                transaction_fd,
            )
        if plan["candidates"]:
            move_archives(plan["candidates"], plan["archive_dir"])
        if plan["state_changed"]:
            desired_state = plan["desired_state"]
            if desired_state is None:
                durable_unlink(
                    plan["state_path"],
                    plan["state_data"],
                    plan["state_stat"],
                    code="receipt-preimage-drift",
                )
            else:
                atomic_write(
                    plan["state_path"],
                    desired_state,
                    plan["state_stat"],
                    expected_data=(
                        b"" if plan["state_data"] is None else plan["state_data"]
                    ),
                    expected_stat=plan["state_stat"],
                    preimage_code="receipt-preimage-drift",
                    invalid_code="receipt-path-invalid",
                )
        if not transaction_converged(document, transaction_fd):
            raise InstallError("transaction-commit-unproven")
        config_error = finalize_config_exchange(document, transaction_fd)
        retire_transaction_journal(
            document,
            journal_path,
            journal_raw,
            journal_stat,
            transaction_fd,
        )
        if config_error is not None:
            raise InstallError(config_error)
    except InstallError as error:
        config_error: str | None = None
        try:
            loaded = load_transaction_journal(
                plan["codex_home"],
                transaction_fd if transaction_fd >= 0 else None,
            )
            if loaded is None:
                raise error
            (
                document,
                journal_path,
                journal_raw,
                journal_stat,
                recovery_fd,
            ) = loaded
            if transaction_fd >= 0:
                os.close(transaction_fd)
            transaction_fd = recovery_fd
            if transaction_converged(document, transaction_fd):
                raise error
            config_error = restore_transaction_preimages(document, transaction_fd)
            retire_transaction_journal(
                document,
                journal_path,
                journal_raw,
                journal_stat,
                transaction_fd,
            )
        except InstallError as rollback_error:
            if rollback_error is error:
                raise error
            raise InstallError("rollback-failed") from None
        if config_error is not None:
            if (
                config_error == "config-writer-conflict"
                and error.code == "config-publish-conflict"
            ):
                raise error
            raise InstallError(config_error)
        raise error
    finally:
        if transaction_fd >= 0:
            os.close(transaction_fd)


def emit(
    *,
    operation: str,
    version: str,
    status: str,
    changed: bool,
    digest: str,
    archived: int,
    code: str | None = None,
) -> None:
    receipt: dict[str, Any] = {
        "plugin": PLUGIN_ID,
        "version": version,
        "operation": operation,
        "status": status,
        "changed": changed,
        "role_count": ROLE_COUNT,
        "archived_count": archived,
        "digest": digest,
    }
    if operation in {"install", "uninstall"} and status in {"changed", "no-op"}:
        receipt["new_task_required"] = True
    if code is not None:
        receipt["code"] = code
    print(json.dumps(receipt, sort_keys=True, separators=(",", ":")))


def open_coordination_lock_at(codex_home_fd: int, name: str) -> int:
    if not name or name in {".", ".."} or "/" in name:
        raise InstallError("lock-path-invalid")
    flags = os.O_RDWR | os.O_CREAT
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    try:
        lock_fd = os.open(name, flags, 0o600, dir_fd=codex_home_fd)
        lock_stat = os.fstat(lock_fd)
        if (
            not stat.S_ISREG(lock_stat.st_mode)
            or lock_stat.st_nlink != 1
            or lock_stat.st_uid != os.geteuid()
            or stat.S_IMODE(lock_stat.st_mode) != 0o600
        ):
            raise InstallError("lock-path-invalid")
        return lock_fd
    except InstallError:
        if "lock_fd" in locals():
            os.close(lock_fd)
        raise
    except OSError:
        raise InstallError("lock-open-failed") from None


def main() -> int:
    global _BOUND_CODEX_HOME_FD, _BOUND_CODEX_HOME_PATH
    args = parse_cli()
    plugin_root = Path(__file__).resolve().parent
    version = "unknown"
    digest = ""
    try:
        version, profiles = plugin_metadata(plugin_root)
        block = build_block(version, profiles)
        digest = digest_bytes(block)
        home_arg = args.codex_home
        if home_arg is None:
            home_arg = Path(os.environ.get("CODEX_HOME", "~/.codex"))
        codex_home = Path(os.path.abspath(os.fspath(home_arg.expanduser())))

        if args.dry_run:
            home_fd = open_codex_home_fd(codex_home, create=False)
            if home_fd is None:
                plan = plan_operation(
                    operation=args.operation,
                    codex_home=codex_home,
                    version=version,
                    profiles=profiles,
                    block=block,
                )
                emit(
                    operation=args.operation,
                    version=version,
                    status="dry-run",
                    changed=plan["changed"],
                    digest=plan["digest"],
                    archived=len(plan["candidates"]),
                )
                return 0
            _BOUND_CODEX_HOME_FD = home_fd
            _BOUND_CODEX_HOME_PATH = codex_home
            io_home = bound_home_path(home_fd)
            loaded_transaction = load_transaction_journal(codex_home)
            if loaded_transaction is not None:
                os.close(loaded_transaction[4])
                raise InstallError("transaction-recovery-required")
            plan = plan_operation(
                operation=args.operation,
                codex_home=io_home,
                version=version,
                profiles=profiles,
                block=block,
            )
            emit(
                operation=args.operation,
                version=version,
                status="dry-run",
                changed=plan["changed"],
                digest=plan["digest"],
                archived=len(plan["candidates"]),
            )
            os.close(home_fd)
            _BOUND_CODEX_HOME_FD = -1
            _BOUND_CODEX_HOME_PATH = None
            return 0

        home_fd = open_codex_home_fd(
            codex_home,
            create=args.operation == "install",
        )
        if args.operation == "uninstall" and home_fd is None:
            emit(
                operation=args.operation,
                version=version,
                status="no-op",
                changed=False,
                digest=digest,
                archived=0,
            )
            return 0
        if home_fd is None:
            raise InstallError("codex-home-invalid")
        _BOUND_CODEX_HOME_FD = home_fd
        _BOUND_CODEX_HOME_PATH = codex_home
        io_home = bound_home_path(home_fd)
        config_lock_fd = open_coordination_lock_at(
            home_fd,
            CONFIG_COORDINATION_LOCK,
        )
        try:
            operation_lock_fd = open_coordination_lock_at(
                home_fd,
                f".{PLUGIN_ID}.lock",
            )
        except InstallError:
            os.close(config_lock_fd)
            raise
        try:
            fcntl.flock(config_lock_fd, fcntl.LOCK_EX)
            fcntl.flock(operation_lock_fd, fcntl.LOCK_EX)
            recover_unfinished_transaction(codex_home)
            plan = plan_operation(
                operation=args.operation,
                codex_home=io_home,
                version=version,
                profiles=profiles,
                block=block,
            )
            if plan["changed"]:
                apply_plan(plan)
                status = "changed"
            else:
                status = "no-op"
        finally:
            os.close(operation_lock_fd)
            os.close(config_lock_fd)
            os.close(home_fd)
            _BOUND_CODEX_HOME_FD = -1
            _BOUND_CODEX_HOME_PATH = None
        emit(
            operation=args.operation,
            version=version,
            status=status,
            changed=plan["changed"],
            digest=plan["digest"],
            archived=len(plan["candidates"]),
        )
        return 0
    except InstallError as error:
        emit(
            operation=getattr(args, "operation", "install"),
            version=version,
            status="error",
            changed=False,
            digest=digest,
            archived=0,
            code=error.code,
        )
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
