{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/plugins/bears/schemas/blocker-review.schema.json",
  "title": "Bears workflow-overlay blocker review packet",
  "type": "object",
  "required": [
    "schema",
    "version",
    "status",
    "blockers",
    "reviewer"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "bears-workflow-overlay.blocker-review"
    },
    "version": {
      "type": "string",
      "enum": ["1", "1.0", "v1"]
    },
    "status": {
      "type": "string",
      "enum": ["clean", "blocked", "review", "waived"]
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "taxonomy", "severity", "description"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "taxonomy": {
            "type": "string",
            "enum": ["access", "coverage", "artifacts", "runtime", "abuse", "spec"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "description": {"type": "string", "minLength": 1},
          "mitigation": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      },
      "default": []
    },
    "resolved_at": {
      "type": "string",
      "description": "ISO-8601 timestamp"
    }
  },
  "additionalProperties": true
}
