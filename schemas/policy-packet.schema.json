{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/plugins/bears/schemas/policy-packet.schema.json",
  "title": "Bears workflow-overlay policy packet",
  "type": "object",
  "required": [
    "schema",
    "version",
    "status",
    "project_router",
    "policy_id",
    "owner",
    "scope"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "bears-workflow-overlay.policy-packet"
    },
    "version": {
      "type": "string",
      "enum": ["1", "1.0", "v1"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "blocked", "deprecated"]
    },
    "project_router": {
      "type": "string",
      "minLength": 1
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "required": ["name", "team", "contact"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "team": {"type": "string", "minLength": 1},
        "contact": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "required": ["project_group", "artifact_type"],
      "properties": {
        "project_group": {"type": "string", "minLength": 1},
        "artifact_type": {"type": "string", "enum": ["workflow", "plugin", "artifact", "role-gate"]}
      },
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp"
    }
  },
  "additionalProperties": true
}
