{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bears.local/plugins/bears/schemas/role-coverage.schema.json",
  "title": "Bears workflow-overlay role coverage packet",
  "type": "object",
  "required": [
    "schema",
    "version",
    "status",
    "route_target",
    "coverage_status",
    "roles"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "bears-workflow-overlay.role-coverage"
    },
    "version": {
      "type": "string",
      "enum": ["1", "1.0", "v1"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "ok", "blocked", "deferred"]
    },
    "route_target": {
      "type": "string",
      "minLength": 1
    },
    "coverage_status": {
      "type": "string",
      "enum": ["complete", "partial", "missing", "blocked"]
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "covered", "owner"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "covered": {"type": "boolean"},
          "owner": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
