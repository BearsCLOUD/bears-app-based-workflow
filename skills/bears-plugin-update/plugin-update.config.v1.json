{
  "schema": "bears-plugin-update.config.v1",
  "version": "1",
  "owner_plugin": "bears",
  "root_resolution": {
    "marker": ".codex-plugin/plugin.json",
    "search": "nearest_ancestor",
    "absolute_path_required": false
  },
  "owner_surfaces": [
    {
      "id": "central_plugin_config",
      "description": "Shared @Bears plugin policy, catalogs, roles, hooks, scripts, generated inventory, governance schemas, and skill workflow rules."
    },
    {
      "id": "target_agents_md",
      "description": "Nearest target AGENTS.md for repo-local or path-local ownership rules, forbidden paths, and source-of-truth pointers."
    },
    {
      "id": "target_codex",
      "description": "Target-local .codex surface for materialized Codex runtime behavior scoped to that target."
    }
  ],
  "changed_fact_classification": {
    "default_owner_surface": "central_plugin_config",
    "target_specific_rule_owner": "target_agents_md",
    "target_runtime_codex_owner": "target_codex"
  },
  "sequential_audit_review": {
    "triggers": [
      "assets/catalog/platform-role-catalog.v1.json",
      "skills/bears-plugin-update/SKILL.md"
    ],
    "exemptions": [
      {
        "id": "role_profile_only",
        "when_changed_set_contains_only": [
          "agents/*.toml"
        ]
      }
    ],
    "manifest_scope": [
      "git_tracked_files",
      "git_untracked_unignored_files"
    ],
    "review_order": "sorted_path",
    "file_kinds": [
      "text_file",
      "generated_file",
      "directory",
      "binary_or_non_text"
    ],
    "text_review": "line_by_line",
    "directory_review": "child_inventory",
    "generated_file_review": "record_generator_source"
  },
  "audit_packet": {
    "schema": "bears-plugin-update.audit-packet.v1",
    "required_fields": [
      "schema",
      "changed_targets",
      "reviewed_files",
      "reviewed_line_ranges",
      "drift_items",
      "planned_tasks_added"
    ],
    "file_entry_fields": [
      "path",
      "kind",
      "reviewed_line_ranges",
      "constitution_alignment",
      "update_skill_alignment",
      "owner_surface",
      "drift_items"
    ]
  }
}
