{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "architecture-packet.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal_id",
    "role",
    "repo_boundary",
    "module_boundaries",
    "dependency_graph",
    "migration_map",
    "contract_map",
    "risk_map",
    "validation_plan",
    "parallelizable_task_graph",
    "restricted_data_taint",
    "status"
  ],
  "properties": {
    "goal_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "repo_boundary": {
      "type": "string"
    },
    "module_boundaries": {
      "type": "string"
    },
    "dependency_graph": {
      "type": "string"
    },
    "migration_map": {
      "type": "string"
    },
    "contract_map": {
      "type": "string"
    },
    "risk_map": {
      "type": "string"
    },
    "validation_plan": {
      "type": "string"
    },
    "parallelizable_task_graph": {
      "type": "string"
    },
    "restricted_data_taint": {
      "enum": [
        "none",
        "blocked"
      ]
    },
    "status": {
      "type": "string"
    }
  },
  "description": "Forbidden data classes: raw secrets, .env values, raw logs, raw chats, raw VPN configs, credential files, and production data are not allowed."
}
