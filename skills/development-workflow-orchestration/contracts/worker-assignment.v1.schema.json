{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "worker-assignment.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal_id",
    "task_id",
    "role",
    "repo_boundary",
    "branch_worktree",
    "allowed_write_scope",
    "forbidden_scope",
    "validation_commands",
    "required_tests",
    "closeout_schema",
    "no_secret_no_live_mutation_rules",
    "restricted_data_taint",
    "status"
  ],
  "properties": {
    "goal_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "repo_boundary": {
      "type": "string"
    },
    "branch_worktree": {
      "type": "string"
    },
    "allowed_write_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "closeout_schema": {
      "type": "string"
    },
    "no_secret_no_live_mutation_rules": {
      "type": "string"
    },
    "restricted_data_taint": {
      "enum": [
        "none",
        "blocked"
      ]
    },
    "status": {
      "type": "string"
    }
  },
  "description": "Forbidden data classes: raw secrets, .env values, raw logs, raw chats, raw VPN configs, credential files, and production data are not allowed."
}
