      "trust_secret_impact": "Workspace-control agent reviewer role tests only. No raw secrets, tokens, private keys, raw logs, raw chats, provider data, production data, frontend, mobile, UI, or app-screen assets are allowed.",
      "validation_commands": [
        "python3 /srv/bears/plugins/bears/scripts/project_registry_gate.py gate /srv/bears/control-plane/workspace-control/tests/test_agent_reviewer_roles.py",
        "cd /srv/bears/plugins/bears && python3 scripts/subagents_roles.py route /srv/bears/control-plane/workspace-control/tests/test_agent_reviewer_roles.py",
        "cd /srv/bears/plugins/bears && python3 scripts/subagents_roles.py audit /srv/bears/control-plane/workspace-control/tests/test_agent_reviewer_roles.py",
        "python3 /srv/bears/plugins/bears/scripts/project_registry_gate.py validate-registry"
      ],
      "rollback_note": "Remove this registry entry before disabling workspace-control agent reviewer role test governance coverage."
