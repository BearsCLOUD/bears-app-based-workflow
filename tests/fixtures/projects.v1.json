      "classification": "workspace_control_test_governance",
      "canonical_remote": "BearsCLOUD/bears-codex-workspace",
      "canonical_remote_url": "https://github.com/BearsCLOUD/bears-codex-workspace",
      "local_path": "/srv/bears/control-plane/workspace-control/tests",
      "root_owned_payload": true,
      "primary_role": "bears-subagents-roles-governor",
      "supporting_roles": [
        "bears-platform-security-reviewer"
